#!/usr/bin/env python3
"""Root notification contract for agent-do."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))

from notify import (  # noqa: E402
    apply_template,
    delete_group,
    delete_rule,
    emit_event,
    get_group,
    get_recipient,
    get_rule,
    get_template,
    list_groups,
    list_recipients,
    list_rules,
    list_templates,
    load_config,
    load_rules,
    load_state,
    main_json,
    parse_provider_list,
    parse_duration_seconds,
    parse_key_value_pairs,
    providers_payload,
    render_text_result,
    reset_state,
    save_config,
    save_rules,
    save_state,
    send_notification,
    update_group,
    update_rule,
    update_recipient,
)
from live.errors import LiveApprovalRequiredError  # noqa: E402


def preprocess_args(argv: list[str]) -> list[str]:
    commands = {
        "send",
        "providers",
        "recipients",
        "groups",
        "show",
        "show-group",
        "set-recipient",
        "set-group",
        "rules",
        "show-rule",
        "set-rule",
        "templates",
        "show-template",
        "apply-template",
        "delete-group",
        "delete-rule",
        "emit",
        "reset-state",
        "help",
        "--help",
        "-h",
    }
    if argv and argv[0] not in commands and not argv[0].startswith("-"):
        return ["send", *argv]
    return argv


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="agent-do notify",
        description="Cross-provider notification contract for SMS, email, Slack, Messenger, and local pipe delivery",
    )
    parser.add_argument("--json", action="store_true", help="Output structured JSON")

    subparsers = parser.add_subparsers(dest="command")

    send_parser = subparsers.add_parser("send", help="Send a notification")
    send_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    send_parser.add_argument("recipient", help="Configured alias or raw provider target")
    send_parser.add_argument("message", help="Notification message body")
    send_parser.add_argument("--via", help="Comma-separated provider order, e.g. sms,slack,email")
    send_parser.add_argument("--subject", help="Subject line for email transports")
    send_parser.add_argument("--all", action="store_true", help="Send through all matching providers instead of stopping at first success")
    send_parser.add_argument("--dry-run", action="store_true", help="Show planned routing without sending")

    providers_parser = subparsers.add_parser("providers", help="List supported notify providers")
    providers_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    recipients_parser = subparsers.add_parser("recipients", help="List configured recipient aliases")
    recipients_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    groups_parser = subparsers.add_parser("groups", help="List configured recipient groups")
    groups_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    show_parser = subparsers.add_parser("show", help="Show one configured recipient")
    show_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    show_parser.add_argument("alias", help="Recipient alias")

    show_group_parser = subparsers.add_parser("show-group", help="Show one configured recipient group")
    show_group_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    show_group_parser.add_argument("alias", help="Group alias")

    set_parser = subparsers.add_parser("set-recipient", help="Create or update a recipient alias")
    set_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    set_parser.add_argument("alias", help="Recipient alias")
    set_parser.add_argument("--sms", help="Phone number target")
    set_parser.add_argument("--email", help="Email address target")
    set_parser.add_argument("--slack", help="Slack channel or DM target")
    set_parser.add_argument("--messenger", help="Messenger conversation URL or thread target")
    set_parser.add_argument("--pipe", help="Shell command target for pipe delivery")
    set_parser.add_argument("--prefer", help="Comma-separated preferred provider order")
    set_parser.add_argument("--subject", help="Default subject for email notifications")

    set_group_parser = subparsers.add_parser("set-group", help="Create or update a recipient group")
    set_group_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    set_group_parser.add_argument("alias", help="Group alias")
    set_group_parser.add_argument("members", nargs="+", help="Recipient or group aliases")

    rules_parser = subparsers.add_parser("rules", help="List configured notification rules")
    rules_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    templates_parser = subparsers.add_parser("templates", help="List built-in notification rule templates")
    templates_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)

    show_template_parser = subparsers.add_parser("show-template", help="Show one built-in notification rule template")
    show_template_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    show_template_parser.add_argument("name", help="Template name")

    show_rule_parser = subparsers.add_parser("show-rule", help="Show one configured notification rule")
    show_rule_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    show_rule_parser.add_argument("name", help="Rule name")

    set_rule_parser = subparsers.add_parser("set-rule", help="Create or update a notification rule")
    set_rule_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    set_rule_parser.add_argument("name", help="Rule name")
    set_rule_parser.add_argument("--recipient", required=True, help="Configured notify recipient alias")
    set_rule_parser.add_argument("--event", required=True, help="Event name to match")
    set_rule_parser.add_argument("--message", required=True, help="Message template, e.g. 'Build failed for {service}'")
    set_rule_parser.add_argument("--subject", help="Optional subject template")
    set_rule_parser.add_argument("--via", help="Comma-separated provider order for this rule")
    set_rule_parser.add_argument("--match", action="append", default=[], help="Exact fact match in key=value form; may be repeated")
    set_rule_parser.add_argument("--fingerprint", help="Template for cooldown fingerprint, e.g. '{service}:{branch}'")
    set_rule_parser.add_argument("--cooldown", help="Cooldown duration like 15m, 1h, or 1d")

    apply_template_parser = subparsers.add_parser("apply-template", help="Create a rule from a built-in notification template")
    apply_template_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    apply_template_parser.add_argument("template", help="Template name")
    apply_template_parser.add_argument("--name", help="Rule name to write; defaults to the template name")
    apply_template_parser.add_argument("--recipient", required=True, help="Configured notify recipient alias")
    apply_template_parser.add_argument("--via", help="Comma-separated provider order override")
    apply_template_parser.add_argument("--subject", help="Optional subject override")
    apply_template_parser.add_argument("--match", action="append", default=[], help="Additional exact fact match in key=value form; may be repeated")
    apply_template_parser.add_argument("--cooldown", help="Cooldown override like 15m, 1h, or 1d")

    delete_rule_parser = subparsers.add_parser("delete-rule", help="Delete one configured notification rule")
    delete_rule_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    delete_rule_parser.add_argument("name", help="Rule name")

    delete_group_parser = subparsers.add_parser("delete-group", help="Delete one configured recipient group")
    delete_group_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    delete_group_parser.add_argument("alias", help="Group alias")

    emit_parser = subparsers.add_parser("emit", help="Evaluate rules for an event and send matching notifications")
    emit_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    emit_parser.add_argument("event", help="Event name")
    emit_parser.add_argument("--fact", action="append", default=[], help="Fact in key=value form; may be repeated")
    emit_parser.add_argument("--dry-run", action="store_true", help="Show planned notifications without sending")
    emit_parser.add_argument("--all", action="store_true", help="Send through all matching providers for each rule")

    reset_state_parser = subparsers.add_parser("reset-state", help="Reset notify cooldown state for one rule or all rules")
    reset_state_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    reset_state_parser.add_argument("name", nargs="?", help="Optional rule name; omit to reset all notify cooldown state")

    return parser


def main(argv: list[str]) -> int:
    parser = build_parser()
    args = parser.parse_args(preprocess_args(argv))
    config = load_config()
    rules_config = load_rules()

    if args.command in (None, "help"):
        parser.print_help()
        return 0

    if args.command == "providers":
        payload = {"providers": providers_payload()}
        if args.json:
            main_json(payload)
        else:
            for provider in payload["providers"]:
                print(f"{provider['provider']}: {provider['summary']}")
        return 0

    if args.command == "recipients":
        payload = {"recipients": list_recipients(config)}
        if args.json:
            main_json(payload)
        else:
            for recipient in payload["recipients"]:
                providers = ",".join(recipient.get("providers", [])) or "-"
                prefer = ",".join(recipient.get("prefer", [])) or "-"
                print(f"{recipient['alias']}: providers={providers} prefer={prefer}")
        return 0

    if args.command == "groups":
        payload = {"groups": list_groups(config)}
        if args.json:
            main_json(payload)
        else:
            for group in payload["groups"]:
                members = ",".join(group.get("members", [])) or "-"
                print(f"{group['alias']}: members={members}")
        return 0

    if args.command == "show":
        recipient = get_recipient(config, args.alias)
        if recipient is None:
            message = f"Unknown recipient alias: {args.alias}"
            if args.json:
                main_json({"success": False, "error": message})
            else:
                print(message, file=sys.stderr)
            return 1

        payload = {"alias": args.alias, "recipient": recipient}
        if args.json:
            main_json(payload)
        else:
            print(json.dumps(payload, indent=2))
        return 0

    if args.command == "show-group":
        group = get_group(config, args.alias)
        if group is None:
            message = f"Unknown group alias: {args.alias}"
            if args.json:
                main_json({"success": False, "error": message})
            else:
                print(message, file=sys.stderr)
            return 1

        payload = {"alias": args.alias, "group": group}
        if args.json:
            main_json(payload)
        else:
            print(json.dumps(payload, indent=2))
        return 0

    if args.command == "set-recipient":
        recipient = update_recipient(
            config,
            args.alias,
            sms=args.sms,
            email=args.email,
            slack=args.slack,
            messenger=args.messenger,
            pipe=args.pipe,
            prefer=parse_provider_list(args.prefer) if args.prefer is not None else None,
            subject=args.subject,
        )
        save_config(config)
        payload = {"success": True, "alias": args.alias, "recipient": recipient}
        if args.json:
            main_json(payload)
        else:
            print(f"Saved recipient alias: {args.alias}")
        return 0

    if args.command == "set-group":
        group = update_group(config, args.alias, members=args.members)
        save_config(config)
        payload = {"success": True, "alias": args.alias, "group": group}
        if args.json:
            main_json(payload)
        else:
            print(f"Saved group alias: {args.alias}")
        return 0

    if args.command == "rules":
        payload = {"rules": list_rules(rules_config)}
        if args.json:
            main_json(payload)
        else:
            for rule in payload["rules"]:
                via = ",".join(rule.get("via", [])) or "-"
                print(
                    f"{rule['name']}: event={rule.get('event')} recipient={rule.get('recipient')} via={via} cooldown={rule.get('cooldown_seconds', 0)}s"
                )
        return 0

    if args.command == "templates":
        payload = {"templates": list_templates()}
        if args.json:
            main_json(payload)
        else:
            for template in payload["templates"]:
                via = ",".join(template.get("via", [])) or "-"
                print(
                    f"{template['name']}: event={template.get('event')} via={via} cooldown={template.get('cooldown_seconds', 0)}s"
                )
        return 0

    if args.command == "show-template":
        template = get_template(args.name)
        if template is None:
            message = f"Unknown notify template: {args.name}"
            if args.json:
                main_json({"success": False, "error": message})
            else:
                print(message, file=sys.stderr)
            return 1
        payload = {"name": args.name, "template": template}
        if args.json:
            main_json(payload)
        else:
            print(json.dumps(payload, indent=2))
        return 0

    if args.command == "show-rule":
        rule = get_rule(rules_config, args.name)
        if rule is None:
            message = f"Unknown rule: {args.name}"
            if args.json:
                main_json({"success": False, "error": message})
            else:
                print(message, file=sys.stderr)
            return 1
        payload = {"name": args.name, "rule": rule}
        if args.json:
            main_json(payload)
        else:
            print(json.dumps(payload, indent=2))
        return 0

    if args.command == "set-rule":
        try:
            rule = update_rule(
                rules_config,
                args.name,
                recipient=args.recipient,
                event=args.event,
                message=args.message,
                via=parse_provider_list(args.via) if args.via is not None else None,
                subject=args.subject,
                match=parse_key_value_pairs(args.match),
                fingerprint=args.fingerprint,
                cooldown_seconds=parse_duration_seconds(args.cooldown),
            )
        except ValueError as exc:
            payload = {"success": False, "error": str(exc)}
            if args.json:
                main_json(payload)
            else:
                print(str(exc), file=sys.stderr)
            return 1
        save_rules(rules_config)
        payload = {"success": True, "name": args.name, "rule": rule}
        if args.json:
            main_json(payload)
        else:
            print(f"Saved rule: {args.name}")
        return 0

    if args.command == "apply-template":
        try:
            rule = apply_template(
                rules_config,
                args.template,
                rule_name=args.name or args.template,
                recipient=args.recipient,
                via=parse_provider_list(args.via) if args.via is not None else None,
                subject=args.subject,
                match=parse_key_value_pairs(args.match),
                cooldown_seconds=parse_duration_seconds(args.cooldown) if args.cooldown is not None else None,
            )
        except ValueError as exc:
            payload = {"success": False, "error": str(exc)}
            if args.json:
                main_json(payload)
            else:
                print(str(exc), file=sys.stderr)
            return 1
        save_rules(rules_config)
        payload = {"success": True, "template": args.template, "name": args.name or args.template, "rule": rule}
        if args.json:
            main_json(payload)
        else:
            print(f"Applied template: {args.template} -> {args.name or args.template}")
        return 0

    if args.command == "delete-rule":
        removed = delete_rule(rules_config, args.name)
        if removed is None:
            payload = {"success": False, "error": f"Unknown rule: {args.name}"}
            if args.json:
                main_json(payload)
            else:
                print(payload["error"], file=sys.stderr)
            return 1
        save_rules(rules_config)
        payload = {"success": True, "name": args.name, "rule": removed}
        if args.json:
            main_json(payload)
        else:
            print(f"Deleted rule: {args.name}")
        return 0

    if args.command == "delete-group":
        removed = delete_group(config, args.alias)
        if removed is None:
            payload = {"success": False, "error": f"Unknown group alias: {args.alias}"}
            if args.json:
                main_json(payload)
            else:
                print(payload["error"], file=sys.stderr)
            return 1
        save_config(config)
        payload = {"success": True, "alias": args.alias, "group": removed}
        if args.json:
            main_json(payload)
        else:
            print(f"Deleted group alias: {args.alias}")
        return 0

    if args.command == "emit":
        try:
            payload = emit_event(
                config,
                rules_config,
                args.event,
                facts=parse_key_value_pairs(args.fact),
                dry_run=args.dry_run,
                send_all=args.all,
            )
        except LiveApprovalRequiredError as exc:
            payload = exc.payload()
            if args.json:
                main_json(payload)
            else:
                print(json.dumps(payload, indent=2))
            return 1
        except ValueError as exc:
            payload = {"success": False, "error": str(exc)}
            if args.json:
                main_json(payload)
            else:
                print(str(exc), file=sys.stderr)
            return 1
        if args.json:
            main_json(payload)
        else:
            print(json.dumps(payload, indent=2))
        return 0 if payload.get("success") else 1

    if args.command == "reset-state":
        state = load_state()
        payload = {"success": True, **reset_state(state, rule_name=args.name)}
        save_state(state)
        if args.json:
            main_json(payload)
        else:
            if payload["scope"] == "all":
                print(f"Reset notify state for all rules ({payload['cleared_count']} fingerprints)")
            else:
                print(f"Reset notify state for {payload['rule']} ({payload['cleared_count']} fingerprints)")
        return 0

    if args.command == "send":
        try:
            payload = send_notification(
                config,
                args.recipient,
                args.message,
                via=parse_provider_list(args.via),
                subject=args.subject,
                send_all=args.all,
                dry_run=args.dry_run,
            )
        except LiveApprovalRequiredError as exc:
            payload = exc.payload()
            if args.json:
                main_json(payload)
            else:
                print(json.dumps(payload, indent=2))
            return 1
        except ValueError as exc:
            payload = {"success": False, "error": str(exc)}
            if args.json:
                main_json(payload)
            else:
                print(str(exc), file=sys.stderr)
            return 1
        if args.json:
            main_json(payload)
        else:
            print(render_text_result(payload))
        return 0 if payload.get("success") else 1

    parser.print_help()
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
