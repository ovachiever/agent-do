#!/usr/bin/env python3
"""Suggestion and discovery CLI for agent-do."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
import re

sys.path.insert(0, str(Path(__file__).parent.parent / "lib"))

from registry import (  # noqa: E402
    load_registry,
    match_prompt_tools,
    search_tools,
    get_default_command,
    get_recommended_entrypoints,
    get_tool_readiness,
    rank_tools_for_project_signals,
)


PROJECT_MARKERS = (
    ".git",
    "CLAUDE.md",
    "AGENTS.md",
    "package.json",
    "pyproject.toml",
    "Cargo.toml",
    "go.mod",
    "requirements.txt",
    "pnpm-workspace.yaml",
    "turbo.json",
)


def find_project_root(cwd: str) -> Path:
    current = Path(cwd).resolve()
    while current != current.parent:
        for marker in PROJECT_MARKERS:
            if (current / marker).exists():
                return current
        current = current.parent
    return Path(cwd).resolve()


def read_doc_files(project_root: Path) -> list[str]:
    docs = []
    for name in ("CLAUDE.md", "AGENTS.md", "README.md"):
        path = project_root / name
        if path.exists():
            docs.append(path.read_text(encoding="utf-8", errors="ignore"))
    return docs


def infer_project_signals(project_root: Path) -> list[str]:
    signals: set[str] = set()
    docs = "\n".join(read_doc_files(project_root)).lower()

    if (project_root / ".zpc").exists() or ".zpc" in docs or "agent-do zpc" in docs:
        signals.update({"zpc", "memory", "lessons"})
    if (project_root / ".manna").exists() or ".manna" in docs or "agent-do manna" in docs:
        signals.update({"infra"})
    if (project_root / "agent-do-spec").exists() or "agent-do spec" in docs:
        signals.update({"spec", "planning", "docs"})
    if "agent-do context" in docs or "documentation" in docs or "llms.txt" in docs:
        signals.update({"docs", "knowledge"})
    if "agent-do browse" in docs:
        signals.update({"browser", "web"})
    if "agent-do dpt" in docs:
        signals.update({"design", "ui", "frontend"})
    if "agent-do vercel" in docs or (project_root / "vercel.json").exists():
        signals.update({"vercel", "deploy", "frontend"})
    if "agent-do render" in docs or (project_root / "render.yaml").exists():
        signals.update({"render", "deploy", "infra"})
    if "agent-do supabase" in docs or (project_root / "supabase").exists():
        signals.update({"supabase", "backend", "database"})

    if (project_root / "ios").exists() or list(project_root.glob("*.xcodeproj")):
        signals.update({"ios", "mobile", "xcode"})
    if (project_root / "android").exists():
        signals.update({"android", "mobile", "emulator"})
    if (project_root / "Dockerfile").exists() or (project_root / "docker-compose.yml").exists() or (project_root / "docker-compose.yaml").exists():
        signals.update({"docker", "containers", "infra"})
    if (project_root / "k8s").exists() or (project_root / "helm").exists():
        signals.update({"kubernetes", "k8s", "infra"})
    if (project_root / "docs").exists():
        signals.update({"docs", "knowledge"})
    if (project_root / "playwright.config.ts").exists() or (project_root / "playwright.config.js").exists():
        signals.update({"frontend", "e2e", "browser"})

    package_json = project_root / "package.json"
    if package_json.exists():
        text = package_json.read_text(encoding="utf-8", errors="ignore").lower()
        if re.search(r'"(react|next|vue|nuxt|svelte|astro|remix|gatsby|solid-js)"', text):
            signals.update({"frontend", "web"})
        if "playwright" in text:
            signals.update({"frontend", "e2e", "browser"})

    if (project_root / "migrations").exists() or list(project_root.rglob("*.sql")):
        signals.update({"database", "sql"})

    return sorted(signals)


def infer_primary_entrypoint(tool: str, info: dict, query: str) -> str:
    commands = list(info.get("commands", {}).keys())
    query_lower = query.lower()
    entrypoints = get_recommended_entrypoints(info)

    for command in commands:
        if command.lower() in query_lower:
            for entry in entrypoints:
                if entry.startswith(f"agent-do {tool} {command}"):
                    return entry
            return f"agent-do {tool} {command}"

    default_command = get_default_command(info)
    if default_command:
        for entry in entrypoints:
            if entry.startswith(f"agent-do {tool} {default_command}"):
                return entry
        if entrypoints:
            return entrypoints[0]
        return f"agent-do {tool} {default_command}"

    if entrypoints:
        return entrypoints[0]

    return f"agent-do {tool} --help"


def build_item(tool: str, info: dict, query: str, source: str, score: int | float) -> dict:
    entrypoints = get_recommended_entrypoints(info)
    readiness = get_tool_readiness(info)
    primary = infer_primary_entrypoint(tool, info, query)
    extra = [entry for entry in entrypoints if entry != primary][:2]

    return {
        "tool": tool,
        "description": info.get("description", ""),
        "source": source,
        "score": score,
        "primary": primary,
        "entrypoints": [primary] + extra,
        "readiness": readiness,
    }


def suggest(query: str, limit: int) -> list[dict]:
    registry = load_registry()
    shared_matches = match_prompt_tools(registry, query, limit=limit)
    if shared_matches:
        return [
            build_item(match["tool"], match["info"], query, "routing", match["score"])
            for match in shared_matches
        ]

    search_matches = search_tools(registry, query)[:limit]
    return [build_item(tool, info, query, "search", 0) for tool, info in search_matches]


def find(query: str, limit: int) -> list[dict]:
    registry = load_registry()
    matches = search_tools(registry, query)[:limit]
    return [build_item(tool, info, query, "search", 0) for tool, info in matches]


def suggest_for_project(cwd: str, limit: int) -> tuple[Path, list[str], list[dict]]:
    registry = load_registry()
    project_root = find_project_root(cwd)
    signals = infer_project_signals(project_root)
    ranked = rank_tools_for_project_signals(registry, signals, limit=limit)

    items = [
        build_item(item["tool"], item["info"], " ".join(signals), "project", item["score"])
        for item in ranked
    ]
    return project_root, signals, items


def render_text(mode: str, query: str, items: list[dict]) -> None:
    print(f"agent-do {mode}")
    print(f"  Query: {query}")

    if not items:
        print("  No strong matches found.")
        return

    for idx, item in enumerate(items, start=1):
        print(f"  {idx}. {item['tool']}")
        print(f"     Start: {item['primary']}")
        if item["description"]:
            print(f"     What: {item['description']}")
        readiness = item.get("readiness") or {}
        if readiness.get("fix") and readiness.get("note"):
            print(f"     Setup: {readiness['fix']} ({readiness['note']})")


def main() -> int:
    parser = argparse.ArgumentParser(description="Suggest and discover agent-do tools")
    parser.add_argument("mode", choices=["suggest", "find"])
    parser.add_argument("query", nargs="*", help="Task description or keyword")
    parser.add_argument("--json", action="store_true", help="Output JSON")
    parser.add_argument("--limit", type=int, default=5, help="Maximum number of results")
    parser.add_argument("--project", action="store_true", help="Suggest tools for the current project instead of a query")
    parser.add_argument("--cwd", default=".", help="Project path for --project mode")
    args = parser.parse_args()

    if args.project:
        project_root, signals, items = suggest_for_project(args.cwd, args.limit)
        payload = {
            "mode": args.mode,
            "project": str(project_root),
            "signals": signals,
            "results": items,
        }
        if args.json:
            print(json.dumps(payload, indent=2))
        else:
            print(f"agent-do {args.mode} --project")
            print(f"  Project: {project_root}")
            print(f"  Signals: {', '.join(signals) if signals else 'none'}")
            if not items:
                print("  No strong matches found.")
            else:
                for idx, item in enumerate(items, start=1):
                    print(f"  {idx}. {item['tool']}")
                    print(f"     Start: {item['primary']}")
                    readiness = item.get("readiness") or {}
                    if readiness.get("fix") and readiness.get("note"):
                        print(f"     Setup: {readiness['fix']} ({readiness['note']})")
        return 0

    query = " ".join(args.query).strip()
    if not query:
        parser.error("query is required unless --project is used")

    items = suggest(query, args.limit) if args.mode == "suggest" else find(query, args.limit)

    if args.json:
        print(json.dumps({"mode": args.mode, "query": query, "results": items}, indent=2))
    else:
        render_text(args.mode, query, items)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
