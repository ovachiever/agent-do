#!/usr/bin/env python3
"""
Intent router using Claude API.
Maps natural language intents to agent-* tool commands.
"""

import json
import os
import subprocess
import sys
from pathlib import Path

try:
    import anthropic
except ModuleNotFoundError:
    anthropic = None

# Add lib to path
sys.path.insert(0, str(Path(__file__).parent.parent / "lib"))

from cache import check_cache, cache_result, fuzzy_match, note_route_outcome, infer_project_scope
from registry import load_registry, get_tool_info, get_tool_secret_envs, has_tool


def resolve_tool_executable(tool_name: str) -> Path | None:
    """Resolve a tool name to the executable path agent-do would invoke."""
    script_dir = Path(__file__).parent.parent
    tool_root = script_dir / "tools" / f"agent-{tool_name}"
    nested_exec = tool_root / f"agent-{tool_name}"

    if tool_root.is_dir() and nested_exec.exists() and nested_exec.is_file():
        return nested_exec

    if tool_root.exists() and tool_root.is_file():
        return tool_root

    registry = load_registry()
    if not has_tool(registry, tool_name):
        return None

    binary = f"agent-{tool_name}"
    which = subprocess.run(
        ["which", binary],
        check=False,
        capture_output=True,
        text=True,
    )
    if which.returncode == 0:
        return Path(which.stdout.strip())

    return None


def load_tool_credentials_env(tool_name: str) -> dict:
    """Return a process environment with secure-store secrets loaded for a tool."""
    env = dict(os.environ)
    if tool_name == "creds":
        return env

    registry = load_registry()
    info = get_tool_info(registry, tool_name) or {}
    keys = get_tool_secret_envs(info)
    if not keys:
        return env

    creds_tool = Path(__file__).parent.parent / "tools" / "agent-creds"
    if not creds_tool.exists():
        return env

    for key in keys:
        if env.get(key):
            continue
        result = subprocess.run(
            [str(creds_tool), "get", key, "--reveal"],
            check=False,
            capture_output=True,
            text=True,
            env=env,
        )
        if result.returncode == 0:
            env[key] = result.stdout.rstrip("\n")

    return env


def route_is_supported(result: dict | None) -> bool:
    """Return whether a cached/fuzzy route still points at a supported tool."""
    if not result:
        return False

    tool_name = result.get("tool")
    if not tool_name:
        return True

    return resolve_tool_executable(tool_name) is not None


def route_intent(
    intent: str,
    registry_context: str,
    state_context: str,
    project_scope: str = "",
    dry_run: bool = False,
    explain: bool = False,
) -> dict:
    """Route intent to tool command using Claude."""

    # Try cache first
    cached = check_cache(intent, project_scope=project_scope)
    if cached and route_is_supported(cached) and not explain:
        cached['from_cache'] = True
        return cached

    # Try fuzzy match if cache miss
    fuzzy = fuzzy_match(intent, project_scope=project_scope)
    if fuzzy and route_is_supported(fuzzy) and not explain:
        fuzzy['from_fuzzy'] = True
        return fuzzy

    # Fall back to LLM
    if anthropic is None:
        raise RuntimeError(
            "The 'anthropic' package is not installed. Install requirements.txt to use natural language routing."
        )

    client = anthropic.Anthropic()

    mode = "explain what tool to use" if explain else "determine the exact command"

    prompt = f"""You are an intent router for the agent-do CLI. Given a natural language request, {mode}.

Current state:
{state_context}

Available tools (each is invoked as `agent-<tool> <command> [args]`):
{registry_context}

User request: "{intent}"

Respond with JSON only:
{{
  "tool": "tool_name",
  "command": "subcommand",
  "args": ["arg1", "arg2"],
  "flags": {{"--flag": "value"}},
  "confidence": 0.95,
  "explanation": "brief explanation of what this will do",
  "clarification_needed": null
}}

Rules:
- tool should be just the name (e.g., "tui" not "agent-tui")
- If the intent is ambiguous, set clarification_needed to a clarifying question
- If no tool matches, set tool to null
- Reference session IDs from current state when relevant
- Keep args as a flat list of strings
- Use flags dict for named options (--flag value)"""

    response = client.messages.create(
        model="claude-opus-4-5-20251101",
        max_tokens=1024,
        messages=[{"role": "user", "content": prompt}]
    )

    # Extract JSON from response
    text = response.content[0].text
    # Handle potential markdown code blocks
    if "```json" in text:
        text = text.split("```json")[1].split("```")[0]
    elif "```" in text:
        text = text.split("```")[1].split("```")[0]

    result = json.loads(text.strip())

    # Cache successful routing
    if result.get('tool') and not result.get('clarification_needed'):
        cache_result(intent, result, project_scope=project_scope, route_source="llm")

    return result


def build_command(result: dict) -> list[str]:
    """Build command list from routing result."""
    cmd = [f"agent-{result['tool']}", result['command']]
    cmd.extend(result.get('args', []))
    for flag, value in result.get('flags', {}).items():
        if value is True:
            cmd.append(flag)
        elif value is not None:
            cmd.extend([flag, str(value)])
    return cmd


def execute(
    result: dict,
    dry_run: bool = False,
    json_output: bool = False,
    intent: str = "",
    project_scope: str = "",
) -> int:
    """Execute the routed command."""

    if result.get('clarification_needed'):
        if json_output:
            # Structured output for orchestrators
            output = {
                "status": "needs_input",
                "question": result['clarification_needed'],
                "context": result.get('explanation'),
                "partial_routing": {
                    "tool": result.get('tool'),
                    "command": result.get('command'),
                    "confidence": result.get('confidence', 0)
                }
            }
            print(json.dumps(output))
        else:
            print(f"? {result['clarification_needed']}")
            if result.get('explanation'):
                print(f"  (Hint: {result['explanation']})")
            print(f"\nRetry with: agent-do --context \"your answer\" \"original request\"")
        return 2  # Exit 2 = needs clarification (not error) - ALWAYS

    if not result.get('tool'):
        if json_output:
            output = {
                "status": "error",
                "error": "no_matching_tool",
                "message": "Could not determine which tool to use.",
                "explanation": result.get('explanation')
            }
            print(json.dumps(output))
            return 1
        print("Could not determine which tool to use.")
        if result.get('explanation'):
            print(f"  {result['explanation']}")
        return 1

    cmd = build_command(result)
    cmd_str = ' '.join(cmd)

    if dry_run:
        if json_output:
            output = {
                "status": "dry_run",
                "command": cmd_str,
                "tool": result.get('tool'),
                "explanation": result.get('explanation')
            }
            print(json.dumps(output))
        else:
            print(f"Would execute: {cmd_str}")
            if result.get('explanation'):
                print(f"  ({result['explanation']})")
        return 0

    # Show what we're doing
    source = ""
    if result.get('from_cache'):
        source = " [cached]"
    elif result.get('from_fuzzy'):
        source = " [fuzzy match]"

    if not json_output:
        print(f"→ {cmd_str}{source}")
        if result.get('explanation'):
            print(f"  ({result['explanation']})")
        print()

    tool_path = resolve_tool_executable(result["tool"])
    if tool_path is None:
        if intent:
            note_route_outcome(
                intent,
                result,
                success=False,
                project_scope=project_scope,
                route_source=route_source_label(result),
            )
        if json_output:
            output = {
                "status": "error",
                "error": "tool_not_found",
                "message": f"Tool 'agent-{result['tool']}' not found.",
                "tool": result.get('tool')
            }
            print(json.dumps(output))
        else:
            print(f"Error: Tool 'agent-{result['tool']}' not found.")
        return 1

    cmd[0] = str(tool_path)

    try:
        proc = subprocess.run(
            cmd,
            capture_output=json_output,
            text=True,
            env=load_tool_credentials_env(result["tool"]),
        )
        if intent:
            note_route_outcome(
                intent,
                result,
                success=(proc.returncode == 0),
                project_scope=project_scope,
                route_source=route_source_label(result),
            )
        if json_output:
            output = {
                "status": "success" if proc.returncode == 0 else "tool_error",
                "command": cmd_str,
                "tool": result.get('tool'),
                "exit_code": proc.returncode,
                "stdout": proc.stdout,
                "stderr": proc.stderr
            }
            print(json.dumps(output))
        return proc.returncode
    except FileNotFoundError:
        if intent:
            note_route_outcome(
                intent,
                result,
                success=False,
                project_scope=project_scope,
                route_source=route_source_label(result),
            )
        if json_output:
            output = {
                "status": "error",
                "error": "tool_not_found",
                "message": f"Tool 'agent-{result['tool']}' not found.",
                "tool": result.get('tool')
            }
            print(json.dumps(output))
        else:
            print(f"Error: Tool 'agent-{result['tool']}' not found.")
        return 1


def route_source_label(result: dict) -> str:
    """Return a compact source label for routing memory."""
    if result.get("from_cache"):
        return "cache"
    if result.get("from_fuzzy"):
        return "fuzzy"
    if result.get("from_registry_routing"):
        return "registry"
    return "llm"


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Intent router for agent-do")
    parser.add_argument("intent", nargs="*", help="Natural language intent")
    parser.add_argument("--dry-run", action="store_true", help="Show command without executing")
    parser.add_argument("--explain", action="store_true", help="Explain how to do something")
    parser.add_argument("--json", action="store_true", help="Output JSON (for orchestrator integration)")
    parser.add_argument("--context", type=str, help="Additional context/answer to previous question")
    args = parser.parse_args()

    intent = " ".join(args.intent)
    if not intent:
        if args.json:
            print(json.dumps({"status": "error", "error": "no_intent", "message": "No intent provided"}))
        else:
            print("Usage: intent-router \"what you want to do\"")
        return 1

    # If context provided, append to intent
    if args.context:
        intent = f"{intent}. Additional context: {args.context}"

    try:
        project_scope = infer_project_scope()
        try:
            from state import load_state, build_state_context
            state_context = build_state_context(load_state())
        except ModuleNotFoundError as e:
            if e.name != "yaml":
                raise
            state_context = "Session state unavailable (install pyyaml to enable state-aware routing)."

        try:
            from registry import load_registry, build_registry_context
            registry_context = build_registry_context(load_registry())
        except ModuleNotFoundError as e:
            if e.name != "yaml":
                raise
            message = (
                "PyYAML is required for natural language routing. "
                "Install dependencies with 'pip3 install -r requirements.txt' or use 'agent-do --offline' for common intents."
            )
            if args.json:
                print(json.dumps({"status": "error", "error": "missing_dependency", "message": message}))
            else:
                print(message)
            return 1

        result = route_intent(
            intent,
            registry_context,
            state_context,
            project_scope=project_scope,
            dry_run=args.dry_run,
            explain=args.explain,
        )
        return execute(result, args.dry_run, args.json, intent=intent, project_scope=project_scope)
    except json.JSONDecodeError as e:
        if args.json:
            print(json.dumps({"status": "error", "error": "json_parse_error", "message": str(e)}))
        else:
            print(f"Error parsing router response: {e}")
        return 1
    except Exception as e:
        is_api_error = anthropic is not None and isinstance(e, anthropic.APIError)
        if args.json:
            error_type = "api_error" if is_api_error else "error"
            print(json.dumps({"status": "error", "error": error_type, "message": str(e)}))
        else:
            prefix = "API error" if is_api_error else "Error"
            print(f"{prefix}: {e}")

        # Try fuzzy match as fallback
        fuzzy = fuzzy_match(intent, threshold=0.4, project_scope=project_scope)
        if fuzzy and route_is_supported(fuzzy):
            if not args.json:
                print("Falling back to fuzzy match...")
            fuzzy["from_fuzzy"] = True
            return execute(fuzzy, args.dry_run, args.json, intent=intent, project_scope=project_scope)
        return 1


if __name__ == "__main__":
    sys.exit(main())
