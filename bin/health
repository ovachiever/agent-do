#!/usr/bin/env bash
# bin/health — Health check for agent-do tools
# Usage: agent-do --health [tool...]
# Checks if tools have their dependencies installed and are ready to use.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TOOLS_DIR="$ROOT_DIR/tools"
CREDS_TOOL="$TOOLS_DIR/agent-creds"

resolve_tool_path() {
    local name="$1"

    if [[ -d "$TOOLS_DIR/agent-$name" && -x "$TOOLS_DIR/agent-$name/agent-$name" ]]; then
        echo "$TOOLS_DIR/agent-$name/agent-$name"
        return 0
    fi

    if [[ -f "$TOOLS_DIR/agent-$name" && -x "$TOOLS_DIR/agent-$name" ]]; then
        echo "$TOOLS_DIR/agent-$name"
        return 0
    fi

    return 1
}

credential_check() {
    local name="$1"
    [[ -x "$CREDS_TOOL" ]] || return 0

    local payload
    payload=$("$CREDS_TOOL" check --tool "$name" --json 2>/dev/null || true)
    [[ -n "$payload" ]] || return 0

    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1])
items = payload.get("items") or []
if not items:
    print("SKIP|")
    raise SystemExit(0)

if payload.get("ok"):
    sources = sorted({item.get("source") for item in items if item.get("present") and item.get("source")})
    note = "credentials configured"
    if sources:
        note = f"credentials from {', '.join(sources)}"
    print(f"OK|{note}")
    raise SystemExit(0)

parts = []
missing_required = payload.get("missing_required") or []
missing_one_of = payload.get("missing_one_of") or []
if missing_required:
    parts.append("missing " + ", ".join(missing_required))
for group in missing_one_of:
    parts.append("need one of: " + " | ".join(group))

print("CONF|" + "; ".join(parts))
PY
}

merge_credential_status() {
    local current_status="$1"
    local current_note="$2"
    local credential_result="$3"

    [[ -n "$credential_result" ]] || {
        printf '%s|%s\n' "$current_status" "$current_note"
        return 0
    }

    local credential_status="${credential_result%%|*}"
    local credential_note="${credential_result#*|}"

    if [[ "$credential_status" == "SKIP" ]]; then
        printf '%s|%s\n' "$current_status" "$current_note"
        return 0
    fi

    if [[ "$current_status" == "WARN" || "$current_status" == "MISS" ]]; then
        printf '%s|%s\n' "$current_status" "$current_note"
        return 0
    fi

    if [[ "$credential_status" == "CONF" ]]; then
        local merged_note="$credential_note"
        if [[ -n "$current_note" && "$current_note" != "$credential_note" ]]; then
            merged_note="$current_note; $credential_note"
        elif [[ -n "$current_note" ]]; then
            merged_note="$current_note"
        fi
        printf 'CONF|%s\n' "$merged_note"
        return 0
    fi

    if [[ -z "$current_note" && -n "$credential_note" ]]; then
        printf '%s|%s\n' "$current_status" "$credential_note"
    else
        printf '%s|%s\n' "$current_status" "$current_note"
    fi
}

check_tool() {
    local name="$1"
    local tool_path=""

    # Find tool
    if ! tool_path="$(resolve_tool_path "$name")"; then
        echo "  ✗  MISS  $name  (not found)"
        return 1
    fi

    # Check if --help works
    if "$tool_path" --help &>/dev/null; then
        # Tool-specific dependency checks
        local status="OK"
        local note=""

        case "$name" in
            browse|unbrowse)
                if ! command -v node &>/dev/null; then
                    status="WARN"; note="node not found"
                elif [[ -d "$TOOLS_DIR/agent-$name/node_modules" ]]; then
                    status="OK"; note="node_modules present"
                else
                    status="WARN"; note="run: cd tools/agent-$name && npm install"
                fi
                ;;
            manna)
                local manna_bin="$TOOLS_DIR/agent-manna/target/release/manna-core"
                if [[ -x "$manna_bin" ]]; then
                    status="OK"; note="binary built"
                else
                    status="WARN"; note="run: cd tools/agent-manna && cargo build --release"
                fi
                ;;
            ios)
                if command -v xcrun &>/dev/null; then
                    status="OK"
                else
                    status="WARN"; note="Xcode CLI tools not found"
                fi
                ;;
            docker)
                if command -v docker &>/dev/null; then
                    if docker info &>/dev/null; then
                        status="OK"; note="Docker running"
                    else
                        status="WARN"; note="Docker installed but not running"
                    fi
                else
                    status="WARN"; note="docker not found"
                fi
                ;;
            k8s)
                if command -v kubectl &>/dev/null; then
                    if kubectl cluster-info &>/dev/null 2>&1; then
                        status="OK"; note="cluster reachable"
                    else
                        status="WARN"; note="kubectl found but no cluster"
                    fi
                else
                    status="WARN"; note="kubectl not found"
                fi
                ;;
            okta)
                if [[ -z "${OKTA_DOMAIN:-}" ]]; then
                    status="CONF"; note="OKTA_DOMAIN not set"
                fi
                ;;
            tui)
                command -v tmux &>/dev/null && { status="OK"; } || { status="WARN"; note="tmux not found"; }
                ;;
            jupyter)
                command -v jupyter &>/dev/null && { status="OK"; } || { status="WARN"; note="jupyter not found"; }
                ;;
            latex)
                command -v pdflatex &>/dev/null && { status="OK"; } || { status="WARN"; note="pdflatex not found"; }
                ;;
            *)
                status="OK"
                ;;
        esac

        local credential_result merged
        credential_result="$(credential_check "$name" 2>/dev/null || true)"
        merged="$(merge_credential_status "$status" "$note" "$credential_result")"
        status="${merged%%|*}"
        note="${merged#*|}"

        local icon="✓"
        [[ "$status" == "WARN" ]] && icon="⚠"
        [[ "$status" == "CONF" ]] && icon="○"
        [[ "$status" == "MISS" ]] && icon="✗"

        if [[ -n "$note" ]]; then
            echo "  $icon  $status  $name  ($note)"
        else
            echo "  $icon  OK    $name"
        fi
    else
        echo "  ✗  ERR   $name  (--help failed)"
        return 1
    fi
}

main() {
    echo "agent-do health check"
    echo "===================="
    echo ""

    local tools=("$@")

    if [[ ${#tools[@]} -eq 0 ]]; then
        # Check all tools
        for tool_path in "$TOOLS_DIR"/agent-*; do
            local name
            if [[ -d "$tool_path" ]]; then
                name=$(basename "$tool_path" | sed 's/^agent-//')
            else
                name=$(basename "$tool_path" | sed 's/^agent-//')
            fi
            tools+=("$name")
        done
    fi

    local ok=0 warn=0 conf=0 miss=0

    for name in $(echo "${tools[@]}" | tr ' ' '\n' | sort -u); do
        result="$(check_tool "$name" 2>/dev/null || true)"
        [[ -n "$result" ]] || result="  ✗  MISS  $name"
        echo "$result"
        case "$result" in
            *"OK"*) ok=$((ok + 1)) ;;
            *"WARN"*) warn=$((warn + 1)) ;;
            *"CONF"*) conf=$((conf + 1)) ;;
            *) miss=$((miss + 1)) ;;
        esac
    done

    echo ""
    echo "Summary: $ok ready, $warn warnings, $conf need config, $miss missing"
    echo ""
    echo "Legend: ✓ OK = ready  ⚠ WARN = missing dependency  ○ CONF = needs config or credentials"
}

main "$@"
