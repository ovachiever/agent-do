def nudge_events(since: str | None = None) -> list[dict[str, Any]]:
    cutoff = parse_since(since)
    events = read_jsonl(agent_do_home() / "telemetry" / "nudges.jsonl")
    if cutoff is None:
        return events
    filtered = []
    for event in events:
        timestamp = parse_iso(str(event.get("timestamp") or ""))
        if timestamp and timestamp >= cutoff:
            filtered.append(event)
    return filtered


def nudge_effectiveness(since: str | None = None) -> dict[str, Any]:
    events = nudge_events(since)
    by_type = Counter(str(event.get("event_type") or "unknown") for event in events)
    by_source = Counter(str(event.get("source") or "unknown") for event in events)
    by_tool: Counter[str] = Counter()
    emitted = 0
    suppressed = 0

    for event in events:
        event_type = str(event.get("event_type") or "")
        if any(token in event_type for token in ("suppress", "silent", "skip")):
            suppressed += 1
        else:
            emitted += 1
        if event.get("tool"):
            by_tool[str(event["tool"])] += 1
        for tool in event.get("tools", []) or []:
            by_tool[str(tool)] += 1

    return {
        "ok": True,
        "tool": "harness",
        "command": "nudges effectiveness",
        "generated_at": now_iso(),
        "since": since,
        "log": str(agent_do_home() / "telemetry" / "nudges.jsonl"),
        "summary": {
            "events": len(events),
            "emitted": emitted,
            "suppressed": suppressed,
            "by_type": dict(by_type.most_common()),
            "by_source": dict(by_source.most_common()),
            "by_tool": dict(by_tool.most_common()),
        },
        "compliance": {
            "status": "not_yet_available",
            "reason": "Current telemetry records hook emissions but does not yet join next tool calls or outcomes.",
            "next_required_surface": "harness event stream with tool_call/tool_result events",
        },
        "events": events[-25:],
    }


