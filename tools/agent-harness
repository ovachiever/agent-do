def library_components() -> list[dict[str, Any]]:
    libs = [
        ("lib:registry", "registry helpers", ["lib/registry.py"], "Registry loading and routing metadata helpers."),
        ("lib:ai-router", "AI router", ["lib/ai_router.py"], "Shared Sonnet JSON helper for suggest and prompt hooks."),
        ("lib:telemetry", "telemetry", ["lib/telemetry.py", "bin/nudges"], "Local nudge telemetry writer and viewer."),
        ("lib:credentials", "credential preload", ["lib/creds-helper.sh", "tools/agent-creds"], "Secure credential resolution substrate."),
        ("lib:json-output", "JSON output", ["lib/json-output.sh"], "Structured JSON output helpers for shell tools."),
        ("lib:snapshot", "snapshot", ["lib/snapshot.sh"], "Snapshot JSON helpers for shell tools."),
    ]
    components = []
    for component_id, name, files, summary in libs:
        existing_files = [item for item in files if (REPO_ROOT / item).exists()]
        if existing_files:
            components.append(
                {
                    "id": component_id,
                    "type": "library",
                    "name": name,
                    "files": existing_files,
                    "summary": summary,
                }
            )
    return components


def tool_components(registry: dict[str, Any]) -> list[dict[str, Any]]:
    components = []
    sys.path.insert(0, str(REPO_ROOT / "lib"))
    from registry import get_tool_secret_envs  # noqa: WPS433

    for name, info in sorted(registry.items()):
        files = tool_files(name)
        commands = sorted((info.get("commands") or {}).keys())
        credentials = sorted(get_tool_secret_envs(info))
        component = {
            "id": f"tool:{name}",
            "type": "tool",
            "name": name,
            "description": info.get("description", ""),
            "files": files,
            "registry": "registry.yaml",
            "commands": commands,
            "capabilities": info.get("capabilities") or [],
            "concurrency": info.get("concurrency", "mixed"),
            "credentials": credentials,
            "routing": bool(info.get("routing")),
            "tests": test_paths_for_tool(name),
            "state": state_refs_for_tool(name),
        }
        components.append(component)
    return components


def inspect_harness() -> dict[str, Any]:
    registry = load_registry()
    components: list[dict[str, Any]] = []
    components.append(registry_component(registry))
    components.extend(instruction_components())
    components.extend(hook_components())
    components.extend(library_components())
    components.extend(tool_components(registry))

    by_type = Counter(component["type"] for component in components)
    tools_with_tests = sum(1 for component in components if component["type"] == "tool" and component.get("tests"))
    tools_with_routing = sum(1 for component in components if component["type"] == "tool" and component.get("routing"))

    return {
        "ok": True,
        "tool": "harness",
        "command": "inspect",
        "generated_at": now_iso(),
        "repo_root": str(REPO_ROOT),
        "project": current_project(),
        "summary": {
            "components": len(components),
            "by_type": dict(sorted(by_type.items())),
            "tools": len(registry),
            "tools_with_tests": tools_with_tests,
            "tools_with_routing": tools_with_routing,
        },
        "components": components,
    }


