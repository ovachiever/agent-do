def spec_change_dir(change_id: str) -> Path:
    return Path.cwd() / "agent-do-spec" / "changes" / safe_id(change_id)


def manifest_template(change_id: str, args: argparse.Namespace) -> dict[str, Any]:
    return {
        "change_id": safe_id(change_id),
        "status": "draft",
        "created_at": now_iso(),
        "component_type": args.component_type,
        "files": args.file or [],
        "evidence": args.evidence or [],
        "root_cause": args.root_cause or "TBD",
        "targeted_fix": args.targeted_fix or "TBD",
        "predicted_fixes": args.predicted_fix or [],
        "risk_regressions": args.risk_regression or ["unknown: define blast radius and regression checks"],
        "verification_plan": args.verification or [],
        "rollback_plan": args.rollback_plan or "TBD",
        "safety_scope": args.safety_scope or "TBD",
        "verdict": None,
    }


def manifest_new(args: argparse.Namespace) -> dict[str, Any]:
    change_dir = spec_change_dir(args.change_id)
    manifest_path = change_dir / "manifest.json"
    if manifest_path.exists() and not args.force:
        raise RuntimeError(f"Manifest already exists: {manifest_path}. Use --force to overwrite.")
    payload = manifest_template(args.change_id, args)
    write_json(manifest_path, payload)
    return {
        "ok": True,
        "tool": "harness",
        "command": "manifest new",
        "change_id": payload["change_id"],
        "path": str(manifest_path),
        "manifest": payload,
    }


def load_json_file(path: Path) -> Any:
    return json.loads(path.read_text(encoding="utf-8"))


def case_id(case: dict[str, Any], index: int) -> str:
    for key in ("id", "name", "case_id", "task", "input"):
        value = case.get(key)
        if value:
            return str(value)
    return f"case-{index + 1}"


def case_passed(case: dict[str, Any]) -> bool | None:
    if isinstance(case.get("passed"), bool):
        return case["passed"]
    status = str(case.get("status") or case.get("outcome") or case.get("result") or "").lower()
    if status in {"pass", "passed", "success", "ok", "true"}:
        return True
    if status in {"fail", "failed", "failure", "error", "false"}:
        return False
    return None


def extract_cases(payload: Any) -> dict[str, bool]:
    if isinstance(payload, dict):
        raw_cases = payload.get("cases") or payload.get("results") or payload.get("items") or []
    elif isinstance(payload, list):
        raw_cases = payload
    else:
        raw_cases = []
    cases: dict[str, bool] = {}
    for index, raw_case in enumerate(raw_cases):
        if not isinstance(raw_case, dict):
            continue
        passed = case_passed(raw_case)
        if passed is None:
            continue
        cases[case_id(raw_case, index)] = passed
    return cases


def manifest_verify(args: argparse.Namespace) -> dict[str, Any]:
    change_dir = spec_change_dir(args.change_id)
    manifest_path = change_dir / "manifest.json"
    if not manifest_path.exists():
        raise RuntimeError(f"Manifest not found: {manifest_path}")
    manifest = load_json_file(manifest_path)
    before = extract_cases(load_json_file(Path(args.before)))
    after = extract_cases(load_json_file(Path(args.after)))
    shared = sorted(set(before) & set(after))

    fail_to_pass = [case for case in shared if before[case] is False and after[case] is True]
    pass_to_fail = [case for case in shared if before[case] is True and after[case] is False]
    predicted_fixes = set(manifest.get("predicted_fixes") or [])
    risk_regressions = set(manifest.get("risk_regressions") or [])
    landed_fixes = sorted(predicted_fixes & set(fail_to_pass))
    landed_risks = sorted(risk_regressions & set(pass_to_fail))
    unexpected_regressions = sorted(set(pass_to_fail) - risk_regressions)

    if not shared:
        verdict = "manual"
        reason = "No comparable case IDs were found."
    elif unexpected_regressions:
        verdict = "manual"
        reason = "Unexpected regressions landed and need review."
    elif predicted_fixes and not landed_fixes:
        verdict = "rollback"
        reason = "Predicted fixes did not land."
    elif landed_fixes and not pass_to_fail:
        verdict = "keep"
        reason = "Predicted fixes landed with no observed regressions."
    else:
        verdict = "improve"
        reason = "Signal is mixed or partial."

    result = {
        "ok": True,
        "tool": "harness",
        "command": "manifest verify",
        "generated_at": now_iso(),
        "change_id": manifest.get("change_id") or safe_id(args.change_id),
        "verdict": verdict,
        "reason": reason,
        "comparison": {
            "shared_cases": len(shared),
            "fail_to_pass": fail_to_pass,
            "pass_to_fail": pass_to_fail,
            "landed_predicted_fixes": landed_fixes,
            "landed_risk_regressions": landed_risks,
            "unexpected_regressions": unexpected_regressions,
        },
    }
    eval_dir = change_dir / "eval"
    write_json(eval_dir / "verdict.json", result)
    manifest["verdict"] = result
    write_json(manifest_path, manifest)
    return result


def render_manifest_result(payload: dict[str, Any]) -> None:
    if payload["command"] == "manifest new":
        print("agent-do harness manifest new")
        print(f"  Change: {payload['change_id']}")
        print(f"  Path: {payload['path']}")
        return
    print("agent-do harness manifest verify")
    print(f"  Change: {payload['change_id']}")
    print(f"  Verdict: {payload['verdict']}")
    print(f"  Reason: {payload['reason']}")


def show_help() -> None:
    print(
        """agent-harness - Observable agent-do harness operations

Commands:
  inspect [--json]                                  Inventory tools, hooks, docs, libs, state, and tests
  nudges effectiveness [--since 7d] [--json]        Summarize nudge telemetry and current compliance limits
  evidence build <session-or-run> [--out DIR]       Build a local drill-down evidence bundle
  manifest new <change-id> [opts]                   Create a harness change manifest
  manifest verify <change-id> --before A --after B  Compare eval case flips against manifest predictions

Examples:
  agent-do harness inspect
  agent-do harness inspect --json
  agent-do harness nudges effectiveness --since 7d
  agent-do harness evidence build 2017ab8f
  agent-do harness manifest new email-hydration --component-type tool --file tools/agent-email
"""
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--json", dest="global_json", action="store_true")
    sub = parser.add_subparsers(dest="command")

    inspect_parser = sub.add_parser("inspect", add_help=False)
    inspect_parser.add_argument("--json", action="store_true")

    nudges = sub.add_parser("nudges", add_help=False)
    nudges.add_argument("nudge_command", choices=["effectiveness"])
    nudges.add_argument("--since")
    nudges.add_argument("--json", action="store_true")

    evidence = sub.add_parser("evidence", add_help=False)
    evidence_sub = evidence.add_subparsers(dest="evidence_command")
    evidence_build = evidence_sub.add_parser("build", add_help=False)
    evidence_build.add_argument("target")
    evidence_build.add_argument("--out")
    evidence_build.add_argument("--json", action="store_true")

    manifest = sub.add_parser("manifest", add_help=False)
    manifest_sub = manifest.add_subparsers(dest="manifest_command")
    manifest_new_parser = manifest_sub.add_parser("new", add_help=False)
    manifest_new_parser.add_argument("change_id")
    manifest_new_parser.add_argument("--component-type", default="tool")
    manifest_new_parser.add_argument("--file", action="append")
    manifest_new_parser.add_argument("--evidence", action="append")
    manifest_new_parser.add_argument("--root-cause")
    manifest_new_parser.add_argument("--targeted-fix")
    manifest_new_parser.add_argument("--predicted-fix", action="append")
    manifest_new_parser.add_argument("--risk-regression", action="append")
    manifest_new_parser.add_argument("--verification", action="append")
    manifest_new_parser.add_argument("--rollback-plan")
    manifest_new_parser.add_argument("--safety-scope")
    manifest_new_parser.add_argument("--force", action="store_true")
    manifest_new_parser.add_argument("--json", action="store_true")

    manifest_verify_parser = manifest_sub.add_parser("verify", add_help=False)
    manifest_verify_parser.add_argument("change_id")
    manifest_verify_parser.add_argument("--before", required=True)
    manifest_verify_parser.add_argument("--after", required=True)
    manifest_verify_parser.add_argument("--json", action="store_true")
    return parser


def main(argv: list[str]) -> int:
    if not argv or argv[0] in {"--help", "-h", "help"}:
        show_help()
        return 0

    parser = build_parser()
    try:
        args = parser.parse_args(argv)
        json_mode = bool(getattr(args, "global_json", False) or getattr(args, "json", False))
        if args.command == "inspect":
            payload = inspect_harness()
            if json_mode:
                print(json.dumps(payload, indent=2))
            else:
                render_inspect_text(payload)
            return 0
        if args.command == "nudges":
            payload = nudge_effectiveness(args.since)
            if json_mode:
                print(json.dumps(payload, indent=2))
            else:
                render_nudge_effectiveness(payload)
            return 0
        if args.command == "evidence" and args.evidence_command == "build":
            payload = build_evidence(args.target, Path(args.out) if args.out else None)
            if json_mode:
                print(json.dumps(payload, indent=2))
            else:
                render_evidence_build(payload)
            return 0
        if args.command == "manifest" and args.manifest_command == "new":
            payload = manifest_new(args)
            if json_mode:
                print(json.dumps(payload, indent=2))
            else:
                render_manifest_result(payload)
            return 0
        if args.command == "manifest" and args.manifest_command == "verify":
            payload = manifest_verify(args)
            if json_mode:
                print(json.dumps(payload, indent=2))
            else:
                render_manifest_result(payload)
            return 0
    except Exception as exc:
        if "--json" in argv:
            print(json.dumps({"ok": False, "tool": "harness", "error": str(exc)}, indent=2))
        else:
            print(f"Error: {exc}", file=sys.stderr)
        return 1

    show_help()
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
