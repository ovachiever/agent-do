def safe_id(value: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_.-]+", "-", value.strip()).strip("-")
    return cleaned[:120] or "run"


def git_artifacts(project_root: Path) -> dict[str, str]:
    status = run_cmd(["git", "status", "--short", "--branch"], cwd=project_root)
    diff = run_cmd(["git", "diff", "--", "."], cwd=project_root, timeout=30)
    return {
        "status": status.stdout if status.returncode == 0 else status.stderr,
        "diff": diff.stdout if diff.returncode == 0 else diff.stderr,
    }


def build_evidence(target: str, out_dir: Path | None = None) -> dict[str, Any]:
    project = current_project()
    project_root = Path(project["git_root"] or Path.cwd())
    run_id = safe_id(target)
    root = out_dir or (project_root / ".agent-do-harness" / "evidence" / run_id)
    root.mkdir(parents=True, exist_ok=True)

    events: list[dict[str, Any]] = [
        {
            "event_id": "event-0001",
            "event_type": "evidence_build",
            "timestamp": now_iso(),
            "summary": f"Built harness evidence bundle for {target}",
            "outcome": "unknown",
        }
    ]

    session_context = agent_do_cmd("sessions", "context", target, "--json", cwd=project_root)
    session_payload: dict[str, Any] = {
        "available": session_context.returncode == 0,
        "stdout": session_context.stdout.strip(),
        "stderr": session_context.stderr.strip(),
    }
    if session_payload["available"]:
        events.append(
            {
                "event_id": f"event-{len(events) + 1:04d}",
                "event_type": "session_context",
                "timestamp": now_iso(),
                "summary": "Session context was available through agent-do sessions.",
                "artifact_ref": "session_context.json",
                "outcome": "unknown",
            }
        )

    nudges = nudge_events()
    if nudges:
        events.append(
            {
                "event_id": f"event-{len(events) + 1:04d}",
                "event_type": "nudges",
                "timestamp": now_iso(),
                "summary": f"Attached {len(nudges)} local nudge telemetry events.",
                "artifact_ref": "nudges.jsonl",
                "outcome": "unknown",
            }
        )

    coord_status = agent_do_cmd("coord", "status", "--json", cwd=project_root)
    coord_payload = {
        "available": coord_status.returncode == 0,
        "stdout": coord_status.stdout.strip(),
        "stderr": coord_status.stderr.strip(),
    }

    git_data = git_artifacts(project_root)
    (root / "git_status.txt").write_text(git_data["status"], encoding="utf-8")
    (root / "diff.patch").write_text(git_data["diff"], encoding="utf-8")
    write_json(root / "session_context.json", session_payload)
    write_json(root / "coord.json", coord_payload)
    write_jsonl(root / "nudges.jsonl", nudges)
    write_jsonl(root / "timeline.jsonl", events)

    overview = f"""# Harness Evidence: {target}

Generated: {now_iso()}

## Project

- cwd: {project['cwd']}
- git root: {project['git_root']}
- branch: {project['branch']}
- commit: {project['commit']}

## Sources

- session context: {'available' if session_payload['available'] else 'unavailable'}
- nudge events: {len(nudges)}
- coord status: {'available' if coord_payload['available'] else 'unavailable'}
- git status: `git_status.txt`
- git diff: `diff.patch`

## Drill-Down Files

- `timeline.jsonl`
- `session_context.json`
- `nudges.jsonl`
- `coord.json`
- `git_status.txt`
- `diff.patch`
- `root_cause.md`
"""
    (root / "overview.md").write_text(overview, encoding="utf-8")
    (root / "root_cause.md").write_text(
        "# Root Cause\n\nTBD. Summarize the observed failure pattern and cite timeline events.\n",
        encoding="utf-8",
    )

    return {
        "ok": True,
        "tool": "harness",
        "command": "evidence build",
        "generated_at": now_iso(),
        "run_id": run_id,
        "target": target,
        "path": str(root),
        "files": sorted(path.name for path in root.iterdir() if path.is_file()),
        "summary": {
            "events": len(events),
            "nudge_events": len(nudges),
            "session_available": session_payload["available"],
            "coord_available": coord_payload["available"],
        },
    }


