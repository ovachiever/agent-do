REPO_ROOT = Path(__file__).resolve().parents[1]


def rel(path: Path) -> str:
    try:
        return path.relative_to(REPO_ROOT).as_posix()
    except ValueError:
        return str(path)


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_iso(value: str | None) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def parse_since(value: str | None) -> datetime | None:
    if not value:
        return None
    now = datetime.now(timezone.utc)
    match = re.fullmatch(r"(\d+)([dhm])", value.strip())
    if match:
        amount = int(match.group(1))
        unit = match.group(2)
        if unit == "d":
            return now - timedelta(days=amount)
        if unit == "h":
            return now - timedelta(hours=amount)
        return now - timedelta(minutes=amount)
    return parse_iso(value)


def agent_do_home() -> Path:
    return Path(os.environ.get("AGENT_DO_HOME", Path.home() / ".agent-do"))


def read_jsonl(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    events: list[dict[str, Any]] = []
    with path.open(encoding="utf-8") as handle:
        for line in handle:
            line = line.strip()
            if not line:
                continue
            try:
                payload = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(payload, dict):
                events.append(payload)
    return events


def write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def write_jsonl(path: Path, events: list[dict[str, Any]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        for event in events:
            handle.write(json.dumps(event, ensure_ascii=False) + "\n")


def run_cmd(args: list[str], cwd: Path | None = None, timeout: int = 10) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            args,
            cwd=cwd or Path.cwd(),
            text=True,
            capture_output=True,
            check=False,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired as exc:
        return subprocess.CompletedProcess(
            args,
            124,
            stdout=exc.stdout or "",
            stderr=f"Command timed out after {timeout}s",
        )


def agent_do_cmd(*args: str, cwd: Path | None = None, timeout: int = 10) -> subprocess.CompletedProcess[str]:
    return run_cmd([str(REPO_ROOT / "agent-do"), *args], cwd=cwd, timeout=timeout)


def load_registry() -> dict[str, Any]:
    sys.path.insert(0, str(REPO_ROOT / "lib"))
    from registry import load_registry as load_agent_registry  # noqa: WPS433

    return load_agent_registry().get("tools") or {}


def git_value(args: list[str], cwd: Path) -> str | None:
    result = subprocess.run(["git", *args], cwd=cwd, text=True, capture_output=True, check=False)
    if result.returncode != 0:
        return None
    value = result.stdout.strip()
    return value or None


def current_project() -> dict[str, Any]:
    cwd = Path.cwd()
    root = git_value(["rev-parse", "--show-toplevel"], cwd)
    branch = git_value(["rev-parse", "--abbrev-ref", "HEAD"], cwd)
    commit = git_value(["rev-parse", "--short", "HEAD"], cwd)
    return {
        "cwd": str(cwd),
        "git_root": root,
        "branch": branch,
        "commit": commit,
    }


def existing(paths: list[Path]) -> list[str]:
    return [rel(path) for path in paths if path.exists()]


def test_paths_for_tool(name: str) -> list[str]:
    candidates = [
        REPO_ROOT / "tests" / f"test_{name.replace('-', '_')}.py",
        REPO_ROOT / "tests" / f"test_{name}.py",
        REPO_ROOT / "tools" / f"agent-{name}" / "test" / "integration.sh",
        REPO_ROOT / "tools" / f"agent-{name}" / "tests",
    ]
    return existing(candidates)


def tool_files(name: str) -> list[str]:
    tool_path = REPO_ROOT / "tools" / f"agent-{name}"
    nested = tool_path / f"agent-{name}"
    files = []
    if tool_path.exists():
        files.append(rel(tool_path))
    if nested.exists():
        files.append(rel(nested))
    return files


def state_refs_for_tool(name: str) -> list[str]:
    refs = {
        "context": ["~/.agent-do/context/"],
        "zpc": [".zpc/"],
        "spec": ["agent-do-spec/"],
        "coord": [".git/agent-do/coord/", "~/.agent-do/coord/"],
        "nudges": ["~/.agent-do/telemetry/nudges.jsonl"],
        "sessions": ["~/.cache/agent-sessions/sessions.db"],
        "eval": ["~/.agent-do/evals/"],
        "auth": ["~/.agent-do/auth/"],
        "creds": ["OS secure credential store"],
        "browse": ["~/.agent-browse/sessions/", "agent-browser sockets"],
        "tail": ["tmp/logs/"],
    }
    return refs.get(name, [])


def registry_component(registry: dict[str, Any]) -> dict[str, Any]:
    return {
        "id": "registry:agent-do",
        "type": "registry",
        "name": "registry.yaml",
        "files": ["registry.yaml"],
        "tools": sorted(registry.keys()),
        "summary": "Master tool catalog: descriptions, commands, routing, credentials, and concurrency.",
    }


def instruction_components() -> list[dict[str, Any]]:
    candidates = [
        ("instructions:agents", "AGENTS.md", "Repo-scoped agent operating guide."),
        ("instructions:claude", "CLAUDE.md", "Claude-facing repo guidance and tool map."),
        ("docs:integration", "INTEGRATION.md", "Hook integration and host compatibility guidance."),
        ("docs:architecture", "ARCHITECTURE.md", "Harness architecture and routing flow."),
    ]
    components = []
    for component_id, filename, summary in candidates:
        path = REPO_ROOT / filename
        if not path.exists():
            continue
        components.append(
            {
                "id": component_id,
                "type": "instructions",
                "name": filename,
                "files": [filename],
                "summary": summary,
            }
        )
    return components


def hook_components() -> list[dict[str, Any]]:
    hooks = [
        (
            "hook:session-start",
            "SessionStart",
            ["hooks/agent-do-session-start.sh"],
            "Injects project-aware tool guidance and bootstrap context.",
        ),
        (
            "hook:user-prompt-submit",
            "UserPromptSubmit",
            ["hooks/agent-do-prompt-router.py"],
            "Routes prompts to high-confidence tool suggestions and coord focus context.",
        ),
        (
            "hook:pretooluse-claude",
            "PreToolUse Claude",
            ["hooks/agent-do-pretooluse-check.py"],
            "Emits Claude-compatible raw-command nudges.",
        ),
        (
            "hook:pretooluse-codex",
            "PreToolUse Codex",
            ["hooks/agent-do-pretooluse-codex.py"],
            "Runs the shared PreToolUse check while suppressing Codex-unsupported output.",
        ),
    ]
    components = []
    for component_id, name, files, summary in hooks:
        existing_files = [item for item in files if (REPO_ROOT / item).exists()]
        if not existing_files:
            continue
        components.append(
            {
                "id": component_id,
                "type": "hook",
                "name": name,
                "files": existing_files,
                "state": ["~/.agent-do/telemetry/nudges.jsonl"],
                "tests": existing(
                    [
                        REPO_ROOT / "tests" / "test_v11_routing.py",
                        REPO_ROOT / "tests" / "test_prompt_hook_ai.py",
                    ]
                ),
