#!/usr/bin/env bash
# agent-email - Email operations

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

show_help() {
    cat << 'EOF'
agent-email - Email operations

Commands:
  send <to> <subject>        Send email
  read                       Open Mail.app
  search [query]             Search emails with structured filters
  count                      Count scoped messages and unread messages
  snapshot                   Inbox state as JSON (accounts, mailboxes, recent messages)
  latest                     Show latest matching message
  wait                       Wait for a matching message
  code                       Extract verification code from latest/waited message
  link                       Extract magic link from latest/waited message
  get --id <message-id>      Fetch one exact message by id
  export --id <message-id>   Export one message as json, txt, html, eml, or pdf
  mailboxes                  List available mailboxes

Options:
  --body <text>              Email body
  --file <path>              Read body from file
  --attach <path>            Attach file
  --cc <email>               CC recipient
  --bcc <email>              BCC recipient
  --from <email>             From address (if supported)
  --subject <text>           Subject contains filter
  --contains <text>          Body or subject contains filter
  --unread                   Only consider unread messages
  --limit <n>                Maximum messages to inspect
  --account <name>           Limit query to one account
  --mailbox <name>           Limit query to one mailbox
  --all-mailboxes            Search all mailboxes instead of inbox-only defaults
  --timeout <seconds>        Wait timeout for wait/code/link
  --interval <seconds>       Poll interval for wait/code/link
  --length <n>               Preferred verification code length
  --regex <pattern>          Explicit regex for verification code extraction
  --domain <host>            Restrict extracted link to a domain
  --exclude-id <id>          Ignore a previously seen message id
  --format <format>          Export format: json, txt, html, eml, pdf
  --output <path>            Write exported message to a file
  --allow-summary            Allow summary-only exports when full body/source is unavailable
  --json                     Output JSON for query commands

Environment:
  SMTP_HOST                  SMTP server
  SMTP_PORT                  SMTP port (default: 587)
  SMTP_USER                  SMTP username
  SMTP_PASS                  SMTP password
  EMAIL_FROM                 Default from address
  AGENT_EMAIL_FIXTURE        JSON fixture file for tests or offline development
  AGENT_EMAIL_ENVELOPE_INDEX Apple Mail Envelope Index override for tests/debugging

Examples:
  agent-email send user@example.com "Hello" --body "Hi there!"
  agent-email search "invoice" --all-mailboxes --json
  agent-email latest --from WidgetHub --account Primary --json
  agent-email get --id msg-123 --json
  agent-email export --id msg-123 --format html --output receipt.html
  agent-email code --from login@example.com --subject "verification code"
  agent-email link --from auth@example.com --domain app.example.com
EOF
}

query_helper() {
    python3 "$ROOT/lib/email_query.py" "$@"
}

send_helper() {
    python3 "$ROOT/lib/email_send.py" "$@"
}

cmd_read() {
    if [[ "$(uname)" == "Darwin" ]]; then
        osascript -e 'tell application "Mail" to activate'
        echo "Opened Mail.app"
    else
        echo "Email reading requires platform-specific setup"
        echo "For CLI reading, consider: mutt, neomutt, or alpine"
    fi
}

OUTPUT_JSON=0
FILTERED_ARGS=()
for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then
        OUTPUT_JSON=1
    else
        FILTERED_ARGS+=("$arg")
    fi
done
set -- "${FILTERED_ARGS[@]}"
export AGENT_EMAIL_OUTPUT_JSON="$OUTPUT_JSON"

case "${1:-help}" in
    send|compose|write)
        shift
        send_helper "$@"
        ;;
    read|inbox|open)
        shift || true
        cmd_read "$@"
        ;;
    search|find|snapshot|snap|latest|wait|code|link|get|export|count|unread|mailboxes)
        query_helper "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: ${1:-}" >&2
        echo "Try: agent-email help" >&2
        exit 1
        ;;
esac
