# --- Helpers ---

okta_request() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"

    if [[ -z "${OKTA_DOMAIN:-}" ]]; then
        echo '{"error":"OKTA_DOMAIN not set"}' >&2
        return 1
    fi
    if [[ -z "${OKTA_API_TOKEN:-}" ]]; then
        echo '{"error":"OKTA_API_TOKEN not set"}' >&2
        return 1
    fi

    local url
    if [[ "$endpoint" == http* ]]; then
        url="$endpoint"
    else
        url="${OKTA_API}${endpoint}"
    fi

    local args=(-s -X "$method" "$url" \
        -H "Authorization: SSWS $OKTA_API_TOKEN" \
        -H "Accept: application/json" \
        -H "Content-Type: application/json")

    if [[ -n "$data" ]]; then
        args+=(-d "$data")
    fi

    local http_code body
    body=$(curl -w '\n%{http_code}' "${args[@]}")
    http_code=$(echo "$body" | tail -1)
    body=$(echo "$body" | sed '$d')

    # Handle rate limiting (429)
    if [[ "$http_code" == "429" ]]; then
        local reset_epoch
        reset_epoch=$(curl -s -o /dev/null -D- -X "$method" "$url" \
            -H "Authorization: SSWS $OKTA_API_TOKEN" \
            -H "Accept: application/json" 2>/dev/null | grep -i 'x-rate-limit-reset' | tr -d '\r' | awk '{print $2}')
        if [[ -n "$reset_epoch" ]]; then
            local now wait_secs
            now=$(date +%s)
            wait_secs=$((reset_epoch - now + 1))
            [[ $wait_secs -gt 0 && $wait_secs -lt 60 ]] && sleep "$wait_secs"
        else
            sleep 2
        fi
        # Retry once
        body=$(curl -w '\n%{http_code}' "${args[@]}")
        http_code=$(echo "$body" | tail -1)
        body=$(echo "$body" | sed '$d')
    fi

    echo "$body"
}

# Paginated GET — follows Link: <url>; rel="next" headers
okta_list() {
    local endpoint="$1"
    local limit="${2:-200}"

    if [[ -z "${OKTA_DOMAIN:-}" || -z "${OKTA_API_TOKEN:-}" ]]; then
        echo '[]'
        return 1
    fi

    local url="${OKTA_API}${endpoint}"
    [[ "$url" == *"?"* ]] && url="${url}&limit=${limit}" || url="${url}?limit=${limit}"

    python3 -c "
import urllib.request, json, re, os, ssl

domain = os.environ.get('OKTA_DOMAIN', '')
token = os.environ.get('OKTA_API_TOKEN', '')
url = '$url'
all_items = []
ctx = ssl.create_default_context()

while url:
    req = urllib.request.Request(url, headers={
        'Authorization': f'SSWS {token}',
        'Accept': 'application/json',
    })
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        body = resp.read().decode()
        items = json.loads(body)
        if isinstance(items, list):
            all_items.extend(items)
        else:
            all_items.append(items)
        # Parse Link header for next page
        link = resp.getheader('Link', '')
        m = re.search(r'<([^>]+)>;\s*rel=\"next\"', link)
        url = m.group(1) if m else None
    except Exception as e:
        break

print(json.dumps(all_items))
"
}

resolve_app() {
    local name_or_id="$1"

    # Already an ID
    if [[ "$name_or_id" == 0oa* ]]; then
        echo "$name_or_id"
        return 0
    fi

    local result
    result=$(okta_request GET "/apps?q=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name_or_id'))")&limit=1")

    local app_id
    app_id=$(echo "$result" | python3 -c "
import sys, json
items = json.load(sys.stdin)
if isinstance(items, list) and items:
    print(items[0].get('id', ''))
" 2>/dev/null)

    if [[ -z "$app_id" ]]; then
        echo "Error: Application '$name_or_id' not found" >&2
        return 1
    fi

    echo "$app_id"
}

resolve_user() {
    local name_or_id="$1"

    if [[ "$name_or_id" == 00u* ]]; then
        echo "$name_or_id"
        return 0
    fi

    # Okta accepts login (email) directly in the URL path
    local result
    result=$(okta_request GET "/users/$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name_or_id'))")")

    local user_id
    user_id=$(echo "$result" | python3 -c "
import sys, json
data = json.load(sys.stdin)
print(data.get('id', ''))
" 2>/dev/null)

    if [[ -z "$user_id" ]]; then
        echo "Error: User '$name_or_id' not found" >&2
        return 1
    fi

    echo "$user_id"
}

resolve_group() {
    local name_or_id="$1"

    if [[ "$name_or_id" == 00g* ]]; then
        echo "$name_or_id"
        return 0
    fi

    local result
    result=$(okta_request GET "/groups?q=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name_or_id'))")&limit=1")

    local group_id
    group_id=$(echo "$result" | python3 -c "
import sys, json
items = json.load(sys.stdin)
if isinstance(items, list) and items:
    print(items[0].get('id', ''))
" 2>/dev/null)

    if [[ -z "$group_id" ]]; then
        echo "Error: Group '$name_or_id' not found" >&2
        return 1
    fi

    echo "$group_id"
}

resolve_authserver() {
    local name_or_id="$1"

    # Literal "default"
    if [[ "$name_or_id" == "default" ]]; then
        echo "default"
        return 0
    fi

    # Already an ID
    if [[ "$name_or_id" == aus* ]]; then
        echo "$name_or_id"
        return 0
    fi

    # Resolve by name
    local result
    result=$(okta_list "/authorizationServers")

    local server_id
    server_id=$(echo "$result" | python3 -c "
import sys, json
name = '$name_or_id'
items = json.load(sys.stdin)
for s in items:
    if s.get('name', '').lower() == name.lower():
        print(s.get('id', ''))
        break
" 2>/dev/null)

    if [[ -z "$server_id" ]]; then
        echo "Error: Authorization server '$name_or_id' not found" >&2
        return 1
    fi

    echo "$server_id"
}

json_escape() {
    python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$1"
}

parse_since() {
    local since="${1:-24h}"
    python3 -c "
import re
from datetime import datetime, timedelta, timezone
s = '$since'
now = datetime.now(timezone.utc)
m = re.match(r'^(\d+)([hdm])$', s)
if m:
    n, unit = int(m.group(1)), m.group(2)
    if unit == 'h': delta = timedelta(hours=n)
    elif unit == 'd': delta = timedelta(days=n)
    elif unit == 'm': delta = timedelta(minutes=n)
    start = now - delta
elif re.match(r'^\d{4}-\d{2}-\d{2}', s):
    start = datetime.fromisoformat(s.replace('Z', '+00:00'))
    if start.tzinfo is None:
        start = start.replace(tzinfo=timezone.utc)
else:
    start = now - timedelta(hours=24)
print(start.strftime('%Y-%m-%dT%H:%M:%SZ'))
"
}

split_csv() {
    echo "$1" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | python3 -c "
import sys, json
print(json.dumps([line.strip() for line in sys.stdin if line.strip()]))
"
}

# --- Application Commands ---

cmd_apps() {
    local status_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status) status_filter="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local endpoint="/apps"
    [[ -n "$status_filter" ]] && endpoint="/apps?filter=status+eq+%22${status_filter^^}%22"

    local result
    result=$(okta_list "$endpoint")

    echo "$result" | python3 -c "
import sys, json
apps = json.load(sys.stdin)
if not apps:
    print('No applications found')
    sys.exit(0)
for a in apps:
    aid = a.get('id', '')
    label = a.get('label', '')
    mode = a.get('signOnMode', '?')
    status = a.get('status', '?')
    print(f'{aid}  {label}  [{mode}]  {status}')
"
}

cmd_app() {
    local name_or_id="${1:-}"
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-okta app <app>" >&2; return 1; }

    local app_id
    app_id=$(resolve_app "$name_or_id") || return 1

    local result
    result=$(okta_request GET "/apps/$app_id")

    echo "$result" | python3 -c "
import sys, json
a = json.load(sys.stdin)
print(f\"ID:          {a.get('id', '')}\")
print(f\"Label:       {a.get('label', '')}\")
print(f\"SignOnMode:  {a.get('signOnMode', '')}\")
print(f\"Status:      {a.get('status', '')}\")
print(f\"Created:     {a.get('created', '')}\")

creds = a.get('credentials', {}).get('oauthClient', {})
if creds:
    print(f\"Client ID:   {creds.get('client_id', '')}\")
    auth_method = creds.get('token_endpoint_auth_method', '')
    print(f\"Auth Method: {auth_method}\")

settings = a.get('settings', {}).get('oauthClient', {})
if settings:
    uris = settings.get('redirect_uris', [])
    if uris:
        print(f\"Redirects:   {', '.join(uris)}\")
    grants = settings.get('grant_types', [])
    if grants:
        print(f\"Grants:      {', '.join(grants)}\")
    logout = settings.get('post_logout_redirect_uris', [])
    if logout:
        print(f\"Post-logout: {', '.join(logout)}\")
    login = settings.get('initiate_login_uri', '')
    if login:
        print(f\"Login URI:   {login}\")

saml = a.get('settings', {}).get('signOn', {})
if saml and a.get('signOnMode') == 'SAML_2_0':
    print(f\"SSO URL:     {saml.get('ssoAcsUrl', '')}\")
    print(f\"Audience:    {saml.get('audience', '')}\")
"
}

cmd_app_create_oidc() {
    local label="${1:-}"
    [[ -z "$label" ]] && { echo "Usage: agent-okta app-create-oidc <label> --type web|spa|native|service --redirect-uris \"u1,u2\"" >&2; return 1; }
    shift

    local app_type="web" redirect_uris="" login_uri="" post_logout_uris="" grant_types=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) app_type="$2"; shift 2 ;;
            --redirect-uris) redirect_uris="$2"; shift 2 ;;
            --login-uri) login_uri="$2"; shift 2 ;;
            --post-logout-uris) post_logout_uris="$2"; shift 2 ;;
            --grant-types) grant_types="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local body
    body=$(python3 -c "
import json, sys

label = $(json_escape "$label")
app_type = '$app_type'
redirect_uris = [u.strip() for u in '$redirect_uris'.split(',') if u.strip()] if '$redirect_uris' else []
login_uri = '$login_uri'
post_logout = [u.strip() for u in '$post_logout_uris'.split(',') if u.strip()] if '$post_logout_uris' else []
custom_grants = [g.strip() for g in '$grant_types'.split(',') if g.strip()] if '$grant_types' else []

# Map app_type to Okta fields
type_map = {
    'web': {'application_type': 'web', 'grant_types': ['authorization_code', 'client_credentials'], 'response_types': ['code'], 'token_endpoint_auth_method': 'client_secret_basic'},
    'spa': {'application_type': 'browser', 'grant_types': ['authorization_code'], 'response_types': ['code'], 'token_endpoint_auth_method': 'none'},
    'native': {'application_type': 'native', 'grant_types': ['authorization_code'], 'response_types': ['code'], 'token_endpoint_auth_method': 'none'},
    'service': {'application_type': 'service', 'grant_types': ['client_credentials'], 'response_types': ['token'], 'token_endpoint_auth_method': 'client_secret_basic'},
}

config = type_map.get(app_type, type_map['web'])
grants = custom_grants if custom_grants else config['grant_types']

app = {
    'name': 'oidc_client',
    'label': label,
    'signOnMode': 'OPENID_CONNECT',
    'credentials': {
        'oauthClient': {
            'token_endpoint_auth_method': config['token_endpoint_auth_method'],
        }
    },
    'settings': {
        'oauthClient': {
            'client_uri': None,
            'application_type': config['application_type'],
            'grant_types': grants,
            'response_types': config['response_types'],
            'redirect_uris': redirect_uris if redirect_uris else ['http://localhost:8080'],
        }
    }
}

if login_uri:
    app['settings']['oauthClient']['initiate_login_uri'] = login_uri
if post_logout:
    app['settings']['oauthClient']['post_logout_redirect_uris'] = post_logout

print(json.dumps(app))
")

    local result
    result=$(okta_request POST "/apps" "$body")

    echo "$result" | python3 -c "
import sys, json
a = json.load(sys.stdin)
if 'errorCode' in a:
    print(f\"Error: {a.get('errorSummary', a.get('errorCode', 'Unknown'))}\")
    sys.exit(1)
print(f\"Created: {a.get('id', '')}  {a.get('label', '')}  [{a.get('signOnMode', '')}]\")
creds = a.get('credentials', {}).get('oauthClient', {})
if creds:
    print(f\"Client ID:     {creds.get('client_id', '')}\")
    secret = creds.get('client_secret', '')
    if secret:
        print(f\"Client Secret: {secret}\")
    else:
        print(f\"Client Secret: (none — PKCE app)\")
"
}

cmd_app_create_saml() {
    local label="${1:-}"
    [[ -z "$label" ]] && { echo "Usage: agent-okta app-create-saml <label> --sso-url <url> --audience <uri>" >&2; return 1; }
    shift

    local sso_url="" audience=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sso-url) sso_url="$2"; shift 2 ;;
            --audience) audience="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$sso_url" || -z "$audience" ]] && { echo "Error: --sso-url and --audience are required" >&2; return 1; }

    local body
    body=$(python3 -c "
import json
app = {
    'name': 'Custom SAML 2.0',
    'label': $(json_escape "$label"),
    'signOnMode': 'SAML_2_0',
    'settings': {
        'signOn': {
            'ssoAcsUrl': '$sso_url',
            'audience': '$audience',
            'recipient': '$sso_url',
            'destination': '$sso_url',
            'subjectNameIdFormat': 'urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress',
        }
    }
}
print(json.dumps(app))
")

    local result
    result=$(okta_request POST "/apps" "$body")

    echo "$result" | python3 -c "
import sys, json
a = json.load(sys.stdin)
if 'errorCode' in a:
    print(f\"Error: {a.get('errorSummary', a.get('errorCode', 'Unknown'))}\")
    sys.exit(1)
print(f\"Created: {a.get('id', '')}  {a.get('label', '')}  [SAML_2_0]\")
"
}

cmd_app_update() {
    local name_or_id="${1:-}"
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-okta app-update <app> [--redirect-uris ...] [--grant-types ...] [--login-uri ...] [--post-logout-uris ...]" >&2; return 1; }
    shift

    local redirect_uris="" grant_types="" login_uri="" post_logout_uris=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --redirect-uris) redirect_uris="$2"; shift 2 ;;
            --grant-types) grant_types="$2"; shift 2 ;;
            --login-uri) login_uri="$2"; shift 2 ;;
            --post-logout-uris) post_logout_uris="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local app_id
    app_id=$(resolve_app "$name_or_id") || return 1

    # GET current state, merge, PUT back (Okta app update is full replace)
    local current
    current=$(okta_request GET "/apps/$app_id")

    local updated
    updated=$(echo "$current" | python3 -c "
import sys, json

app = json.load(sys.stdin)
oauth = app.get('settings', {}).get('oauthClient', {})

redirect = '$redirect_uris'
grants = '$grant_types'
login = '$login_uri'
post_logout = '$post_logout_uris'

if redirect:
    oauth['redirect_uris'] = [u.strip() for u in redirect.split(',') if u.strip()]
if grants:
    oauth['grant_types'] = [g.strip() for g in grants.split(',') if g.strip()]
if login:
    oauth['initiate_login_uri'] = login
if post_logout:
    oauth['post_logout_redirect_uris'] = [u.strip() for u in post_logout.split(',') if u.strip()]

# Remove read-only fields that Okta rejects on PUT
for key in ['_links', '_embedded', 'created', 'lastUpdated', 'id']:
    app.pop(key, None)

print(json.dumps(app))
")

    local result
    result=$(okta_request PUT "/apps/$app_id" "$updated")

    echo "$result" | python3 -c "
import sys, json
a = json.load(sys.stdin)
if 'errorCode' in a:
    print(f\"Error: {a.get('errorSummary', a.get('errorCode', 'Unknown'))}\")
    sys.exit(1)
print(f\"Updated: {a.get('id', '')}  {a.get('label', '')}\")
oauth = a.get('settings', {}).get('oauthClient', {})
uris = oauth.get('redirect_uris', [])
if uris:
    print(f\"Redirects: {', '.join(uris)}\")
grants = oauth.get('grant_types', [])
if grants:
    print(f\"Grants:    {', '.join(grants)}\")
"
}

cmd_app_creds() {
    local name_or_id="${1:-}"
    local reveal=false
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-okta app-creds <app> [--reveal]" >&2; return 1; }
    shift || true
    [[ "${1:-}" == "--reveal" ]] && reveal=true

    local app_id
    app_id=$(resolve_app "$name_or_id") || return 1

    local result
    result=$(okta_request GET "/apps/$app_id")

    local reveal_flag="$reveal"
    echo "$result" | python3 -c "
import sys, json
a = json.load(sys.stdin)
creds = a.get('credentials', {}).get('oauthClient', {})
reveal = '$reveal_flag' == 'true'
if not creds:
    print('No OAuth credentials (not an OIDC app)')
    sys.exit(0)
client_id = creds.get('client_id', '')
secret = creds.get('client_secret', '')
auth_method = creds.get('token_endpoint_auth_method', '')
print(f'Client ID:     {client_id}')
if secret:
    if reveal:
        print(f'Client Secret: {secret}')
    else:
        print(f'Client Secret: {secret[:8]}****')
elif auth_method == 'none':
    print(f'Client Secret: (none — PKCE app)')
else:
    print(f'Client Secret: (not available)')
print(f'Auth Method:   {auth_method}')
"
}

cmd_app_creds_rotate() {
    local name_or_id="${1:-}"
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-okta app-creds-rotate <app>" >&2; return 1; }

    local app_id
    app_id=$(resolve_app "$name_or_id") || return 1

    local result
    result=$(okta_request POST "/apps/$app_id/credentials/clientSecret/lifecycle/newSecret")

    echo "$result" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if 'errorCode' in data:
    print(f\"Error: {data.get('errorSummary', data.get('errorCode', 'Unknown'))}\")
    sys.exit(1)
secret = data.get('client_secret', '')
print(f'New Client Secret: {secret}')
"
}

cmd_app_activate() {
    local name_or_id="${1:-}"
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-okta app-activate <app>" >&2; return 1; }
    local app_id
    app_id=$(resolve_app "$name_or_id") || return 1
    okta_request POST "/apps/$app_id/lifecycle/activate" > /dev/null
    echo "Activated: $app_id"
}

cmd_app_deactivate() {
    local name_or_id="${1:-}"
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-okta app-deactivate <app>" >&2; return 1; }
    local app_id
    app_id=$(resolve_app "$name_or_id") || return 1
