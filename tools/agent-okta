cmd_users() {
    local search=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --search) search="$2"; shift 2 ;;
            *) search="$1"; shift ;;
        esac
    done

    local endpoint="/users"
    if [[ -n "$search" ]]; then
        local encoded
        encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$search'))")
        # Use q= for simple searches, search= for expressions with operators
        if [[ "$search" == *" eq "* || "$search" == *" sw "* || "$search" == *" co "* ]]; then
            endpoint="/users?search=$encoded"
        else
            endpoint="/users?q=$encoded"
        fi
    fi

    local result
    result=$(okta_list "$endpoint")

    echo "$result" | python3 -c "
import sys, json
users = json.load(sys.stdin)
if not users:
    print('No users found')
    sys.exit(0)
for u in users:
    uid = u.get('id', '')
    p = u.get('profile', {})
    email = p.get('email', p.get('login', ''))
    name = f\"{p.get('firstName', '')} {p.get('lastName', '')}\".strip()
    status = u.get('status', '?')
    print(f'{uid}  {email}  {name}  [{status}]')
"
}

