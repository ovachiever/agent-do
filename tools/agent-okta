for o in origins:
    oid = o.get('id', '')
    name = o.get('name', '')
    origin = o.get('origin', '')
    scopes = ', '.join(s.get('type', '') for s in o.get('scopes', []))
    status = o.get('status', '?')
    print(f'{oid}  {name}  {origin}  [{scopes}]  {status}')
"
}

cmd_trusted_origin_add() {
    local name="${1:-}" origin="${2:-}" scopes="cors,redirect"
    [[ -z "$name" || -z "$origin" ]] && { echo "Usage: agent-okta trusted-origin-add <name> <origin> [--scopes cors,redirect]" >&2; return 1; }
    shift 2
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scopes) scopes="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local scope_array
    scope_array=$(python3 -c "
import json
scopes = '$scopes'.split(',')
print(json.dumps([{'type': s.strip().upper()} for s in scopes if s.strip()]))
")

    local body="{\"name\":$(json_escape "$name"),\"origin\":$(json_escape "$origin"),\"scopes\":$scope_array}"

    local result
    result=$(okta_request POST "/trustedOrigins" "$body")

    echo "$result" | python3 -c "
import sys, json
o = json.load(sys.stdin)
if 'errorCode' in o:
    print(f\"Error: {o.get('errorSummary', o.get('errorCode', 'Unknown'))}\")
    sys.exit(1)
print(f\"Created: {o.get('id', '')}  {o.get('name', '')}  {o.get('origin', '')}\")
"
}

