# --- Dispatch ---

main() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_help
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        apps|ls)               cmd_apps "$@" ;;
        app)                   cmd_app "$@" ;;
        app-create-oidc)       cmd_app_create_oidc "$@" ;;
        app-create-saml)       cmd_app_create_saml "$@" ;;
        app-update)            cmd_app_update "$@" ;;
        app-creds)             cmd_app_creds "$@" ;;
        app-creds-rotate)      cmd_app_creds_rotate "$@" ;;
        app-activate)          cmd_app_activate "$@" ;;
        app-deactivate)        cmd_app_deactivate "$@" ;;
        app-delete)            cmd_app_delete "$@" ;;
        app-users)             cmd_app_users "$@" ;;
        app-assign-user)       cmd_app_assign_user "$@" ;;
        app-unassign-user)     cmd_app_unassign_user "$@" ;;
        app-groups)            cmd_app_groups "$@" ;;
        app-assign-group)      cmd_app_assign_group "$@" ;;
        app-unassign-group)    cmd_app_unassign_group "$@" ;;
        app-metadata)          cmd_app_metadata "$@" ;;
        users)                 cmd_users "$@" ;;
        user)                  cmd_user "$@" ;;
        groups)                cmd_groups "$@" ;;
        group)                 cmd_group "$@" ;;
        group-members)         cmd_group_members "$@" ;;
        group-add-user)        cmd_group_add_user "$@" ;;
        group-remove-user)     cmd_group_remove_user "$@" ;;
        auth-servers)          cmd_auth_servers "$@" ;;
        auth-server)           cmd_auth_server "$@" ;;
        auth-server-scopes)    cmd_auth_server_scopes "$@" ;;
        auth-server-claims)    cmd_auth_server_claims "$@" ;;
        auth-server-policies)  cmd_auth_server_policies "$@" ;;
        logs)                  cmd_logs "$@" ;;
        trusted-origins)       cmd_trusted_origins "$@" ;;
        trusted-origin-add)    cmd_trusted_origin_add "$@" ;;
        trusted-origin-del)    cmd_trusted_origin_del "$@" ;;
        whoami)                cmd_whoami "$@" ;;
        snapshot)              cmd_snapshot "$@" ;;
        *)
            echo "Unknown command: $cmd" >&2
            echo "Run 'agent-okta --help' for usage" >&2
            exit 1
            ;;
    esac
}

main "$@"
