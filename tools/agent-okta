# --- Admin Commands ---

cmd_logs() {
    local since="24h" filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --since) since="$2"; shift 2 ;;
            --filter) filter="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local start_time
    start_time=$(parse_since "$since")

    local endpoint="/logs?since=$start_time&limit=50&sortOrder=DESCENDING"
    if [[ -n "$filter" ]]; then
        local encoded_filter
        encoded_filter=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$filter'))")
        endpoint="${endpoint}&filter=$encoded_filter"
    fi

    local result
    result=$(okta_request GET "$endpoint")

    echo "$result" | python3 -c "
import sys, json
events = json.load(sys.stdin)
if not isinstance(events, list) or not events:
    print('No log events')
    sys.exit(0)
for e in events:
    ts = e.get('published', '')[:19]
    event_type = e.get('eventType', '?')
    severity = e.get('severity', '?')
    display = e.get('displayMessage', '')[:80]
    actor = e.get('actor', {}).get('displayName', e.get('actor', {}).get('alternateId', '?'))
    outcome = e.get('outcome', {}).get('result', '?')
    print(f'{ts}  [{severity}]  {event_type}  {outcome}  actor={actor}')
    if display:
        print(f'             {display}')
"
}

