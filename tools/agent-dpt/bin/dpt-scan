#!/usr/bin/env bash
# dpt-scan — compatibility wrapper for the canonical agent-dpt scan command.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<'EOF'
dpt-scan — Design Perception Tensor

Usage:
  dpt-scan <url>        Open URL and scan
  dpt-scan --current    Scan currently open page
  dpt-scan --json       Output raw JSON
  dpt-scan --help       Show this help

Examples:
  dpt-scan https://example.com
  dpt-scan --current --json > report.json
EOF
    exit 0
fi

exec "$SCRIPT_DIR/agent-dpt" scan "$@"
