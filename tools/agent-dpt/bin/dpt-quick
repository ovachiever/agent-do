#!/usr/bin/env bash
# dpt-quick — Quick DPT scan using agent-do browse eval
# Simpler alternative to dpt-scan: uses the eval CLI command directly.
# Works for engines up to ~100KB. For larger payloads, use dpt-scan (socket-based).
#
# Usage:
#   dpt-quick [url]        Open URL and scan
#   dpt-quick              Scan currently open page

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DPT_DIR="$(dirname "$SCRIPT_DIR")"
DPT_ENGINE="$DPT_DIR/dist/dpt-engine.js"

if [[ ! -f "$DPT_ENGINE" ]]; then
    echo "Error: DPT engine not found. Run: bash $DPT_DIR/bin/build" >&2
    exit 1
fi

# Navigate if URL provided
if [[ "${1:-}" != "" && "${1:-}" != "--"* ]]; then
    agent-do browse open "$1" > /dev/null 2>&1
    agent-do browse wait --stable > /dev/null 2>&1
fi

# Read engine and send via eval
# Note: eval has quoting issues with single quotes, so the engine must avoid them
JS_CONTENT=$(cat "$DPT_ENGINE")

# Use a temp file approach to avoid shell quoting issues with large JS
TMPJS=$(mktemp /tmp/dpt-eval-XXXXX.js)
cat "$DPT_ENGINE" > "$TMPJS"

# Send via Python to handle escaping properly
python3 -c "
import subprocess, json, sys

with open('$TMPJS', 'r') as f:
    js = f.read()

# Use agent-browse eval directly via subprocess
result = subprocess.run(
    ['agent-do', 'browse', 'eval', js],
    capture_output=True, text=True, timeout=60
)

if result.returncode != 0:
    print(f'Error: {result.stderr}', file=sys.stderr)
    sys.exit(1)

# Parse the response
try:
    resp = json.loads(result.stdout)
    if resp.get('success'):
        data = resp.get('data', {}).get('result', {})
        print(json.dumps(data, indent=2))
    else:
        print(f'Error: {resp.get(\"error\", \"unknown\")}', file=sys.stderr)
        sys.exit(1)
except json.JSONDecodeError:
    # Response might contain the result directly
    print(result.stdout)
"

rm -f "$TMPJS"
