THREAD_CANDIDATES: list[tuple[str, str]] = [
    ("codex", "CODEX_THREAD_ID"),
    ("claude", "CLAUDE_THREAD_ID"),
    ("claude", "CLAUDE_SESSION_ID"),
    ("claude", "CLAUDE_AGENT_ID"),
]

ACTIVE_WINDOW_SECONDS = int(os.environ.get("AGENT_DO_COORD_ACTIVE_SECONDS", "900"))
IDLE_WINDOW_SECONDS = int(os.environ.get("AGENT_DO_COORD_IDLE_SECONDS", str(14 * 24 * 60 * 60)))


def now() -> datetime:
    return datetime.now(timezone.utc)


def now_iso() -> str:
    return now().replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_iso(value: str | None) -> datetime | None:
    if not value or not isinstance(value, str):
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def age_seconds(value: str | None) -> int | None:
    parsed = parse_iso(value)
    if parsed is None:
        return None
    return max(0, int((now() - parsed).total_seconds()))


def compact(value: str) -> str:
    return re.sub(r"[^a-zA-Z0-9]+", "", value).lower()[:16]


def sanitize(value: str) -> str:
    value = re.sub(r"[^a-zA-Z0-9._-]+", "-", value).strip("-_.").lower()
    return value[:24]


def print_payload(payload: Any, as_json: bool) -> int:
    if as_json:
        print(json.dumps(payload, indent=2, sort_keys=False))
    else:
        if isinstance(payload, str):
            print(payload)
        else:
            print(json.dumps(payload, indent=2, sort_keys=False))
    return 0


def error(message: str, as_json: bool, code: int = 1, **extra: Any) -> int:
    payload = {"success": False, "error": message, "code": code}
    payload.update(extra)
    if as_json:
        print(json.dumps(payload, indent=2, sort_keys=False))
    else:
        print(f"Error: {message}", file=sys.stderr)
    return code


def git_output(cwd: Path, *args: str) -> str | None:
    completed = subprocess.run(
        ["git", *args],
        cwd=cwd,
        text=True,
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        return None
    return completed.stdout.strip()


def resolve_project_paths(cwd: Path) -> dict[str, str]:
    git_dir_text = git_output(cwd, "rev-parse", "--git-dir")
    if git_dir_text:
        git_dir = Path(git_dir_text)
        if not git_dir.is_absolute():
            git_dir = (cwd / git_dir).resolve()
        project_root_text = git_output(cwd, "rev-parse", "--show-toplevel")
        project_root = Path(project_root_text).resolve() if project_root_text else cwd.resolve()
        coord_root = git_dir / "agent-do" / "coord"
        return {
            "project_root": str(project_root),
            "coord_root": str(coord_root),
            "storage": "git-local",
        }

    project_root = cwd.resolve()
    project_hash = hashlib.sha1(str(project_root).encode("utf-8")).hexdigest()[:16]
    home = Path(os.environ.get("AGENT_DO_HOME", str(Path.home() / ".agent-do")))
    coord_root = home / "projects" / project_hash / "coord"
    return {
        "project_root": str(project_root),
        "coord_root": str(coord_root),
        "storage": "global-fallback",
    }


def derive_identity() -> dict[str, str | None]:
    for prefix, env_key in THREAD_CANDIDATES:
        value = os.environ.get(env_key)
        if not value:
            continue
        short = compact(value)
        if short:
            return {"agent_id": f"{prefix}-{short}", "source": env_key, "raw": value}

    tmux_pane = os.environ.get("TMUX_PANE")
    if tmux_pane:
        short = sanitize(tmux_pane).lstrip("%")
        if short:
            return {"agent_id": f"tmux-{short}", "source": "TMUX_PANE", "raw": tmux_pane}

    fallback = f"{socket.gethostname()}-{os.getpid()}"
    return {"agent_id": f"host-{compact(fallback)}", "source": "hostname+pid", "raw": fallback}


def normalize_path(project_root: Path, cwd: Path, value: str) -> str:
    raw = value.strip()
    if not raw:
        return raw
    candidate = Path(raw)
    if candidate.is_absolute():
        try:
            return candidate.resolve(strict=False).relative_to(project_root).as_posix()
        except ValueError:
            return candidate.as_posix()
    try:
        return (cwd / candidate).resolve(strict=False).relative_to(project_root).as_posix()
    except ValueError:
        return Path(os.path.normpath(raw)).as_posix()


def path_overlaps(a: str, b: str) -> bool:
    if not a or not b:
        return False
    if a == b:
        return True
    if a == "." or b == ".":
        return True
    return a.startswith(f"{b}/") or b.startswith(f"{a}/")


def classify_presence(record: dict[str, Any]) -> str:
    lease_expires_at = parse_iso(record.get("lease_expires_at"))
    if lease_expires_at and now() <= lease_expires_at:
        return "active"
    last_seen = parse_iso(record.get("last_seen"))
    if last_seen is None:
        return "unknown"
    if (now() - last_seen).total_seconds() <= IDLE_WINDOW_SECONDS:
        return "idle"
    return "stale"


class CoordStore:
    def __init__(self, cwd: Path) -> None:
        paths = resolve_project_paths(cwd)
        ident = derive_identity()
        self.cwd = cwd.resolve()
        self.project_root = Path(paths["project_root"])
        self.coord_root = Path(paths["coord_root"])
        self.storage = paths["storage"]
        self.agent_id = str(ident["agent_id"])
        self.identity_source = str(ident["source"])
        self.identity_raw = ident["raw"]

        self.coord_root.mkdir(parents=True, exist_ok=True)

        self.agents_path = self.coord_root / "agents.json"
        self.focus_path = self.coord_root / "focus.json"
        self.claims_path = self.coord_root / "claims.json"
        self.needs_path = self.coord_root / "needs.json"
        self.publishes_path = self.coord_root / "publishes.json"
        self.events_path = self.coord_root / "events.jsonl"
        self.lock_path = self.coord_root / ".lock"

    @contextmanager
    def locked(self):
        self.lock_path.parent.mkdir(parents=True, exist_ok=True)
        with self.lock_path.open("a+") as fh:
            fcntl.flock(fh.fileno(), fcntl.LOCK_EX)
            try:
                yield
            finally:
                fcntl.flock(fh.fileno(), fcntl.LOCK_UN)

    def _read_json(self, path: Path, default: Any) -> Any:
        if not path.exists():
            return default
        try:
            return json.loads(path.read_text())
        except json.JSONDecodeError:
            return default

    def _write_json(self, path: Path, payload: Any) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp = path.with_suffix(path.suffix + ".tmp")
        tmp.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n")
        tmp.replace(path)

    def _load_agents(self) -> dict[str, dict[str, Any]]:
        payload = self._read_json(self.agents_path, {"agents": {}})
        agents = payload.get("agents", {})
        return agents if isinstance(agents, dict) else {}

    def _save_agents(self, agents: dict[str, dict[str, Any]]) -> None:
        self._write_json(self.agents_path, {"agents": agents})

    def _load_focus(self) -> dict[str, dict[str, Any]]:
        payload = self._read_json(self.focus_path, {"focus": {}})
        focus = payload.get("focus", {})
        return focus if isinstance(focus, dict) else {}

    def _save_focus(self, focus: dict[str, dict[str, Any]]) -> None:
        self._write_json(self.focus_path, {"focus": focus})

    def _load_claims(self) -> list[dict[str, Any]]:
        payload = self._read_json(self.claims_path, {"claims": []})
        claims = payload.get("claims", [])
        return claims if isinstance(claims, list) else []

    def _save_claims(self, claims: list[dict[str, Any]]) -> None:
        self._write_json(self.claims_path, {"claims": claims})

    def _load_needs(self) -> list[dict[str, Any]]:
        payload = self._read_json(self.needs_path, {"needs": []})
        needs = payload.get("needs", [])
        return needs if isinstance(needs, list) else []

    def _save_needs(self, needs: list[dict[str, Any]]) -> None:
        self._write_json(self.needs_path, {"needs": needs})

    def _load_publishes(self) -> list[dict[str, Any]]:
        payload = self._read_json(self.publishes_path, {"publishes": []})
        publishes = payload.get("publishes", [])
        return publishes if isinstance(publishes, list) else []

    def _save_publishes(self, publishes: list[dict[str, Any]]) -> None:
        self._write_json(self.publishes_path, {"publishes": publishes})

    def _load_events(self) -> list[dict[str, Any]]:
        if not self.events_path.exists():
            return []
        events: list[dict[str, Any]] = []
        for line in self.events_path.read_text().splitlines():
            if not line.strip():
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(event, dict):
                events.append(event)
        events.sort(key=lambda item: int(item.get("seq", 0)))
        return events

    def _append_event(
        self,
        *,
        kind: str,
        paths: list[str] | None = None,
        keys: list[str] | None = None,
        summary: str,
    ) -> dict[str, Any]:
        events = self._load_events()
        seq = (max((int(item.get("seq", 0)) for item in events), default=0) + 1)
        self_record = self.self_record(refresh=False)
        event = {
            "seq": seq,
            "id": f"evt_{seq:06d}",
            "kind": kind,
            "agent_id": self.agent_id,
            "agent_alias": self_record.get("alias"),
            "paths": paths or [],
            "keys": keys or [],
            "summary": summary,
            "created_at": now_iso(),
        }
        with self.events_path.open("a") as fh:
            fh.write(json.dumps(event, sort_keys=True) + "\n")
        return event

    def _resolve_peer(self, token: str | None) -> tuple[str | None, str | None]:
        if token is None:
            return None, None
        agents = self._load_agents()
        if token in agents:
            return token, agents[token].get("alias")
        for agent_id, record in agents.items():
            alias = record.get("alias")
            if isinstance(alias, str) and alias == token:
                return agent_id, alias
        return token, token

    def register_self(self) -> dict[str, Any]:
        with self.locked():
            agents = self._load_agents()
            current = agents.get(self.agent_id, {})
            current.update(
                {
                    "agent_id": self.agent_id,
                    "last_seen": now_iso(),
                    "lease_expires_at": datetime.fromtimestamp(
                        now().timestamp() + ACTIVE_WINDOW_SECONDS, tz=timezone.utc
                    ).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
                    "project_root": str(self.project_root),
                    "identity_source": self.identity_source,
                }
            )
            if self.identity_raw:
                current["identity_raw"] = self.identity_raw
            agents[self.agent_id] = current
            self._save_agents(agents)
            return current

    def self_record(self, refresh: bool = True) -> dict[str, Any]:
        if refresh:
            self.register_self()
        return self._load_agents().get(self.agent_id, {"agent_id": self.agent_id})

    def alias_self(self, alias: str) -> dict[str, Any]:
        current = self.register_self()
        with self.locked():
            agents = self._load_agents()
            current = agents.get(self.agent_id, current)
            current["alias"] = alias
            agents[self.agent_id] = current
            self._save_agents(agents)
            return current

    def aliases(self) -> list[dict[str, Any]]:
        self.register_self()
        aliases: list[dict[str, Any]] = []
        for agent_id, record in sorted(self._load_agents().items()):
            alias = record.get("alias")
            if not isinstance(alias, str) or not alias:
                continue
            aliases.append(
                {
                    "agent_id": agent_id,
                    "alias": alias,
                    "status": classify_presence(record),
                    "current": agent_id == self.agent_id,
                }
            )
        return aliases

    def focus_map(self) -> dict[str, dict[str, Any]]:
        return self._load_focus()

    def focus_for(self, token: str | None = None) -> dict[str, Any] | None:
        agent_id = self.agent_id if token is None else self._resolve_peer(token)[0]
        if not agent_id:
            return None
        return self.focus_map().get(agent_id)

    def set_focus(self, goal: str, paths: list[str]) -> dict[str, Any]:
        self.register_self()
        normalized = sorted({normalize_path(self.project_root, self.cwd, path) for path in paths if path.strip()})
        payload = {
            "agent_id": self.agent_id,
            "alias": self.self_record(refresh=False).get("alias"),
            "goal": goal,
            "paths": normalized,
            "updated_at": now_iso(),
        }
        with self.locked():
            focus = self._load_focus()
            focus[self.agent_id] = payload
            self._save_focus(focus)
            self._append_event(
                kind="focus_set",
                paths=normalized,
                summary=f"{payload.get('alias') or self.agent_id} set focus: {goal}",
            )
        return payload

    def clear_focus(self) -> dict[str, Any] | None:
        self.register_self()
        with self.locked():
            focus = self._load_focus()
            existing = focus.pop(self.agent_id, None)
            self._save_focus(focus)
            if existing:
                self._append_event(
                    kind="focus_clear",
                    paths=existing.get("paths", []),
                    summary=f"{existing.get('alias') or self.agent_id} cleared focus",
                )
            return existing

    def peers(self, include_stale: bool = False) -> list[dict[str, Any]]:
        self.register_self()
        focus = self.focus_map()
        peers: list[dict[str, Any]] = []
        for agent_id, record in sorted(self._load_agents().items()):
            status = classify_presence(record)
            if status == "stale" and not include_stale:
                continue
            peer_focus = focus.get(agent_id)
            peers.append(
                {
                    "agent_id": agent_id,
                    "alias": record.get("alias"),
                    "status": status,
                    "last_seen": record.get("last_seen"),
                    "lease_expires_at": record.get("lease_expires_at"),
                    "current": agent_id == self.agent_id,
                    "focus": peer_focus,
                }
            )
        return peers

    def claims(self) -> list[dict[str, Any]]:
        self.register_self()
        claims = self._load_claims()
        agents = self._load_agents()
        for claim in claims:
            owner = claim.get("owner")
            owner_record = agents.get(str(owner), {})
            claim["owner_status"] = classify_presence(owner_record) if owner_record else "unknown"
        claims.sort(key=lambda item: item.get("path", ""))
        return claims

    def claim(self, path: str, reason: str | None, strength: str) -> tuple[bool, dict[str, Any] | None, str | None]:
        self.register_self()
        normalized = normalize_path(self.project_root, self.cwd, path)
        alias = self.self_record(refresh=False).get("alias")
        with self.locked():
            claims = self._load_claims()
            for existing in claims:
                if existing.get("path") != normalized:
                    continue
                if existing.get("owner") == self.agent_id:
                    existing["reason"] = reason
                    existing["strength"] = strength
                    existing["updated_at"] = now_iso()
                    self._save_claims(claims)
                    self._append_event(
                        kind="claim",
                        paths=[normalized],
                        summary=f"{alias or self.agent_id} updated claim on {normalized}",
                    )
                    return True, existing, None
                owner = existing.get("owner_alias") or existing.get("owner")
                return False, existing, f"{normalized} is already claimed by {owner}"

            claim = {
                "path": normalized,
                "owner": self.agent_id,
                "owner_alias": alias,
                "reason": reason,
                "strength": strength,
                "created_at": now_iso(),
                "updated_at": now_iso(),
            }
            claims.append(claim)
            self._save_claims(claims)
            self._append_event(
                kind="claim",
                paths=[normalized],
                summary=f"{alias or self.agent_id} claimed {normalized}",
            )
            return True, claim, None

    def release(self, path: str) -> tuple[bool, dict[str, Any] | None, str | None]:
        self.register_self()
        normalized = normalize_path(self.project_root, self.cwd, path)
        with self.locked():
            claims = self._load_claims()
            for existing in list(claims):
                if existing.get("path") != normalized:
                    continue
                if existing.get("owner") != self.agent_id:
                    owner = existing.get("owner_alias") or existing.get("owner")
                    return False, existing, f"{normalized} is owned by {owner}"
                claims.remove(existing)
                self._save_claims(claims)
                self._append_event(
                    kind="release",
                    paths=[normalized],
                    summary=f"{existing.get('owner_alias') or self.agent_id} released {normalized}",
                )
                return True, existing, None
            return False, None, f"No active claim for {normalized}"

    def needs(self, include_all: bool = False) -> list[dict[str, Any]]:
        self.register_self()
        needs = self._load_needs()
        if not include_all:
            needs = [item for item in needs if item.get("owner") == self.agent_id]
        needs.sort(key=lambda item: (item.get("key", ""), item.get("created_at", "")))
        return needs

    def add_need(self, key: str, why: str, from_token: str | None) -> dict[str, Any]:
        self.register_self()
        alias = self.self_record(refresh=False).get("alias")
        from_agent_id, from_alias = self._resolve_peer(from_token)
        with self.locked():
            needs = self._load_needs()
            existing = next(
                (
                    item
                    for item in needs
                    if item.get("owner") == self.agent_id and item.get("key") == key
                ),
                None,
            )
            if existing:
                existing.update(
                    {
                        "why": why,
                        "from": from_agent_id,
                        "from_alias": from_alias,
                        "updated_at": now_iso(),
                    }
                )
                payload = existing
            else:
                payload = {
                    "key": key,
                    "owner": self.agent_id,
                    "owner_alias": alias,
                    "why": why,
                    "from": from_agent_id,
                    "from_alias": from_alias,
                    "created_at": now_iso(),
                    "updated_at": now_iso(),
                }
                needs.append(payload)
            self._save_needs(needs)
            self._append_event(
                kind="need_add",
                keys=[key],
                summary=f"{alias or self.agent_id} needs {key}",
            )
            return payload

    def clear_need(self, key: str) -> tuple[bool, dict[str, Any] | None]:
        self.register_self()
        with self.locked():
            needs = self._load_needs()
            for existing in list(needs):
                if existing.get("owner") == self.agent_id and existing.get("key") == key:
                    needs.remove(existing)
                    self._save_needs(needs)
                    self._append_event(
                        kind="need_clear",
                        keys=[key],
                        summary=f"{existing.get('owner_alias') or self.agent_id} cleared need {key}",
                    )
                    return True, existing
            return False, None

    def publishes(self) -> list[dict[str, Any]]:
        self.register_self()
        publishes = self._load_publishes()
        agents = self._load_agents()
        for publish in publishes:
            owner = str(publish.get("owner"))
            owner_record = agents.get(owner, {})
            publish["owner_status"] = classify_presence(owner_record) if owner_record else "unknown"
        publishes.sort(key=lambda item: (item.get("key", ""), item.get("updated_at", "")), reverse=False)
        return publishes

    def add_publish(self, key: str, status: str, summary: str, refs: list[str]) -> dict[str, Any]:
        self.register_self()
        alias = self.self_record(refresh=False).get("alias")
        with self.locked():
            publishes = self._load_publishes()
            existing = next(
                (
                    item
                    for item in publishes
                    if item.get("owner") == self.agent_id and item.get("key") == key
                ),
                None,
            )
            if existing:
                existing.update(
                    {
                        "status": status,
                        "summary": summary,
                        "refs": refs,
                        "updated_at": now_iso(),
                    }
                )
                payload = existing
            else:
                payload = {
                    "key": key,
                    "owner": self.agent_id,
                    "owner_alias": alias,
                    "status": status,
                    "summary": summary,
                    "refs": refs,
                    "created_at": now_iso(),
                    "updated_at": now_iso(),
                }
                publishes.append(payload)
            self._save_publishes(publishes)
            self._append_event(
                kind="publish_add",
                keys=[key],
                summary=f"{alias or self.agent_id} published {key} ({status})",
            )
            return payload

    def clear_publish(self, key: str) -> tuple[bool, dict[str, Any] | None]:
        self.register_self()
        with self.locked():
            publishes = self._load_publishes()
            for existing in list(publishes):
                if existing.get("owner") == self.agent_id and existing.get("key") == key:
                    publishes.remove(existing)
                    self._save_publishes(publishes)
                    self._append_event(
                        kind="publish_clear",
                        keys=[key],
                        summary=f"{existing.get('owner_alias') or self.agent_id} cleared publish {key}",
                    )
                    return True, existing
            return False, None

    def _current_paths(self) -> list[str]:
        focus = self.focus_for() or {}
        focus_paths = list(focus.get("paths", []))
        claim_paths = [item["path"] for item in self.claims() if item.get("owner") == self.agent_id]
        return sorted({*focus_paths, *claim_paths})

    def _current_need_keys(self) -> set[str]:
        return {str(item.get("key")) for item in self.needs() if item.get("key")}

    def _last_interrupt_seq(self) -> int:
        record = self.self_record(refresh=False)
        value = record.get("last_interrupt_seq", 0)
        try:
            return int(value)
        except (TypeError, ValueError):
            return 0

    def _mark_interrupt_seq(self, seq: int) -> None:
        current = self.register_self()
        with self.locked():
            agents = self._load_agents()
            current = agents.get(self.agent_id, current)
            current["last_interrupt_seq"] = seq
            agents[self.agent_id] = current
            self._save_agents(agents)

    def _matching_publish(self, need: dict[str, Any], publishes: list[dict[str, Any]]) -> dict[str, Any] | None:
        key = need.get("key")
        from_target = need.get("from")
        from_alias = need.get("from_alias")
        candidates = [item for item in publishes if item.get("key") == key]
        if from_target:
            candidates = [
                item
                for item in candidates
                if item.get("owner") == from_target or item.get("owner_alias") == from_alias or item.get("owner_alias") == from_target
            ]
        if not candidates:
            return None
        candidates.sort(key=lambda item: item.get("updated_at", ""), reverse=True)
        return candidates[0]

    def interrupts(self, mark_seen: bool = False, limit: int = 20) -> dict[str, Any]:
        self.register_self()
        last_seen_seq = self._last_interrupt_seq()
        focus = self.focus_for() or {}
        my_paths = self._current_paths()
        my_needs = self.needs()
        my_need_keys = {str(item.get("key")) for item in my_needs if item.get("key")}
        agents = self._load_agents()
        publishes = self.publishes()
        active_peers = [
            peer for peer in self.peers(include_stale=False)
            if not peer["current"] and peer["status"] == "active"
        ]

        interrupts: list[dict[str, Any]] = []

        # Current contentions.
        claims = self.claims()
        my_claim_paths = {item["path"] for item in claims if item.get("owner") == self.agent_id}
        for peer in active_peers:
            peer_focus = peer.get("focus") or {}
            peer_focus_paths = [str(item) for item in peer_focus.get("paths", [])]
            peer_claim_paths = [
                item["path"]
                for item in claims
                if item.get("owner") == peer["agent_id"]
            ]
            overlaps = sorted(
                {
                    mine
                    for mine in [*my_paths, *my_claim_paths]
                    for theirs in [*peer_focus_paths, *peer_claim_paths]
                    if path_overlaps(mine, theirs)
                }
            )
            if not overlaps:
                continue
            peer_label = peer.get("alias") or peer["agent_id"]
            interrupts.append(
                {
                    "kind": "contention",
                    "severity": "warning",
                    "peer": peer["agent_id"],
                    "peer_label": peer_label,
                    "paths": overlaps,
                    "keys": [],
                    "summary": f"{peer_label} is active in overlapping paths: {', '.join(overlaps)}",
                    "new": False,
                    "event_id": None,
                }
            )

        # Current dependencies.
        for need in my_needs:
            match = self._matching_publish(need, publishes)
            if match:
                owner_label = match.get("owner_alias") or match.get("owner")
                seq = 0
                latest_event = next(
                    (
                        event
                        for event in reversed(self._load_events())
                        if event.get("kind") == "publish_add"
                        and need.get("key") in event.get("keys", [])
                        and event.get("agent_id") == match.get("owner")
                    ),
                    None,
                )
                if latest_event:
                    seq = int(latest_event.get("seq", 0))
                interrupts.append(
                    {
                        "kind": "dependency",
                        "severity": "info",
                        "peer": match.get("owner"),
                        "peer_label": owner_label,
                        "paths": [],
                        "keys": [need["key"]],
                        "summary": f"Dependency satisfied: {need['key']} is available from {owner_label}",
                        "new": seq > last_seen_seq,
                        "event_id": latest_event.get("id") if latest_event else None,
                    }
                )
                continue

            from_target = need.get("from")
            if not from_target:
                continue
            owner_record = agents.get(str(from_target), {})
            owner_label = owner_record.get("alias") or need.get("from_alias") or from_target
            owner_status = classify_presence(owner_record) if owner_record else "unknown"
            interrupts.append(
                {
                    "kind": "dependency",
                    "severity": "warning" if owner_status == "active" else "info",
                    "peer": from_target,
                    "peer_label": owner_label,
                    "paths": [],
                    "keys": [need["key"]],
                    "summary": (
                        f"Dependency still blocked on {owner_label}: {need['key']}"
                        if owner_status == "active"
                        else f"Dependency waiting with no active owner: {need['key']}"
                    ),
                    "new": False,
                    "event_id": None,
                }
            )

        # Relevant novelty since last seen.
        seen_by_novelty: set[int] = set()
        for event in self._load_events():
            seq = int(event.get("seq", 0))
            if seq <= last_seen_seq:
                continue
            if event.get("agent_id") == self.agent_id:
                continue
            event_paths = [str(item) for item in event.get("paths", [])]
            event_keys = {str(item) for item in event.get("keys", [])}
            relevant = False
            if event_paths and any(path_overlaps(mine, theirs) for mine in my_paths for theirs in event_paths):
                relevant = True
            if event_keys and event_keys & my_need_keys:
                relevant = True
            if not relevant:
                continue
            if event.get("kind") in {"focus_set", "claim"}:
                continue
            seen_by_novelty.add(seq)
            interrupts.append(
                {
                    "kind": "novelty",
                    "severity": "info",
                    "peer": event.get("agent_id"),
                    "peer_label": event.get("agent_alias") or event.get("agent_id"),
                    "paths": event_paths,
                    "keys": sorted(event_keys),
                    "summary": event.get("summary"),
                    "new": True,
                    "event_id": event.get("id"),
                }
            )

        interrupts.sort(
            key=lambda item: (
                {"contention": 0, "dependency": 1, "novelty": 2}.get(str(item.get("kind")), 9),
                0 if item.get("new") else 1,
                item.get("summary", ""),
            )
        )
        interrupts = interrupts[:limit]

        max_seq = max((int(item.get("seq", 0)) for item in self._load_events()), default=last_seen_seq)
        if mark_seen and max_seq > last_seen_seq:
            self._mark_interrupt_seq(max_seq)

        counts = {"contention": 0, "dependency": 0, "novelty": 0}
        for item in interrupts:
            kind = str(item.get("kind"))
            counts[kind] = counts.get(kind, 0) + 1

        return {
            "interrupts": interrupts,
            "counts": counts,
            "last_interrupt_seq": last_seen_seq,
            "current_event_seq": max_seq,
            "focus": focus or None,
        }

    def touch(self) -> dict[str, Any]:
        agent = self.register_self()
        current_focus = self.focus_for()
        peers = self.peers(include_stale=False)
        active_peers = [peer for peer in peers if not peer["current"] and peer["status"] == "active"]
        return {
            "agent": {
                **agent,
                "status": classify_presence(agent),
            },
            "focus": current_focus,
            "active_peers": active_peers,
            "active_window_seconds": ACTIVE_WINDOW_SECONDS,
            "idle_window_seconds": IDLE_WINDOW_SECONDS,
        }

    def status(self) -> dict[str, Any]:
        record = self.self_record()
        my_claims = [item for item in self.claims() if item.get("owner") == self.agent_id]
        my_needs = self.needs()
        my_publishes = [item for item in self.publishes() if item.get("owner") == self.agent_id]
        interrupt_state = self.interrupts(mark_seen=False, limit=20)
        return {
            "agent": {
                "agent_id": self.agent_id,
                "alias": record.get("alias"),
                "status": classify_presence(record),
                "last_seen": record.get("last_seen"),
                "lease_expires_at": record.get("lease_expires_at"),
            },
            "focus": self.focus_for(),
            "claims": my_claims,
            "needs": my_needs,
            "publishes": my_publishes,
            "interrupts": interrupt_state,
            "active_peers": [peer for peer in self.peers(include_stale=False) if not peer["current"] and peer["status"] == "active"],
        }


def parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(add_help=False)
    p.add_argument("--json", action="store_true")
    sub = p.add_subparsers(dest="command")

    sub.add_parser("touch")
    sub.add_parser("whoami")
    sub.add_parser("status")

    alias_p = sub.add_parser("alias")
    alias_p.add_argument("name")

    sub.add_parser("aliases")

    peers_p = sub.add_parser("peers")
    peers_p.add_argument("--all", action="store_true")

    interrupts_p = sub.add_parser("interrupts")
    interrupts_p.add_argument("--mark-seen", action="store_true")
    interrupts_p.add_argument("--limit", type=int, default=20)

    focus_p = sub.add_parser("focus")
    focus_sub = focus_p.add_subparsers(dest="focus_command")
    focus_set = focus_sub.add_parser("set")
    focus_set.add_argument("goal")
    focus_set.add_argument("--path", action="append", required=True, dest="paths")
    focus_show = focus_sub.add_parser("show")
    focus_show.add_argument("peer", nargs="?")
    focus_sub.add_parser("clear")

    sub.add_parser("claims")
    claim_p = sub.add_parser("claim")
    claim_p.add_argument("path")
    claim_p.add_argument("--reason")
    claim_p.add_argument("--strength", choices=["soft", "strong"], default="soft")

    release_p = sub.add_parser("release")
    release_p.add_argument("path")

    need_p = sub.add_parser("need")
    need_sub = need_p.add_subparsers(dest="need_command")
    need_add = need_sub.add_parser("add")
    need_add.add_argument("key")
    need_add.add_argument("--why", required=True)
    need_add.add_argument("--from", dest="from_target")
    need_list = need_sub.add_parser("list")
    need_list.add_argument("--all", action="store_true")
    need_clear = need_sub.add_parser("clear")
    need_clear.add_argument("key")

    sub.add_parser("publishes")
    publish_p = sub.add_parser("publish")
    publish_sub = publish_p.add_subparsers(dest="publish_command")
    publish_add = publish_sub.add_parser("add")
    publish_add.add_argument("key")
    publish_add.add_argument("--status", required=True)
    publish_add.add_argument("--summary", required=True)
    publish_add.add_argument("--ref", action="append", default=[])
    publish_clear = publish_sub.add_parser("clear")
    publish_clear.add_argument("key")

    sub.add_parser("help")
    return p


def format_peer(peer: dict[str, Any]) -> str:
    label = peer.get("alias") or peer.get("agent_id")
    current = " current" if peer.get("current") else ""
    focus = peer.get("focus") or {}
    goal = f' goal:"{focus.get("goal")}"' if focus.get("goal") else ""
    return f"{label} status:{peer.get('status')}{current}{goal}"


def format_interrupt(item: dict[str, Any]) -> str:
    prefix = "[new] " if item.get("new") else ""
    return f"{prefix}{item.get('kind')}: {item.get('summary')}"


def main(argv: list[str]) -> int:
    if len(argv) == 1 or argv[1] in {"--help", "-h", "help"}:
        print(HELP)
        return 0

    raw_args = argv[1:]
    force_json = False
    if "--json" in raw_args:
        force_json = True
        raw_args = [arg for arg in raw_args if arg != "--json"]

    args = parser().parse_args(raw_args)
    args.json = bool(force_json or getattr(args, "json", False))
    if not args.command:
        print(HELP)
        return 0

    store = CoordStore(Path.cwd())

    if args.command == "touch":
        payload = store.touch()
        payload.update(
            {
                "success": True,
                "tool": "coord",
                "agent_id": store.agent_id,
                "project_root": str(store.project_root),
                "coord_root": str(store.coord_root),
                "storage": store.storage,
            }
        )
        return print_payload(payload, args.json)

    if args.command == "whoami":
        record = store.self_record()
        payload = {
            "success": True,
            "tool": "coord",
            "agent_id": store.agent_id,
            "alias": record.get("alias"),
            "identity_source": store.identity_source,
            "project_root": str(store.project_root),
            "coord_root": str(store.coord_root),
            "storage": store.storage,
            "last_seen": record.get("last_seen"),
            "lease_expires_at": record.get("lease_expires_at"),
            "status": classify_presence(record),
            "active_window_seconds": ACTIVE_WINDOW_SECONDS,
            "idle_window_seconds": IDLE_WINDOW_SECONDS,
        }
        return print_payload(payload, args.json)

    if args.command == "alias":
        record = store.alias_self(args.name)
        return print_payload({"success": True, "tool": "coord", "agent": record}, args.json)

    if args.command == "aliases":
        aliases = store.aliases()
        if args.json:
            return print_payload({"success": True, "tool": "coord", "aliases": aliases}, True)
        if not aliases:
            print("No aliases.")
            return 0
        for item in aliases:
            current = " (current)" if item["current"] else ""
            print(f'{item["alias"]} -> {item["agent_id"]} status:{item["status"]}{current}')
        return 0

    if args.command == "peers":
        peers = store.peers(include_stale=args.all)
        if args.json:
            return print_payload({"success": True, "tool": "coord", "peers": peers}, True)
        if not peers:
            print("No peers.")
            return 0
        for peer in peers:
            print(format_peer(peer))
        return 0

    if args.command == "status":
        payload = store.status()
        if args.json:
            return print_payload({"success": True, "tool": "coord", **payload}, True)
        agent = payload["agent"]
        print(f'Agent: {agent["alias"] or agent["agent_id"]} status:{agent["status"]}')
        if payload["focus"]:
            print(f'Focus: {payload["focus"]["goal"]} [{", ".join(payload["focus"]["paths"])}]')
        print(
            "State:"
            f" claims={len(payload['claims'])}"
            f" needs={len(payload['needs'])}"
            f" publishes={len(payload['publishes'])}"
            f" active_peers={len(payload['active_peers'])}"
        )
        print(
            "Interrupts:"
            f" contention={payload['interrupts']['counts']['contention']}"
            f" dependency={payload['interrupts']['counts']['dependency']}"
            f" novelty={payload['interrupts']['counts']['novelty']}"
        )
        return 0

    if args.command == "interrupts":
        payload = store.interrupts(mark_seen=args.mark_seen, limit=args.limit)
        if args.json:
            return print_payload({"success": True, "tool": "coord", **payload}, True)
        if not payload["interrupts"]:
            print("No interrupts.")
            return 0
        for item in payload["interrupts"]:
            print(format_interrupt(item))
        return 0

    if args.command == "focus":
        if args.focus_command == "set":
            payload = store.set_focus(args.goal, args.paths)
            return print_payload({"success": True, "tool": "coord", "focus": payload}, args.json)
        if args.focus_command == "show":
            payload = store.focus_for(args.peer)
            if payload is None:
                return error("Focus not found", args.json, code=2)
            return print_payload({"success": True, "tool": "coord", "focus": payload}, args.json)
        if args.focus_command == "clear":
            payload = store.clear_focus()
            return print_payload({"success": True, "tool": "coord", "cleared": payload}, args.json)
        return error("focus requires set|show|clear", args.json, code=2)

    if args.command == "claims":
        claims = store.claims()
        return print_payload({"success": True, "tool": "coord", "claims": claims}, args.json)

    if args.command == "claim":
        ok, claim, message = store.claim(args.path, args.reason, args.strength)
        if not ok:
            return error(message or "Unable to claim path", args.json)
        return print_payload({"success": True, "tool": "coord", "claim": claim}, args.json)

    if args.command == "release":
        ok, payload, message = store.release(args.path)
        if not ok:
            return error(message or "Unable to release path", args.json)
        return print_payload({"success": True, "tool": "coord", "released": payload}, args.json)

    if args.command == "need":
        if args.need_command == "add":
            payload = store.add_need(args.key, args.why, args.from_target)
            return print_payload({"success": True, "tool": "coord", "need": payload}, args.json)
        if args.need_command == "list":
            payload = store.needs(include_all=args.all)
            return print_payload({"success": True, "tool": "coord", "needs": payload}, args.json)
        if args.need_command == "clear":
            ok, payload = store.clear_need(args.key)
            if not ok:
                return error(f"No active need for {args.key}", args.json, code=2)
            return print_payload({"success": True, "tool": "coord", "cleared": payload}, args.json)
        return error("need requires add|list|clear", args.json, code=2)

    if args.command == "publishes":
        payload = store.publishes()
        return print_payload({"success": True, "tool": "coord", "publishes": payload}, args.json)

    if args.command == "publish":
        if args.publish_command == "add":
            payload = store.add_publish(args.key, args.status, args.summary, args.ref)
            return print_payload({"success": True, "tool": "coord", "publish": payload}, args.json)
        if args.publish_command == "clear":
            ok, payload = store.clear_publish(args.key)
            if not ok:
                return error(f"No active publish for {args.key}", args.json, code=2)
            return print_payload({"success": True, "tool": "coord", "cleared": payload}, args.json)
        return error("publish requires add|clear", args.json, code=2)

    print(HELP)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
