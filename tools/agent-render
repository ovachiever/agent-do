cmd_logs() {
    if [[ $# -eq 0 ]]; then
        show_logs_help
        return 1
    fi
    if is_help_arg "${1:-}"; then
        show_logs_help
        return 0
    fi

    local name_or_id=""
    local since=""
    local until=""
    local limit="20"
    local direction="backward"
    local json_output=0
    local -a type_filters=()
    local -a level_filters=()
    local -a text_filters=()
    local -a host_filters=()
    local -a method_filters=()
    local -a status_filters=()
    local -a path_filters=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h|help)
                show_logs_help
                return 0
                ;;
            --since)
                since="${2:-}"
                [[ -n "$since" ]] || { echo "Error: --since requires a value" >&2; return 1; }
                shift 2
                ;;
            --until)
                until="${2:-}"
                [[ -n "$until" ]] || { echo "Error: --until requires a value" >&2; return 1; }
                shift 2
                ;;
            --limit)
                limit="${2:-}"
                [[ "$limit" =~ ^[0-9]+$ ]] || { echo "Error: --limit must be an integer" >&2; return 1; }
                shift 2
                ;;
            --type)
                append_multi_values type_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --type requires a value" >&2; return 1; }
                shift 2
                ;;
            --level)
                append_multi_values level_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --level requires a value" >&2; return 1; }
                shift 2
                ;;
            --text)
                append_multi_values text_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --text requires a value" >&2; return 1; }
                shift 2
                ;;
            --host)
                append_multi_values host_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --host requires a value" >&2; return 1; }
                shift 2
                ;;
            --method)
                append_multi_values method_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --method requires a value" >&2; return 1; }
                shift 2
                ;;
            --status)
                append_multi_values status_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --status requires a value" >&2; return 1; }
                shift 2
                ;;
            --path)
                append_multi_values path_filters "${2:-}"
                [[ -n "${2:-}" ]] || { echo "Error: --path requires a value" >&2; return 1; }
                shift 2
                ;;
            --json)
                json_output=1
                shift
                ;;
            --forward)
                direction="forward"
                shift
                ;;
            --backward)
                direction="backward"
                shift
                ;;
            --*)
                echo "Error: Unknown logs option: $1" >&2
                return 1
                ;;
            *)
                if [[ -z "$name_or_id" ]]; then
                    name_or_id="$1"
                else
                    echo "Error: Unexpected argument: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$name_or_id" ]]; then
        echo "Error: Service name or ID is required" >&2
        show_logs_help
        return 1
    fi
    if (( limit < 1 || limit > 100 )); then
        echo "Error: --limit must be between 1 and 100" >&2
        return 1
    fi

    local sid
    sid=$(resolve_service "$name_or_id") || return 1

    local service
    service=$(render_request_checked GET "/services/$sid") || return 1

    local owner_id
    owner_id=$(echo "$service" | python3 -c "
import sys, json
svc = json.load(sys.stdin)
print(svc.get('ownerId', ''))
" 2>/dev/null)
    if [[ -z "$owner_id" ]]; then
        echo "Error: Could not resolve ownerId for service '$name_or_id' ($sid)" >&2
        return 1
    fi

    local -a query_parts=("ownerId=$owner_id" "resource=$sid" "limit=$limit" "direction=$direction")
    if [[ -n "$since" ]]; then
        query_parts+=("startTime=$(normalize_log_time "$since")")
    fi
    if [[ -n "$until" ]]; then
        query_parts+=("endTime=$(normalize_log_time "$until")")
    fi
    local value
    for value in "${type_filters[@]}"; do query_parts+=("type=$value"); done
    for value in "${level_filters[@]}"; do query_parts+=("level=$value"); done
    for value in "${text_filters[@]}"; do query_parts+=("text=$value"); done
    for value in "${host_filters[@]}"; do query_parts+=("host=$value"); done
    for value in "${method_filters[@]}"; do query_parts+=("method=$value"); done
    for value in "${status_filters[@]}"; do query_parts+=("statusCode=$value"); done
    for value in "${path_filters[@]}"; do query_parts+=("path=$value"); done

    local query
    query=$(urlencode_pairs "${query_parts[@]}")

    local result
    result=$(render_request_checked GET "/logs?$query") || return 1

    if [[ "$json_output" == "1" ]]; then
        echo "$result"
        return 0
    fi

    echo "$result" | python3 -c "
import sys, json
try:
    payload = json.load(sys.stdin)
    logs = payload.get('logs', [])
    if not logs:
        print('No logs found')
        sys.exit(0)
    for entry in logs:
        labels = {label.get('name'): label.get('value') for label in entry.get('labels', [])}
        ts = entry.get('timestamp', '')
        log_type = labels.get('type', '')
        level = labels.get('level', '')
        prefix = '/'.join([part for part in [log_type, level] if part])
        msg = entry.get('message', str(entry))
        ansi_stripped = __import__('re').sub(r'\\x1b\\[[0-9;]*m', '', msg)
        if prefix:
            print(f'{ts}  [{prefix}] {ansi_stripped}')
        else:
            print(f'{ts}  {ansi_stripped}')
    if payload.get('hasMore'):
        next_start = payload.get('nextStartTime', '')
        next_end = payload.get('nextEndTime', '')
        print(f'\\nMore logs available. nextStartTime={next_start} nextEndTime={next_end}', file=sys.stderr)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
"
}

cmd_restart() {
    local name_or_id="${1:-}"
    if [[ -z "$name_or_id" ]]; then
        echo "Usage: agent-render restart <service>"
        return 1
    fi

    local sid
    sid=$(resolve_service "$name_or_id") || return 1
    render_request POST "/services/$sid/restart" > /dev/null
    echo "Restarted: $name_or_id ($sid)"
}

