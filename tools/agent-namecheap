  agent-namecheap dns-add recognitionoracle.com TXT @ "v=spf1 include:_spf.google.com ~all"
  agent-namecheap dns-del recognitionoracle.com www A
  agent-namecheap nameservers recognitionoracle.com
  agent-namecheap snapshot
