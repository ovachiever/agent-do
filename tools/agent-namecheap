#!/usr/bin/env bash
# agent-namecheap - Namecheap domain and DNS management
# Part of the agent-do ecosystem

set -euo pipefail

NC_API="${NAMECHEAP_API_URL:-https://api.namecheap.com/xml.response}"

show_help() {
    cat << 'EOF'
agent-namecheap - Namecheap domain and DNS management

DOMAINS:
  domains / ls                   List all domains
  domains --expiring             Domains expiring within 30 days
  domain <name>                  Domain details (whois, expiry, nameservers)
  domain-check <name> [name2...] Check domain availability
  domain-renew <name> [--years N] Renew domain (default: 1 year)

DNS:
  dns <domain>                   List DNS records
  dns-add <domain> <type> <host> <addr> [--ttl N] [--mx-pref N]
                                 Add a DNS record (safe: GET → merge → SET)
  dns-update <domain> <host> <type> <addr> [--ttl N] [--mx-pref N]
                                 Update a DNS record (matches by host+type)
  dns-del <domain> <host> [type] Delete DNS record(s) (matches by host, optionally type)
  dns-set-all <domain> <json>    Replace ALL records from JSON array (dangerous)

NAMESERVERS:
  nameservers <domain>           Show current nameservers
  nameservers-set <domain> <ns1,ns2,...>  Set custom nameservers
  nameservers-reset <domain>     Reset to Namecheap default nameservers

SSL:
  ssl-list                       List SSL certificates
