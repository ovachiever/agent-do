# --- SSL Commands ---

cmd_ssl_list() {
    local result
    result=$(nc_request "namecheap.ssl.getList" "PageSize=100")

    local checked
    checked=$(echo "$result" | nc_check_error) || return 1
    echo "$checked" | python3 -c "
import sys, xml.etree.ElementTree as ET
raw = sys.stdin.read()
root = ET.fromstring(raw)
ns = {'nc': 'http://api.namecheap.com/xml.response'}
certs = root.findall('.//nc:SSLListResult/nc:SSL', ns)
if not certs:
    certs = root.findall('.//SSL')
if not certs:
    print('No SSL certificates')
    sys.exit(0)
for c in certs:
    cid = c.get('CertificateID', '')
    host = c.get('HostName', '')
    status = c.get('Status', '')
    ctype = c.get('SSLType', '')
    expires = c.get('ExpireDate', '')
    print(f'{cid}  {host:<40}  [{ctype}]  {status}  {expires}')
"
}

cmd_ssl_info() {
    local cert_id="${1:-}"
    [[ -z "$cert_id" ]] && { echo "Usage: agent-namecheap ssl-info <certificate-id>" >&2; return 1; }

    local result
    result=$(nc_request "namecheap.ssl.getInfo" "CertificateID=$cert_id")

    local checked
    checked=$(echo "$result" | nc_check_error) || return 1
    echo "$checked" | python3 -c "
import sys, xml.etree.ElementTree as ET
raw = sys.stdin.read()
root = ET.fromstring(raw)
ns = {'nc': 'http://api.namecheap.com/xml.response'}
info = root.find('.//nc:SSLGetInfoResult', ns) or root.find('.//SSLGetInfoResult')
if info is None:
    print('Certificate not found')
    sys.exit(1)
print(f\"ID:       {info.get('CertificateID', '')}\")
print(f\"Status:   {info.get('Status', '')}\")
print(f\"Type:     {info.get('SSLType', '')}\")
print(f\"Domain:   {info.get('HostName', '')}\")
print(f\"Expires:  {info.get('ExpireDate', '')}\")
print(f\"Provider: {info.get('Provider', '')}\")
"
}

# --- Account Commands ---

cmd_whoami() {
    # Use domains.getList with PageSize=1 to check auth and see account info
    local result
    result=$(nc_request "namecheap.users.getBalances")

    local checked
    checked=$(echo "$result" | nc_check_error) || return 1
    echo "$checked" | python3 -c "
import sys, xml.etree.ElementTree as ET
raw = sys.stdin.read()
root = ET.fromstring(raw)
ns = {'nc': 'http://api.namecheap.com/xml.response'}
bal = root.find('.//nc:UserGetBalancesResult', ns) or root.find('.//UserGetBalancesResult')
if bal is not None:
    print(f\"Account:         ${NAMECHEAP_API_USER:-}\")
    print(f\"Balance:         \${bal.get('AvailableBalance', '?')}\")
    print(f\"Account Balance: \${bal.get('AccountBalance', '?')}\")
    print(f\"Earned:          \${bal.get('EarnedAmount', '?')}\")
    print(f\"Funds Required:  \${bal.get('FundsRequiredForAutoRenew', '?')}\")
else:
    print('Could not retrieve account info')
"
}

cmd_snapshot() {
    echo "{"
    echo "  \"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\","
    echo "  \"account\": \"${NAMECHEAP_API_USER:-}\","

    # Domains
    local domains
    domains=$(nc_request "namecheap.domains.getList" "ListType=ALL&PageSize=100&SortBy=NAME")
    echo '  "domains": '
    echo "$domains" | python3 -c "
import sys, json, xml.etree.ElementTree as ET
raw = sys.stdin.read()
root = ET.fromstring(raw)
ns = {'nc': 'http://api.namecheap.com/xml.response'}
domains = root.findall('.//nc:DomainGetListResult/nc:Domain', ns) or root.findall('.//Domain')
out = []
for d in domains:
    out.append({
        'name': d.get('Name', ''),
        'expires': d.get('Expires', ''),
        'autoRenew': d.get('AutoRenew', ''),
        'isOurDNS': d.get('IsOurDNS', ''),
        'isExpired': d.get('IsExpired', ''),
    })
print(json.dumps(out, indent=4))
"
    echo ","

    # SSL
    local ssl
    ssl=$(nc_request "namecheap.ssl.getList" "PageSize=100")
    echo '  "ssl": '
    echo "$ssl" | python3 -c "
import sys, json, xml.etree.ElementTree as ET
raw = sys.stdin.read()
root = ET.fromstring(raw)
ns = {'nc': 'http://api.namecheap.com/xml.response'}
certs = root.findall('.//nc:SSLListResult/nc:SSL', ns) or root.findall('.//SSL')
out = []
for c in certs:
    out.append({
        'id': c.get('CertificateID', ''),
        'host': c.get('HostName', ''),
        'type': c.get('SSLType', ''),
        'status': c.get('Status', ''),
        'expires': c.get('ExpireDate', ''),
    })
print(json.dumps(out, indent=4))
"

    echo "}"
}

# --- Dispatch ---

main() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_help
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        domains|ls)           cmd_domains "$@" ;;
        domain)               cmd_domain "$@" ;;
        domain-check)         cmd_domain_check "$@" ;;
        domain-renew)         cmd_domain_renew "$@" ;;
        dns)                  cmd_dns "$@" ;;
        dns-add)              cmd_dns_add "$@" ;;
        dns-update)           cmd_dns_update "$@" ;;
        dns-del)              cmd_dns_del "$@" ;;
        dns-set-all)          cmd_dns_set_all "$@" ;;
        nameservers)          cmd_nameservers "$@" ;;
        nameservers-set)      cmd_nameservers_set "$@" ;;
        nameservers-reset)    cmd_nameservers_reset "$@" ;;
        ssl-list)             cmd_ssl_list "$@" ;;
        ssl-info)             cmd_ssl_info "$@" ;;
        whoami)               cmd_whoami "$@" ;;
        snapshot)             cmd_snapshot "$@" ;;
        *)
            echo "Unknown command: $cmd" >&2
            echo "Run 'agent-namecheap --help' for usage" >&2
            exit 1
            ;;
    esac
}

main "$@"
