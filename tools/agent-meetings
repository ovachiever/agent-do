#!/usr/bin/env bash
# agent-meetings - Unified meeting provider orchestration

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$REPO_ROOT/lib/json-output.sh" ]]; then
    # shellcheck source=lib/json-output.sh
    source "$REPO_ROOT/lib/json-output.sh"
fi

show_help() {
    cat << 'EOF'
agent-meetings - Unified enterprise meeting orchestration

Commands:
  snapshot                              Snapshot provider readiness and active meeting state
  providers                             List supported providers
  active                                Show the detected active meeting provider
  join <target> [--provider <name>]     Join meeting URL/code/ID with provider auto-detection
  new [provider]                        Start a new meeting on the selected provider
  schedule <provider> <topic> [...]     Schedule a meeting via a provider-specific flow
  mute [--provider <name>]              Toggle microphone on the active provider
  video [--provider <name>]             Toggle camera on the active provider
  share [--provider <name>]             Start screen share on the active provider
  chat [message] [--provider <name>]    Open or send meeting chat on the active provider
  end [--provider <name>]               End or leave the active meeting
  zoom <command> [args...]              Provider passthrough to agent-zoom
  meet <command> [args...]              Provider passthrough to agent-meet
  teams <command> [args...]             Provider passthrough to agent-teams

Options:
  --provider <zoom|meet|teams>          Select a provider explicitly
  --json                                Wrap delegated command output in structured JSON

Examples:
  agent-meetings snapshot
  agent-meetings join https://meet.google.com/abc-defg-hij
  agent-meetings join 123-456-789 --provider zoom
  agent-meetings mute
  agent-meetings schedule zoom "Quarterly Review" --time "2026-05-01 09:00"
  agent-meetings teams join "https://teams.microsoft.com/l/meetup-join/..."
EOF
}

normalize_provider() {
    local provider="${1:-}"
    case "$provider" in
        zoom|zoom-us) echo "zoom" ;;
        meet|google|google-meet|google_meet) echo "meet" ;;
        teams|msteams|microsoft|microsoft-teams|microsoft_teams) echo "teams" ;;
        *) echo "$provider" ;;
    esac
}

resolve_provider_exec() {
    local provider
    provider="$(normalize_provider "$1")"
    local leaf_dir="${AGENT_DO_MEETINGS_TOOL_DIR:-$SCRIPT_DIR}"
    local local_exec="$leaf_dir/agent-$provider"

    if [[ -x "$local_exec" ]]; then
        echo "$local_exec"
        return 0
    fi

    if command -v "agent-$provider" >/dev/null 2>&1; then
        command -v "agent-$provider"
        return 0
    fi

    return 1
}

provider_running() {
    local provider
    provider="$(normalize_provider "$1")"
    local forced_active="${AGENT_DO_MEETINGS_ACTIVE_PROVIDER:-}"
    if [[ -n "$forced_active" ]] && [[ "$(normalize_provider "$forced_active")" == "$provider" ]]; then
        return 0
    fi

    case "$provider" in
        zoom)
            if [[ "$(uname)" == "Darwin" ]]; then
                pgrep -x "zoom.us" >/dev/null 2>&1
            else
                pgrep -x "zoom" >/dev/null 2>&1
            fi
            ;;
        teams)
            if [[ "$(uname)" == "Darwin" ]]; then
                pgrep -x "Microsoft Teams" >/dev/null 2>&1 || pgrep -x "Teams" >/dev/null 2>&1
            else
                pgrep -x "teams" >/dev/null 2>&1
            fi
            ;;
        meet)
            if [[ -n "${AGENT_DO_MEETINGS_FRONTMOST_URL:-}" ]] && [[ "${AGENT_DO_MEETINGS_FRONTMOST_URL}" == *"meet.google.com"* ]]; then
                return 0
            fi
            return 1
            ;;
        *)
            return 1
            ;;
    esac
}

frontmost_browser_url() {
    if [[ -n "${AGENT_DO_MEETINGS_FRONTMOST_URL:-}" ]]; then
        printf '%s\n' "$AGENT_DO_MEETINGS_FRONTMOST_URL"
        return 0
    fi

    if [[ "$(uname)" != "Darwin" ]]; then
        return 1
    fi

    osascript <<'EOF' 2>/dev/null
tell application "System Events"
    set frontApp to name of first application process whose frontmost is true
end tell

if frontApp is "Google Chrome" then
    tell application "Google Chrome"
        if (count of windows) > 0 then
            return URL of active tab of front window
        end if
    end tell
else if frontApp is "Safari" then
    tell application "Safari"
        if (count of windows) > 0 then
            return URL of current tab of front window
        end if
    end tell
end if
EOF
}

detect_active_provider() {
    local forced_active="${AGENT_DO_MEETINGS_ACTIVE_PROVIDER:-}"
    if [[ -n "$forced_active" ]]; then
        normalize_provider "$forced_active"
        return 0
    fi

    local url
    url="$(frontmost_browser_url 2>/dev/null || true)"
    if [[ "$url" == *"meet.google.com"* ]]; then
        echo "meet"
        return 0
    fi

    if provider_running zoom; then
        echo "zoom"
        return 0
    fi

    if provider_running teams; then
        echo "teams"
        return 0
    fi

    return 1
}

detect_provider_from_target() {
    local target="${1:-}"
    local target_lower
    target_lower="$(printf '%s' "$target" | tr '[:upper:]' '[:lower:]')"

    if [[ "$target_lower" == zoommtg://* ]] || [[ "$target_lower" == *"zoom.us/"* ]] || [[ "$target" =~ ^[0-9][0-9[:space:]-]{7,}$ ]]; then
        echo "zoom"
        return 0
    fi

    if [[ "$target_lower" == *"meet.google.com/"* ]] || [[ "$target" =~ ^[a-z]{3}-[a-z]{4}-[a-z]{3}$ ]]; then
        echo "meet"
        return 0
    fi

    if [[ "$target_lower" == *"teams.microsoft.com/"* ]] || [[ "$target_lower" == msteams:* ]] || [[ "$target_lower" == *"teams.live.com/"* ]]; then
        echo "teams"
        return 0
    fi

    return 1
}

delegate_provider() {
    local provider
    provider="$(normalize_provider "$1")"
    shift || true

    local provider_exec
    if ! provider_exec="$(resolve_provider_exec "$provider")"; then
        json_error "agent-$provider is not available" 1
        return 1
    fi

    if [[ "${OUTPUT_FORMAT:-text}" != "json" ]]; then
        exec "$provider_exec" "$@"
    fi

    local stdout_file stderr_file status
    stdout_file="$(mktemp)"
    stderr_file="$(mktemp)"

    set +e
    "$provider_exec" "$@" >"$stdout_file" 2>"$stderr_file"
    status=$?
    set -e

    python3 - "$provider" "$status" "$stdout_file" "$stderr_file" "$@" <<'PY'
import json
import pathlib
import sys

provider = sys.argv[1]
status = int(sys.argv[2])
stdout_path = pathlib.Path(sys.argv[3])
stderr_path = pathlib.Path(sys.argv[4])
command = sys.argv[5:]

stdout = stdout_path.read_text()
stderr = stderr_path.read_text()
stdout_path.unlink(missing_ok=True)
stderr_path.unlink(missing_ok=True)

result = stdout.strip()
try:
    parsed_result = json.loads(result)
except Exception:
    parsed_result = result

payload = {
    "success": status == 0,
    "tool": "meetings",
    "provider": provider,
    "command": command,
    "exit_code": status,
    "result": parsed_result,
}

if stderr.strip():
    payload["stderr"] = stderr.strip()

print(json.dumps(payload, indent=2))
PY

    return "$status"
}

parse_provider_flag() {
    SELECTED_PROVIDER=""
    REMAINING_ARGS=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --provider)
                SELECTED_PROVIDER="$(normalize_provider "${2:-}")"
                shift 2
                ;;
            *)
                REMAINING_ARGS+=("$1")
                shift
                ;;
        esac
    done
}

cmd_snapshot() {
    local active url
    active="$(detect_active_provider 2>/dev/null || true)"
    url="$(frontmost_browser_url 2>/dev/null || true)"

    python3 - "$SCRIPT_DIR" "$active" "$url" <<'PY'
import json
import os
import platform
import subprocess
import sys
from pathlib import Path

script_dir = Path(sys.argv[1])
active = sys.argv[2] or None
frontmost_url = sys.argv[3] or None
leaf_dir = Path(os.environ.get("AGENT_DO_MEETINGS_TOOL_DIR", str(script_dir)))


def provider_exec(provider: str) -> Path:
    return leaf_dir / f"agent-{provider}"


def running(provider: str) -> bool:
    forced = os.environ.get("AGENT_DO_MEETINGS_ACTIVE_PROVIDER")
    aliases = {
        "zoom-us": "zoom",
        "google": "meet",
        "google-meet": "meet",
        "google_meet": "meet",
        "msteams": "teams",
        "microsoft": "teams",
        "microsoft-teams": "teams",
        "microsoft_teams": "teams",
    }
    if forced and aliases.get(forced, forced) == provider:
        return True
    if provider == "meet":
        return "meet.google.com" in (os.environ.get("AGENT_DO_MEETINGS_FRONTMOST_URL", frontmost_url or ""))
    if platform.system() == "Darwin":
        if provider == "zoom":
            return subprocess.run(["pgrep", "-x", "zoom.us"], capture_output=True, check=False).returncode == 0
        if provider == "teams":
            return subprocess.run(["pgrep", "-x", "Microsoft Teams"], capture_output=True, check=False).returncode == 0 or subprocess.run(["pgrep", "-x", "Teams"], capture_output=True, check=False).returncode == 0
    return False


providers = {
    "zoom": {
        "available": provider_exec("zoom").exists(),
        "running": running("zoom"),
        "supports": ["join", "new", "schedule", "mute", "video", "share", "chat", "end"],
    },
    "meet": {
        "available": provider_exec("meet").exists(),
        "running": running("meet"),
        "supports": ["join", "new", "schedule", "mute", "video", "share", "chat", "captions", "end"],
    },
    "teams": {
        "available": provider_exec("teams").exists(),
        "running": running("teams"),
        "supports": ["join", "new", "call", "chat", "mute", "video", "share", "status", "end"],
    },
}

payload = {
    "tool": "meetings",
    "timestamp": subprocess.run(
        ["date", "-u", "+%Y-%m-%dT%H:%M:%SZ"],
        text=True,
        capture_output=True,
        check=False,
    ).stdout.strip(),
    "platform": platform.system(),
    "active_provider": active,
    "frontmost_url": frontmost_url,
    "providers": providers,
}

print(json.dumps(payload, indent=2))
PY
}

cmd_providers() {
    cat <<'EOF'
zoom
meet
teams
EOF
}

cmd_active() {
    local provider
    if provider="$(detect_active_provider 2>/dev/null)"; then
        if [[ "${OUTPUT_FORMAT:-text}" == "json" ]]; then
            json_result "{\"tool\":\"meetings\",\"active_provider\":\"$provider\"}"
        else
            printf '%s\n' "$provider"
        fi
        return 0
    fi

    json_error "No active meeting provider detected" 1
    return 1
}

resolve_generic_provider() {
    local explicit_provider="$1"
    local target="${2:-}"

    if [[ -n "$explicit_provider" ]]; then
        printf '%s\n' "$explicit_provider"
        return 0
    fi

    if [[ -n "$target" ]]; then
        detect_provider_from_target "$target"
        return $?
    fi

    detect_active_provider
}

cmd_join() {
    parse_provider_flag "$@"
    local target="${REMAINING_ARGS[0]:-}"
    if [[ -z "$target" ]]; then
        json_error "Meeting target required" 1
        return 1
    fi

    local provider
    if ! provider="$(resolve_generic_provider "$SELECTED_PROVIDER" "$target")"; then
        json_error "Could not detect meeting provider. Use --provider zoom|meet|teams." 1
        return 1
    fi

    delegate_provider "$provider" join "$target"
}

cmd_new() {
    parse_provider_flag "$@"
    local first="${REMAINING_ARGS[0]:-}"
    local provider

    if [[ -n "$first" ]] && [[ "$first" != --* ]]; then
        provider="$(normalize_provider "$first")"
    else
        provider="${SELECTED_PROVIDER:-}"
    fi

    if [[ -z "$provider" ]]; then
        provider="zoom"
    fi

    case "$provider" in
        zoom) delegate_provider "$provider" start ;;
        meet|teams) delegate_provider "$provider" new ;;
        *) json_error "Unsupported provider for new meeting: $provider" 1; return 1 ;;
    esac
}

cmd_schedule() {
    parse_provider_flag "$@"
    local provider="${SELECTED_PROVIDER:-}"
    local remaining=("${REMAINING_ARGS[@]}")

    if [[ -z "$provider" ]]; then
        provider="$(normalize_provider "${remaining[0]:-}")"
        remaining=("${remaining[@]:1}")
    fi

    local topic="${remaining[0]:-}"
    if [[ -z "$provider" ]] || [[ -z "$topic" ]]; then
        json_error "Usage: schedule <provider> <topic> [provider-specific args...]" 1
        return 1
    fi

    case "$provider" in
        zoom|meet)
            delegate_provider "$provider" schedule "${remaining[@]}"
            ;;
        *)
            json_error "Scheduling is not implemented for provider: $provider" 1
            return 1
            ;;
    esac
}

cmd_provider_control() {
    local action="$1"
    shift || true

    parse_provider_flag "$@"
    local provider
    if ! provider="$(resolve_generic_provider "$SELECTED_PROVIDER")"; then
        json_error "No active meeting provider detected. Use --provider zoom|meet|teams." 1
        return 1
    fi

    delegate_provider "$provider" "$action" "${REMAINING_ARGS[@]}"
}

parse_output_format "${@:-}"
ARGS=("${PARSED_ARGS[@]}")
command="${ARGS[0]:-help}"

case "$command" in
    snapshot|status)
        cmd_snapshot
        ;;
    providers|list)
        if [[ "${OUTPUT_FORMAT:-text}" == "json" ]]; then
            json_result '{"tool":"meetings","providers":["zoom","meet","teams"]}'
        else
            cmd_providers
        fi
        ;;
    active)
        cmd_active
        ;;
    join)
        shift_count=1
        cmd_join "${ARGS[@]:$shift_count}"
        ;;
    new|start)
        shift_count=1
        cmd_new "${ARGS[@]:$shift_count}"
        ;;
    schedule)
        shift_count=1
        cmd_schedule "${ARGS[@]:$shift_count}"
        ;;
    mute|video|share|chat|end)
        shift_count=1
        cmd_provider_control "$command" "${ARGS[@]:$shift_count}"
        ;;
    zoom|meet|teams)
        if [[ ${#ARGS[@]} -lt 2 ]]; then
            json_error "Subcommand required for $command" 1
            exit 1
        fi
        delegate_provider "$command" "${ARGS[@]:1}"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        json_error "Unknown command: $command" 1
        if [[ "${OUTPUT_FORMAT:-text}" != "json" ]]; then
            echo "Try: agent-meetings help" >&2
        fi
        exit 1
        ;;
esac
