            code_args.extend(["--length", str(code_length)])
        payload = run_email_json(*code_args)
        code = str(payload.get("code") or "")
        if not code:
            raise RuntimeError("No verification code returned from email lookup")
        run_browse("fill", selector, code)
        wait_brief()
        click_first_selector(submit_selectors)
        wait_for_settle()
        raise_if_passkey_challenge_visible()
        return []
    except ActionRequiredError:
        raise
    except RuntimeError as exc:
        raise ActionRequiredError("EMAIL_CHALLENGE_TIMEOUT", str(exc))


