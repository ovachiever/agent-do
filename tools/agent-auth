def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def fail(message: str, *, json_mode: bool = False, code: str = "error", exit_code: int = 1, extra: dict[str, Any] | None = None) -> int:
    payload = {"ok": False, "error": code, "message": message}
    if extra:
        payload.update(extra)
    if json_mode:
        print(json.dumps(payload, indent=2))
    else:
        print(f"Error: {message}", file=sys.stderr)
    return exit_code


def _load_yaml_data(path: Path) -> dict[str, Any]:
    if yaml is not None:
        with open(path, encoding="utf-8") as handle:
            return yaml.safe_load(handle) or {}

    ruby = subprocess.run(
        [
            "ruby",
            "-e",
            'require "yaml"; require "json"; print JSON.generate(YAML.load_file(ARGV[0]) || {})',
            str(path),
        ],
        check=False,
        capture_output=True,
        text=True,
    )
    if ruby.returncode != 0:
        raise RuntimeError(
            f"Could not parse YAML without PyYAML. Ruby fallback failed: {ruby.stderr.strip()}"
        )
    return json.loads(ruby.stdout or "{}")


def _yaml_scalar(value: Any) -> str:
    if isinstance(value, bool):
        return "true" if value else "false"
    if value is None:
        return "null"
    if isinstance(value, (int, float)):
        return str(value)
    text = str(value)
    if text == "" or re.search(r"[:#\-\[\]\{\}\n]|^\s|\s$", text):
        return json.dumps(text)
    return text


def dump_yaml_lines(value: Any, indent: int = 0) -> list[str]:
    prefix = " " * indent
    if isinstance(value, dict):
        lines: list[str] = []
        for key, item in value.items():
            if isinstance(item, dict):
                if not item:
                    lines.append(f"{prefix}{key}: {{}}")
                else:
                    lines.append(f"{prefix}{key}:")
                    lines.extend(dump_yaml_lines(item, indent + 2))
            elif isinstance(item, list):
                if not item:
                    lines.append(f"{prefix}{key}: []")
                else:
                    lines.append(f"{prefix}{key}:")
                    for entry in item:
                        if isinstance(entry, (dict, list)):
                            lines.append(f"{prefix}  -")
                            lines.extend(dump_yaml_lines(entry, indent + 4))
                        else:
                            lines.append(f"{prefix}  - {_yaml_scalar(entry)}")
            else:
                lines.append(f"{prefix}{key}: {_yaml_scalar(item)}")
        return lines

    if isinstance(value, list):
        lines = []
        for entry in value:
            if isinstance(entry, (dict, list)):
                lines.append(f"{prefix}-")
                lines.extend(dump_yaml_lines(entry, indent + 2))
            else:
                lines.append(f"{prefix}- {_yaml_scalar(entry)}")
        return lines

    return [f"{prefix}{_yaml_scalar(value)}"]


def dump_yaml_data(data: dict[str, Any]) -> str:
    return "\n".join(dump_yaml_lines(data)) + "\n"


def ensure_root() -> None:
    PROFILES_DIR.mkdir(parents=True, exist_ok=True)
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        CONFIG_PATH.write_text("version: 1\n", encoding="utf-8")


def site_slug(site: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", site.strip().lower()).strip("-")


def env_prefix(source: str) -> str:
    value = source
    if "." in source:
        value = re.sub(r"^(www\.|app\.|accounts\.)", "", source)
        value = re.sub(r"\.[a-z0-9]+$", "", value)
    return re.sub(r"[^A-Za-z0-9]+", "_", value).upper().strip("_") or "SITE"


def auth_paths(site: str, name: str = "default") -> dict[str, Path]:
    slug = site_slug(site)
    return {
        "profile": PROFILES_DIR / f"{slug}.yaml",
        "session_dir": SESSIONS_DIR / slug / name,
        "meta": SESSIONS_DIR / slug / name / "meta.json",
        "state": SESSIONS_DIR / slug / name / "state.enc",
    }


def browse_session_name(site: str, name: str = "default") -> str:
    return f"auth-{site_slug(site)}-{site_slug(name)}"


def read_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    return json.loads(path.read_text(encoding="utf-8"))


def write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def read_backup_code_state() -> dict[str, Any]:
    data = read_json(BACKUP_CODE_STATE_PATH)
    return data if isinstance(data, dict) else {}


def write_backup_code_state(payload: dict[str, Any]) -> None:
    write_json(BACKUP_CODE_STATE_PATH, payload)


def load_profile(site: str) -> dict[str, Any] | None:
    path = auth_paths(site)["profile"]
    if not path.exists():
        return None
    data = _load_yaml_data(path)
    if not isinstance(data, dict):
        return None
    return data


def list_profiles() -> list[dict[str, Any]]:
    ensure_root()
    profiles = []
    for path in sorted(PROFILES_DIR.glob("*.yaml")):
        data = _load_yaml_data(path)
        if isinstance(data, dict):
            profiles.append(data)
    return profiles


def list_session_meta(site: str) -> list[dict[str, Any]]:
    site_dir = SESSIONS_DIR / site_slug(site)
    if not site_dir.exists():
        return []
    sessions = []
    for meta_path in sorted(site_dir.glob("*/meta.json")):
        data = read_json(meta_path)
        if data:
            sessions.append(data)
    sessions.sort(key=lambda item: item.get("updated_at", ""), reverse=True)
    return sessions


def get_session_meta(site: str, name: str = "default") -> dict[str, Any] | None:
    data = read_json(auth_paths(site, name)["meta"])
    return data or None


def write_session_meta(site: str, name: str, payload: dict[str, Any]) -> dict[str, Any]:
    path_info = auth_paths(site, name)
    session_dir = path_info["session_dir"]
    session_dir.mkdir(parents=True, exist_ok=True)
    base = get_session_meta(site, name) or {
        "site": site_slug(site),
        "name": name,
        "browse_session": browse_session_name(site, name),
        "created_at": now_iso(),
    }
    base.update(payload)
    base["updated_at"] = now_iso()
    write_json(path_info["meta"], base)
    return base


def delete_session_meta(site: str, name: str) -> None:
    path_info = auth_paths(site, name)
    if path_info["session_dir"].exists():
        shutil.rmtree(path_info["session_dir"], ignore_errors=True)


def session_bundle_exists(site: str, name: str = "default") -> bool:
    return auth_paths(site, name)["state"].exists()


