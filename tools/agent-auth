def wait_for_validation(site: str, profile: dict[str, Any], *, timeout_seconds: int, interval_seconds: int) -> dict[str, Any]:
    deadline = time.monotonic() + max(timeout_seconds, 1)
    interval_ms = max(interval_seconds, 1) * 1000
    last_validation = apply_validation(site, profile)
    while time.monotonic() < deadline:
        if last_validation.get("ok"):
            return last_validation
        try:
            run_browse("wait", str(interval_ms))
        except Exception:
            time.sleep(max(interval_seconds, 1))
        last_validation = apply_validation(site, profile)
    return last_validation


def identity_values(identity: str | None) -> dict[str, str]:
    username = (identity or "").strip()
    local_part = username.split("@", 1)[0] if "@" in username else username
    return {
        "username": username,
        "value": username,
        "local_part": local_part,
    }


def expand_selector_patterns(patterns: list[str], identity: str | None = None) -> list[str]:
    values = identity_values(identity)
    expanded: list[str] = []
    for pattern in patterns:
        if not pattern:
            continue
        if "{" in pattern and "}" in pattern:
            try:
                expanded.append(pattern.format(**values))
            except KeyError:
                continue
        else:
            expanded.append(pattern)
    return dedupe_preserve_order(expanded)


def click_matching_identity(patterns: list[str], identity: str | None) -> str | None:
    if not identity:
        return None
    selectors = expand_selector_patterns(patterns, identity)
    return click_first_selector(selectors)


def resolve_profile_username(profile: dict[str, Any]) -> str | None:
    creds = ((profile.get("credentials") or {}).get("site") or {})
    username_key = creds.get("username")
    if not username_key:
        return None
    return resolve_secret(str(username_key))


