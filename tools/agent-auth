def safe_macos_dialog_probe() -> dict[str, Any] | None:
    try:
        permissions = run_macos_json("permissions")
    except Exception as exc:
        return {"available": False, "error": str(exc)}
    if not permissions.get("granted"):
        return {
            "available": False,
            "granted": False,
            "message": permissions.get("message"),
        }
    try:
        frontmost = run_macos_json("frontmost")
    except Exception:
        frontmost = None
    try:
        dialog = run_macos_json("dialog", "detect")
    except Exception as exc:
        return {
            "available": True,
            "granted": True,
            "frontmost": frontmost,
            "error": str(exc),
        }
    if dialog.get("type"):
        dialog["available"] = True
        dialog["granted"] = True
        dialog["frontmost"] = frontmost
        return dialog
    return {
        "available": True,
        "granted": True,
        "frontmost": frontmost,
        "type": None,
        "message": dialog.get("message", "No dialog detected"),
    }


