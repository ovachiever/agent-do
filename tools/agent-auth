def wait_for_settle() -> None:
    try:
        run_browse("wait", "--stable")
    except Exception:
        wait_brief(1000)


def passkey_challenge_details() -> dict[str, Any] | None:
    selectors = [
        'input[autocomplete="webauthn"]',
        '[data-webauthn]',
        '[data-passkey]',
        'button[aria-label*="passkey" i]',
    ]
    visible = [selector for selector in selectors if selector_exists(selector)]
    text = read_page_text()
    lowered = text.lower()
    markers = [
        "use a passkey",
        "sign in with a passkey",
        "use your passkey",
        "touch your security key",
        "security key",
    ]
    matched = [marker for marker in markers if marker in lowered]
    if not visible and not matched:
        return None
    return {"selectors": visible, "markers": matched, "url": read_page_url().strip()}


