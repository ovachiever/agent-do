    return tool_cmd_from_env("AGENT_DO_AUTH_SMS_CMD", default)


def macos_cmd() -> list[str]:
    default = [str(ROOT / "tools" / "agent-macos" / "agent-macos")]
    return tool_cmd_from_env("AGENT_DO_AUTH_MACOS_CMD", default)


def run_tool(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True, check=False)


def run_browse(*args: str) -> dict[str, Any]:
    proc = run_tool([*browse_cmd(), "--json", *args])
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or f"browse failed: {' '.join(args)}")
    payload = json.loads(proc.stdout or "{}")
    if payload.get("success") is False:
        message = payload.get("error") or payload.get("message") or json.dumps(payload)
        raise RuntimeError(str(message))
    return payload.get("data") or payload.get("result") or payload


def run_email_json(*args: str) -> dict[str, Any]:
    proc = run_tool([*email_cmd(), "--json", *args])
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"email failed: {' '.join(args)}"
        raise RuntimeError(detail)
    payload = json.loads(proc.stdout or "{}")
    if payload.get("ok") is False:
        raise RuntimeError(payload.get("message") or "email command failed")
    return payload


def run_sms_json(*args: str) -> dict[str, Any]:
    proc = run_tool([*sms_cmd(), "--json", *args])
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"sms failed: {' '.join(args)}"
        raise RuntimeError(detail)
    payload = json.loads(proc.stdout or "{}")
    if payload.get("ok") is False:
