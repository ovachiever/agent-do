def provider_display_name(provider: str) -> str:
    value = provider.strip().lower()
    if value == "github":
        return "GitHub"
    if value == "google":
        return "Google"
    return provider.capitalize()


def default_profile(
    site: str,
    *,
    domain: str | None = None,
    login_url: str | None = None,
    provider_override: str | None = None,
) -> dict[str, Any]:
    slug = site_slug(site)
    provider_override = (provider_override or "").strip().lower() or None
    if slug in KNOWN_PROFILES and provider_override in (None, slug, "generic"):
        profile = copy.deepcopy(KNOWN_PROFILES[slug])
        if domain:
            if domain not in profile["domains"]:
                profile["domains"] = [domain, *profile["domains"]]
            browser_domains = profile.get("browser_import", {}).get("domains", [])
            normalized = f".{domain.lstrip('.')}"
            if normalized not in browser_domains:
                browser_domains.insert(0, normalized)
                profile["browser_import"]["domains"] = browser_domains
        if login_url:
            profile["login_url"] = login_url
        return profile

    resolved_domain = (domain or site).strip()
    title = " ".join(part.capitalize() for part in slug.replace("_", "-").split("-"))
    prefix = env_prefix(resolved_domain)
    normalized_domain = resolved_domain.lstrip(".")
    profile = {
        "id": slug,
        "title": title or "Site",
        "domains": [normalized_domain],
        "login_url": login_url or f"https://{normalized_domain}/login",
        "validation": {
            "url_patterns": [f"https://{normalized_domain}/*"],
            "signed_in_markers": [],
            "signed_out_markers": ["Sign in", "Log in", "Login"],
        },
        "strategies": ["saved-session", "browser-import", "site-creds", "interactive"],
        "provider": {"type": "generic"},
        "credentials": {
            "site": {
                "username": f"{prefix}_EMAIL",
                "password": f"{prefix}_PASSWORD",
            }
        },
        "browser_import": {"browser": "arc", "domains": [f".{normalized_domain}"]},
        "notes": ["Tune validation markers for this site after the first successful authenticated run."],
    }

    provider_name = provider_override or "generic"
    profile["provider"] = {"type": provider_name}
    if provider_name in {"github", "google"}:
        profile["strategies"] = ["saved-session", "browser-import", "provider-refresh", "interactive"]
        profile.get("credentials", {}).pop("site", None)
        profile["provider"]["refresh"] = provider_default_refresh(provider_name)
        profile["notes"].insert(0, f"This site is expected to use {provider_display_name(provider_name)} SSO.")
    return profile


def state_from_profile(site: str) -> str:
    profile = load_profile(site)
    if profile is None:
        return "unconfigured"
    meta = get_session_meta(site)
    if meta and meta.get("state") == "checkpoint":
        return "checkpoint"
    if not meta or (not session_bundle_exists(site) and not meta.get("browse_session")):
        return "configured"
    if meta.get("state") == "authenticated" and meta.get("last_validation_ok") is True:
        return "authenticated"
    if meta.get("state") == "stale" or meta.get("last_validation_ok") is False:
        return "stale"
    return "configured"


def tool_cmd_from_env(var_name: str, default: list[str]) -> list[str]:
    override = os.environ.get(var_name)
    return shlex.split(override) if override else default


def browse_cmd() -> list[str]:
    default = [str(ROOT / "tools" / "agent-browse" / "agent-browse")]
    return tool_cmd_from_env("AGENT_DO_AUTH_BROWSE_CMD", default)


def creds_cmd() -> list[str]:
    default = [str(ROOT / "tools" / "agent-creds")]
    return tool_cmd_from_env("AGENT_DO_AUTH_CREDS_CMD", default)


def email_cmd() -> list[str]:
    default = [str(ROOT / "tools" / "agent-email")]
    return tool_cmd_from_env("AGENT_DO_AUTH_EMAIL_CMD", default)


def sms_cmd() -> list[str]:
