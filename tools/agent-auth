    source_profile = provider_source_profile(profile)
    return source_profile or profile


def resolve_live_login_credentials(profile: dict[str, Any]) -> tuple[str | None, str | None, list[str]]:
    credentials_profile = credentials_profile_for_live_login(profile)
    creds = ((credentials_profile.get("credentials") or {}).get("site") or {})
    username_key = creds.get("username")
    password_key = creds.get("password")
    username = resolve_secret(str(username_key) if username_key else None)
    password = resolve_secret(str(password_key) if password_key else None)
    missing: list[str] = []
    if username_key and not username:
        missing.append(str(username_key))
    if password_key and not password:
        missing.append(str(password_key))
    return username, password, missing


def provider_checkpoint_state(profile: dict[str, Any], provider_name: str, provider_username: str | None) -> dict[str, str | None]:
    refresh_cfg = provider_refresh_config(profile)
    defaults = provider_default_refresh(provider_name)
    account_selectors = list(refresh_cfg.get("account_selectors") or defaults.get("account_selectors", []))
    consent_selectors = list(refresh_cfg.get("consent_selectors") or defaults.get("consent_selectors", []))

    clicked_account = click_matching_identity(account_selectors, provider_username)
    if clicked_account:
        wait_for_settle()

    clicked_consent = None
    if consent_selectors and first_existing_selector(consent_selectors):
        clicked_consent = click_first_selector(consent_selectors)
        wait_for_settle()

    return {
        "account_selector": clicked_account,
        "consent_selector": clicked_consent,
    }


def missing_totp_keys(profile: dict[str, Any]) -> list[str]:
