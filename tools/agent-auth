def complete_phone_challenge_with_baseline(profile: dict[str, Any], baseline_ids: list[str] | None = None) -> list[str]:
    challenge = phone_challenge_config(profile)
    if not challenge:
        return []

    challenge_type = str(challenge.get("type") or "code").strip().lower()
    timeout_seconds = int(challenge.get("timeout_seconds") or 120)
