def complete_totp_if_present(
    profile: dict[str, Any],
    totp_secret: str | None,
    *,
    selectors: list[str],
    submit_selectors: list[str],
) -> list[str]:
    selector = first_existing_selector(selectors)
    if not selector:
        return []
    if not totp_secret:
        return missing_totp_keys(profile)
    code = generate_totp_code(totp_secret)
    run_browse("fill", selector, code)
    wait_brief()
    click_first_selector(submit_selectors)
    wait_for_settle()
    return []


def missing_backup_code_keys(profile: dict[str, Any]) -> list[str]:
    secret_name = backup_code_secret_name(profile)
    if secret_name:
        return [secret_name]
    return ["BACKUP_CODES"]


def complete_backup_code_if_present(profile: dict[str, Any]) -> tuple[list[str], tuple[str, str] | None]:
    selector = first_existing_selector(backup_code_input_selectors(profile))
    details = backup_code_challenge_details(profile)
    if not selector and not details:
        return [], None
    if not selector:
        raise ActionRequiredError(
            "BACKUP_CODE_FIELD_MISSING",
            "Backup-code challenge is visible but no input field selector is configured for this page",
        )

    secret_name = backup_code_secret_name(profile)
    if not secret_name:
        return missing_backup_code_keys(profile), None

    raw_value, codes = available_backup_codes(secret_name)
    if raw_value is None:
        return missing_backup_code_keys(profile), None
    if not codes:
        raise ActionRequiredError(
            "BACKUP_CODES_EXHAUSTED",
            f"No unused backup codes remain in {secret_name}",
        )

    code = codes[0]
    run_browse("fill", selector, code)
    wait_brief()
    click_first_selector(backup_code_submit_selectors(profile))
    wait_for_settle()
    if not first_existing_selector(backup_code_input_selectors(profile)):
        mark_backup_code_used(secret_name, code)
    return [], (secret_name, code)


