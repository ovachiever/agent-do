def detect_checkpoints(profile: dict[str, Any]) -> list[dict[str, Any]]:
    text = current_page_text()
    lowered = text.lower()
    checkpoints: list[dict[str, Any]] = []

    captcha = detect_captcha_result()
    if captcha.get("hasCaptcha"):
        checkpoints.append(
            {
                "type": "captcha",
                "action_required": "CAPTCHA_REQUIRED",
                "source": "browser",
                "details": {"types": captcha.get("types", [])},
            }
        )

    passkey = passkey_challenge_details()
    if passkey:
        checkpoints.append(
            {
                "type": "passkey",
                "action_required": "PASSKEY_CHALLENGE_REQUIRED",
                "source": "browser",
                "details": passkey,
            }
        )

    email_challenge = email_challenge_config(profile)
    challenge_active = False
    if email_challenge:
        challenge_type = str(email_challenge.get("type") or "code").strip().lower()
        email_wait_markers = match_text_markers(
            text,
            [
                "check your email",
                "we emailed you",
                "verification code we emailed",
                "magic link",
            ],
        )
        if challenge_type == "link" and email_wait_markers:
            challenge_active = True
            checkpoints.append(
                {
                    "type": "email-link",
                    "action_required": "EMAIL_CHALLENGE_PENDING",
                    "source": "email",
                    "details": {"markers": email_wait_markers, "command": build_email_probe_command(email_challenge)},
                }
            )
        elif challenge_type == "code" and first_existing_selector(email_code_input_selectors(email_challenge)):
            challenge_active = True
            checkpoints.append(
                {
                    "type": "email-code",
                    "action_required": "EMAIL_CHALLENGE_PENDING",
                    "source": "email",
                    "details": {"command": build_email_probe_command(email_challenge)},
                }
            )

    phone_challenge = phone_challenge_config(profile)
    if phone_challenge:
        challenge_type = str(phone_challenge.get("type") or "code").strip().lower()
        phone_wait_markers = match_text_markers(
            text,
            [
                "check your phone",
                "we texted you",
                "texted you a code",
                "check your messages",
                "sign-in link",
                "sms",
            ],
        )
        if challenge_type == "link" and phone_wait_markers:
            challenge_active = True
            checkpoints.append(
                {
                    "type": "sms-link",
                    "action_required": "PHONE_CHALLENGE_PENDING",
                    "source": "sms",
                    "details": {"markers": phone_wait_markers, "command": build_phone_probe_command(phone_challenge)},
                }
            )
        elif challenge_type == "code" and first_existing_selector(phone_code_input_selectors(phone_challenge)):
            challenge_active = True
            checkpoints.append(
                {
                    "type": "sms-code",
                    "action_required": "PHONE_CHALLENGE_PENDING",
                    "source": "sms",
                    "details": {"command": build_phone_probe_command(phone_challenge)},
                }
            )

    device_markers = match_text_markers(
        text,
        [
            "check your phone",
            "approve sign in",
            "approve the sign in",
            "approve this sign-in",
            "tap yes on your phone",
            "notification sent to your phone",
            "open the app on your device",
            "review the sign-in request",
            "use your phone or tablet",
            "check your device",
        ],
    )
    if device_markers and not challenge_active:
        checkpoints.append(
            {
                "type": "device-approval",
                "action_required": "DEVICE_APPROVAL_REQUIRED",
                "source": "browser",
                "details": {"markers": device_markers},
            }
        )

    totp_markers = match_text_markers(
        text,
        [
            "two-factor",
            "two factor",
            "authenticator",
            "one-time code",
            "verification code",
            "enter the code from your app",
        ],
    )
    if not email_challenge and not phone_challenge and first_existing_selector(
        ['input[name="app_otp"]', 'input[name="otp"]', 'input[name="totp"]', 'input[name="totpPin"]', 'input[autocomplete="one-time-code"]']
    ):
        checkpoints.append(
            {
                "type": "totp",
                "action_required": "TOTP_REQUIRED",
                "source": "browser",
                "details": {"markers": totp_markers},
            }
        )

    account_markers = match_text_markers(
        text,
        ["choose an account", "select an account", "pick an account", "continue as"],
    )
    provider_name = provider_type(profile)
    chooser_selectors = expand_selector_patterns(
        list(provider_refresh_config(profile).get("account_selectors") or provider_default_refresh(provider_name).get("account_selectors", [])),
        resolve_profile_username(load_profile(provider_name) or default_profile(provider_name)) if provider_name in {"github", "google"} else None,
    )
    if account_markers or first_existing_selector(chooser_selectors):
        checkpoints.append(
            {
                "type": "account-chooser",
                "action_required": "ACCOUNT_CHOOSER_REQUIRED",
                "source": "browser",
                "details": {"markers": account_markers, "selectors": chooser_selectors[:4]},
            }
        )

    consent_markers = match_text_markers(
        text,
        ["authorize", "grant access", "allow access", "continue", "wants to access your"],
    )
    consent_selectors = list(
        provider_refresh_config(profile).get("consent_selectors")
        or provider_default_refresh(provider_name).get("consent_selectors", [])
    )
    if consent_markers or first_existing_selector(consent_selectors):
        checkpoints.append(
            {
                "type": "consent",
                "action_required": "CONSENT_REQUIRED",
                "source": "browser",
                "details": {"markers": consent_markers, "selectors": consent_selectors[:4]},
            }
        )

    seen_actions: set[str] = set()
    unique: list[dict[str, Any]] = []
    for checkpoint in checkpoints:
        action = str(checkpoint.get("action_required") or "")
        key = f"{action}:{checkpoint.get('type')}"
        if key in seen_actions:
            continue
        seen_actions.add(key)
        unique.append(checkpoint)
    return unique


def probe_state(site: str, profile: dict[str, Any], *, name: str = "default", load_saved: bool = False) -> dict[str, Any]:
    meta = get_session_meta(site, name) or {}
    if load_saved and (not current_page_url() or current_page_url() == "about:blank") and meta:
        try:
            load_saved_session(site, name=name)
        except Exception:
            pass

    url = current_page_url()
    login_form = detect_login_form_result()
    captcha = detect_captcha_result()
    checkpoints = detect_checkpoints(profile)
    macos_dialog = safe_macos_dialog_probe()

    validation = None
    try:
        validation = apply_validation(site, profile)
    except Exception:
        validation = None

    state = "unknown"
    if validation and validation.get("ok"):
        state = "authenticated"
    elif checkpoints:
        state = "checkpoint"
    elif login_form.get("found"):
        state = "signed-out"
    elif url and url != "about:blank":
        state = "in-flight"

    recommended: list[str] = []
    guidance: list[str] = []
    if state == "authenticated":
        recommended.append(f"agent-do auth save {site}")
        guidance.append("The current page satisfies the profile validation markers.")
    if checkpoints:
        recommended.append(f"agent-do auth probe {site}")
    for checkpoint in checkpoints:
        action = checkpoint.get("action_required")
        details = checkpoint.get("details") or {}
        if action == "EMAIL_CHALLENGE_PENDING" and details.get("command"):
            recommended.append(str(details["command"]))
            guidance.append("Email challenge is active on the current login branch.")
        elif action == "PHONE_CHALLENGE_PENDING" and details.get("command"):
            recommended.append(str(details["command"]))
            guidance.append("Phone/SMS challenge is active on the current login branch.")
        elif action == "PASSKEY_CHALLENGE_REQUIRED":
            guidance.append("A passkey or security-key step is blocking browser-only continuation.")
            if macos_dialog and macos_dialog.get("type") and macos_dialog.get("buttons"):
                recommended.append("agent-do macos dialog detect")
                recommended.append("agent-do macos dialog click --default")
        elif action == "DEVICE_APPROVAL_REQUIRED":
            guidance.append("Another trusted device must approve this sign-in unless an alternate auth path is chosen.")
        elif action == "ACCOUNT_CHOOSER_REQUIRED":
            guidance.append("The provider is waiting for an account choice before auth can continue.")
        elif action == "CONSENT_REQUIRED":
            guidance.append("The provider consent screen is visible and needs approval to proceed.")
        elif action == "CAPTCHA_REQUIRED":
            guidance.append("CAPTCHA is visible and blocks zero-touch continuation for this branch.")
        elif action == "TOTP_REQUIRED":
            guidance.append("A TOTP/app code field is visible on the current page.")

    if not checkpoints and login_form.get("found"):
        recommended.append(f"agent-do auth ensure {site}")
        guidance.append("A login form is visible and no higher-order checkpoint is currently detected.")

    recommended = dedupe_preserve_order(recommended)
    guidance = dedupe_preserve_order(guidance)

    return {
        "site": site,
        "state": state,
        "url": url,
        "validation": validation,
        "login_form": login_form,
        "captcha": captcha,
        "checkpoints": checkpoints,
        "desktop_dialog": macos_dialog,
        "recommended": recommended,
        "guidance": guidance,
        "session": {
            "name": name,
            "meta": meta,
        },
    }


def raise_if_manual_checkpoint_visible(profile: dict[str, Any]) -> None:
    checkpoints = detect_checkpoints(profile)
    for checkpoint in checkpoints:
        action = str(checkpoint.get("action_required") or "")
        if action in {
            "PASSKEY_CHALLENGE_REQUIRED",
            "DEVICE_APPROVAL_REQUIRED",
            "CAPTCHA_REQUIRED",
            "ACCOUNT_CHOOSER_REQUIRED",
            "CONSENT_REQUIRED",
        }:
            details = checkpoint.get("details") or {}
            message = checkpoint.get("type", "checkpoint").replace("-", " ")
            if isinstance(details, dict):
                markers = details.get("markers") or []
                if markers:
                    message = f"{message}: {', '.join(markers)}"
            raise ActionRequiredError(action, str(message))


def dedupe_preserve_order(items: list[str]) -> list[str]:
    seen: set[str] = set()
    output: list[str] = []
    for item in items:
        if item and item not in seen:
            seen.add(item)
            output.append(item)
    return output


def identity_values(identity: str | None) -> dict[str, str]:
    username = (identity or "").strip()
    local_part = username.split("@", 1)[0] if "@" in username else username
    return {
        "username": username,
        "value": username,
        "local_part": local_part,
    }


def expand_selector_patterns(patterns: list[str], identity: str | None = None) -> list[str]:
    values = identity_values(identity)
    expanded: list[str] = []
    for pattern in patterns:
        if not pattern:
            continue
        if "{" in pattern and "}" in pattern:
            try:
                expanded.append(pattern.format(**values))
            except KeyError:
                continue
        else:
            expanded.append(pattern)
    return dedupe_preserve_order(expanded)


def click_matching_identity(patterns: list[str], identity: str | None) -> str | None:
    if not identity:
        return None
    selectors = expand_selector_patterns(patterns, identity)
    return click_first_selector(selectors)


def resolve_profile_username(profile: dict[str, Any]) -> str | None:
    creds = ((profile.get("credentials") or {}).get("site") or {})
    username_key = creds.get("username")
    if not username_key:
        return None
    return resolve_secret(str(username_key))


def provider_checkpoint_state(profile: dict[str, Any], provider_name: str, provider_username: str | None) -> dict[str, str | None]:
    refresh_cfg = provider_refresh_config(profile)
    defaults = provider_default_refresh(provider_name)
    account_selectors = list(refresh_cfg.get("account_selectors") or defaults.get("account_selectors", []))
    consent_selectors = list(refresh_cfg.get("consent_selectors") or defaults.get("consent_selectors", []))

    clicked_account = click_matching_identity(account_selectors, provider_username)
    if clicked_account:
        wait_for_settle()

    clicked_consent = None
    if consent_selectors and first_existing_selector(consent_selectors):
        clicked_consent = click_first_selector(consent_selectors)
        wait_for_settle()

    return {
        "account_selector": clicked_account,
        "consent_selector": clicked_consent,
    }


