def live_complete_email_challenge(profile: dict[str, Any], *, browser_override: str | None = None, baseline_ids: list[str] | None = None) -> list[str]:
    challenge = email_challenge_config(profile)
    if not challenge:
        return []
    challenge_type = str(challenge.get("type") or "code").strip().lower()
    timeout_seconds = int(challenge.get("timeout_seconds") or 120)
    poll_seconds = int(challenge.get("poll_interval_seconds") or 5)
    from_filter = str(challenge.get("from_contains") or "").strip()
    subject_filter = str(challenge.get("subject_contains") or "").strip()
    contains_filter = str(challenge.get("contains") or "").strip()
    unread_only = bool(challenge.get("unread", True))

    common_args: list[str] = []
    if from_filter:
        common_args.extend(["--from", from_filter])
    if subject_filter:
        common_args.extend(["--subject", subject_filter])
    if contains_filter:
        common_args.extend(["--contains", contains_filter])
    if unread_only:
        common_args.append("--unread")
    for message_id in baseline_ids or []:
        common_args.extend(["--exclude-id", message_id])
    common_args.extend(["--timeout", str(timeout_seconds), "--interval", str(poll_seconds)])

    try:
        if challenge_type == "link":
            link_args = ["link", *common_args]
            domain = str(challenge.get("domain") or "").strip()
            if domain:
                link_args.extend(["--domain", domain])
            payload = run_email_json(*link_args)
            link = str(payload.get("link") or "")
            if not link:
                raise RuntimeError("No magic link returned from email lookup")
            live_open_link(link, profile, browser_override=browser_override)
            return []

        code_args = ["code", *common_args]
        code_regex = str(challenge.get("code_regex") or "").strip()
        code_length = challenge.get("code_length")
        if code_regex:
            code_args.extend(["--regex", code_regex])
        elif code_length:
            code_args.extend(["--length", str(code_length)])
        payload = run_email_json(*code_args)
        code = str(payload.get("code") or "")
        if not code:
            raise RuntimeError("No verification code returned from email lookup")
        live_click_first_text(["verification code", "one-time code", "code"])
        live_type_text(code)
        live_press_key("enter")
        live_wait_brief(1.0)
        return []
    except ActionRequiredError:
        raise
    except RuntimeError as exc:
        raise ActionRequiredError("EMAIL_CHALLENGE_TIMEOUT", str(exc))


