def live_probe_state(
    site: str,
    profile: dict[str, Any],
    *,
    name: str = "default",
    browser_override: str | None = None,
) -> dict[str, Any]:
    details = live_browser_details(profile, browser_override=browser_override)
    live_focus_browser(details.get("app"))
    text = live_screen_text()
    validation = live_apply_validation(site, profile, browser_override=browser_override)
    checkpoints = validation.get("checkpoints") or []
    login_form = validation.get("login_form") or live_login_form_result(text)
    captcha = live_captcha_result(text)
    meta = get_session_meta(site, name) or {}

    state = "unknown"
    if validation.get("ok"):
        state = "authenticated"
    elif checkpoints:
        state = "checkpoint"
    elif login_form.get("found"):
        state = "signed-out"
    elif text.strip():
        state = "in-flight"

    recommended: list[str] = []
    guidance: list[str] = []
    if validation.get("ok"):
        guidance.append("Live browser text satisfies the profile validation markers.")
    elif checkpoints:
        recommended.append(live_command(site, profile, "advance", site, browser_override=browser_override))
        recommended.append(live_command(site, profile, "probe", site, browser_override=browser_override))
    elif login_form.get("found"):
        recommended.append(live_command(site, profile, "ensure", site, "--strategy", "live-browser-control", browser_override=browser_override))
        guidance.append("A live login form is visible in the system browser.")

    recommended = dedupe_preserve_order(recommended)
    guidance = dedupe_preserve_order(guidance)
    return {
        "site": site,
        "mode": "live-browser",
        "state": state,
        "url": None,
        "window": details.get("app"),
        "validation": validation,
        "login_form": login_form,
        "captcha": captcha,
        "checkpoints": checkpoints,
        "desktop_dialog": safe_macos_dialog_probe(),
        "recommended": recommended,
        "guidance": guidance,
        "session": {"name": name, "meta": meta},
    }


def live_advance_checkpoint(
    site: str,
    profile: dict[str, Any],
    *,
    name: str = "default",
    action_required: str,
    browser_override: str | None = None,
    timeout_seconds: int = 60,
    interval_seconds: int = 5,
) -> dict[str, Any]:
    meta = get_session_meta(site, name) or {}
    action_taken: dict[str, Any] = {"action_required": action_required}

    if action_required == "ACCOUNT_CHOOSER_REQUIRED":
        clicked = live_click_account_choice(profile)
        if not clicked:
            raise ActionRequiredError(action_required, "Account chooser is visible but no matching account text was clickable")
        live_wait_brief(1.0)
        action_taken["text"] = clicked

    elif action_required == "CONSENT_REQUIRED":
        clicked = live_click_consent(profile)
        if not clicked:
            raise ActionRequiredError(action_required, "Consent screen is visible but no consent button text was clickable")
        live_wait_brief(1.0)
        action_taken["text"] = clicked

    elif action_required == "EMAIL_CHALLENGE_PENDING":
        baseline_ids = normalize_baseline_ids(meta.get("email_baseline_ids"))
        live_complete_email_challenge(profile, browser_override=browser_override, baseline_ids=baseline_ids)
        action_taken["baseline_count"] = len(baseline_ids)

    elif action_required == "PHONE_CHALLENGE_PENDING":
        baseline_ids = normalize_baseline_ids(meta.get("phone_baseline_ids"))
        live_complete_phone_challenge(profile, browser_override=browser_override, baseline_ids=baseline_ids)
        action_taken["baseline_count"] = len(baseline_ids)

    elif action_required == "TOTP_REQUIRED":
        missing = live_complete_totp(profile)
        if missing:
            raise ActionRequiredError("MISSING_CREDENTIALS", "TOTP checkpoint is visible but the configured secret is missing", missing=missing)
        action_taken["totp"] = True

    elif action_required == "BACKUP_CODE_REQUIRED":
        missing, used = live_complete_backup_code(profile)
        if missing:
            raise ActionRequiredError("MISSING_CREDENTIALS", "Backup-code checkpoint is visible but no backup codes are configured", missing=missing)
        if used:
            action_taken["backup_code_secret"] = used[0]

    elif action_required == "PASSKEY_CHALLENGE_REQUIRED":
        clicked = live_click_alternate_method(profile)
        if clicked:
            action_taken["alternate_text"] = clicked
        else:
            dialog = safe_macos_dialog_probe()
            if not dialog or not dialog.get("type"):
                raise ActionRequiredError(action_required, "Passkey checkpoint is active but no alternate method or actionable macOS dialog is available")
            run_macos_json("dialog", "click", "--default")
            action_taken["dialog"] = dialog
        live_wait_brief(1.0)

    elif action_required == "DEVICE_APPROVAL_REQUIRED":
        clicked = live_click_alternate_method(profile)
        if clicked:
            action_taken["alternate_text"] = clicked
            live_wait_brief(1.0)
        else:
            deadline = time.monotonic() + max(timeout_seconds, 1)
            while time.monotonic() < deadline:
                validation = live_apply_validation(site, profile, browser_override=browser_override)
                if validation.get("ok"):
                    action_taken["validation"] = validation
                    return action_taken
                time.sleep(max(interval_seconds, 1))
            raise ActionRequiredError(action_required, f"Timed out waiting {timeout_seconds}s for device approval")

    elif action_required == "CAPTCHA_REQUIRED":
        raise ActionRequiredError(action_required, "CAPTCHA is visible and cannot be advanced safely in live-browser control")

    else:
        raise ActionRequiredError(action_required or "UNSUPPORTED_CHECKPOINT", "No safe live-browser action exists for this checkpoint")

    return action_taken


def live_browser_control_login(
    site: str,
    profile: dict[str, Any],
    *,
    name: str = "default",
    timeout_seconds: int = 180,
    interval_seconds: int = 5,
    browser_override: str | None = None,
) -> dict[str, Any]:
    login_url = str(profile.get("login_url") or "").strip()
    if not login_url:
        raise RuntimeError("Live browser control requires a login URL")

    details = live_browser_details(profile, browser_override=browser_override)
    open_browser = False
    try:
        ensure_live_browser_approval(site, profile, browser_override=browser_override)
    except LiveApprovalRequiredError as exc:
        return {
            "site": site,
            "ok": False,
            "state": "action-required",
            "action_required": "LIVE_APPROVAL_REQUIRED",
            "message": str(exc),
            "recommended": [exc.rerun],
        }

    capture_challenge_baselines(site, name, profile)
    live_open_browser_url(login_url, browser=details.get("browser"), app_name=details.get("app"))
    open_browser = True
    if provider_type(profile) in {"github", "google"} and site_slug(site) != provider_type(profile):
        live_click_provider_entry(profile)
        live_wait_brief(1.0)

    username, password, missing = resolve_live_login_credentials(profile)
    provider_name = provider_type(profile)
    deadline = time.monotonic() + max(timeout_seconds, 1)
    last_probe: dict[str, Any] | None = None

    while time.monotonic() < deadline:
        probe = live_probe_state(site, profile, name=name, browser_override=browser_override)
        last_probe = probe
        validation = probe.get("validation") or {}
        if validation.get("ok"):
            meta = persist_live_session_meta(
                site,
                profile,
                name=name,
                strategy="live-browser-control",
                browser_override=browser_override,
                state="authenticated",
                last_validation_ok=True,
                extra={"live_login_url": login_url, "opened": open_browser},
            )
            return {
                "site": site,
                "ok": True,
                "strategy_used": "live-browser-control",
                "validated": True,
                "opened": open_browser,
                "window": details.get("app"),
                "session": {"name": name, "storage": meta.get("storage"), "live_browser_app": meta.get("live_browser_app")},
            }

        checkpoint = checkpoint_from_probe(probe)
        if checkpoint is not None:
            try:
                action_taken = live_advance_checkpoint(
                    site,
                    profile,
                    name=name,
                    action_required=str(checkpoint.get("action_required") or ""),
                    browser_override=browser_override,
                    timeout_seconds=interval_seconds,
                    interval_seconds=max(1, min(interval_seconds, 2)),
                )
            except ActionRequiredError as exc:
                meta = persist_live_session_meta(
                    site,
                    profile,
                    name=name,
                    strategy="live-browser-control",
                    browser_override=browser_override,
                    state="checkpoint",
                    last_validation_ok=False,
                    last_action_required=exc.action_required,
                    last_error=str(exc),
                    extra={"live_login_url": login_url, "opened": open_browser},
                )
                return {
                    "site": site,
                    "ok": False,
                    "state": "action-required",
                    "action_required": exc.action_required,
                    "missing": exc.missing,
                    "message": str(exc),
                    "opened": open_browser,
                    "window": details.get("app"),
                    "probe": probe,
                    "session": {"name": name, "storage": meta.get("storage"), "live_browser_app": meta.get("live_browser_app")},
                    "recommended": [
                        live_command(site, profile, "probe", site, browser_override=browser_override),
                        live_command(site, profile, "advance", site, browser_override=browser_override),
                    ],
                }
            time.sleep(max(interval_seconds, 1))
            continue

        if missing:
            return {
                "site": site,
                "ok": False,
                "state": "action-required",
                "action_required": "MISSING_CREDENTIALS",
                "missing": missing,
                "message": "Live browser control requires additional credentials before it can complete the provider login",
                "opened": open_browser,
                "window": details.get("app"),
            }

        text = live_screen_text()
        if provider_name == "github":
            live_login_with_github(profile, str(username), str(password))
        elif provider_name == "google":
            live_login_with_google(profile, str(username), str(password), text)
        else:
            live_login_with_generic(profile, str(username), str(password))
        time.sleep(max(interval_seconds, 1))

    meta = persist_live_session_meta(
        site,
        profile,
        name=name,
        strategy="live-browser-control",
        browser_override=browser_override,
        state="checkpoint" if last_probe and last_probe.get("checkpoints") else "in-flight",
        last_validation_ok=False,
        last_action_required=(checkpoint_from_probe(last_probe or {}) or {}).get("action_required") if last_probe else None,
        last_error="live_browser_control_timeout",
        extra={"live_login_url": login_url, "opened": open_browser},
    )
    return {
        "site": site,
        "ok": False,
        "state": "action-required",
        "action_required": "LIVE_BROWSER_TIMEOUT",
        "message": "Live browser control did not reach an authenticated state before timeout",
        "opened": open_browser,
        "window": details.get("app"),
        "probe": last_probe,
        "session": {"name": name, "storage": meta.get("storage"), "live_browser_app": meta.get("live_browser_app")},
        "recommended": [
            live_command(site, profile, "probe", site, browser_override=browser_override),
            live_command(site, profile, "advance", site, browser_override=browser_override),
        ],
    }


def interactive_browser_login(
    site: str,
    profile: dict[str, Any],
    *,
    name: str = "default",
    timeout_seconds: int = 180,
    interval_seconds: int = 5,
    browser_override: str | None = None,
    domain_override: str | None = None,
) -> dict[str, Any]:
    login_url = str(profile.get("login_url") or "").strip()
    if not login_url:
        raise RuntimeError("Interactive auth requires a login URL")

    profile_for_import = copy.deepcopy(profile)
    import_config = profile_for_import.get("browser_import") or {}
    browser = str(browser_override or import_config.get("browser") or "").strip()
    domains = list(import_config.get("domains") or [])
    import_domain = str(domain_override or (domains[0] if domains else "")).strip()
    if browser:
        profile_for_import.setdefault("browser_import", {})["browser"] = browser
    if import_domain:
        profile_for_import.setdefault("browser_import", {})["domains"] = [import_domain]

    if not profile_for_import.get("browser_import"):
        raise RuntimeError("Interactive auth requires browser_import configuration")

    open_system_browser(login_url, browser=browser or None)
    deadline = time.monotonic() + max(timeout_seconds, 1)
    last_error = "interactive_login_pending"

    while time.monotonic() < deadline:
        alias = browse_session_name(site, name)
        try:
            imported = browser_import(site, profile_for_import, name=name)
            validation = apply_validation(site, profile_for_import)
            if validation["ok"]:
                meta = persist_browse_alias(
                    site,
                    name=name,
                    alias=imported.get("browse_session"),
                    strategy="interactive",
                    extra={
                        "source_browser": imported.get("source_browser"),
                        "interactive_login_url": login_url,
                    },
                )
                return {
                    "site": site,
                    "ok": True,
                    "strategy_used": "interactive",
                    "validated": True,
                    "opened": True,
                    "login_url": login_url,
                    "source_browser": imported.get("source_browser"),
                    "validation": validation,
                    "session": {"name": name, "browse_session": meta.get("browse_session")},
                }
            probe = probe_state(site, profile_for_import, name=name, load_saved=False)
            checkpoint = checkpoint_from_probe(probe)
            if checkpoint is not None:
                checkpoint_action = str(checkpoint.get("action_required") or "INTERACTIVE_LOGIN")
                meta = persist_browse_alias(
                    site,
                    name=name,
                    alias=imported.get("browse_session"),
                    strategy="interactive",
                    extra={
                        "source_browser": imported.get("source_browser"),
                        "interactive_login_url": login_url,
                    },
                    state="checkpoint",
                    last_validation_ok=False,
                    last_action_required=checkpoint_action,
                    last_error="interactive_import_requires_advance",
                )
                return {
                    "site": site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": ["interactive"],
                    "action_required": checkpoint_action,
                    "message": "Imported authenticated state reached a live checkpoint branch; use probe or advance to continue from the imported session",
                    "opened": True,
                    "login_url": login_url,
                    "source_browser": imported.get("source_browser"),
                    "session": {"name": name, "browse_session": meta.get("browse_session")},
                    "probe": probe,
                    "recommended": [f"agent-do auth probe {site}", f"agent-do auth advance {site}"],
                }
            last_error = "validation_failed_after_interactive_browser_import"
        except Exception as exc:
            last_error = str(exc)
        run_tool([*browse_cmd(), "session", "delete", alias])
        time.sleep(max(interval_seconds, 1))

    write_session_meta(
        site,
        name,
        {
            "last_strategy": "interactive",
            "last_validation_ok": False,
            "state": "checkpoint",
            "last_error": last_error,
            "last_action_required": "INTERACTIVE_LOGIN",
            "interactive_login_url": login_url,
            "interactive_browser": browser or None,
            "interactive_import_domain": import_domain or None,
        },
    )
    return {
        "site": site,
        "ok": False,
        "state": "action-required",
        "attempted": ["interactive"],
        "action_required": "INTERACTIVE_LOGIN",
        "message": "Opened a visible system browser for login, but imported authenticated state was not validated before timeout",
        "opened": True,
        "login_url": login_url,
        "source_browser": browser or None,
        "import_domain": import_domain or None,
        "recommended": [
            f"Finish login in the visible browser, then rerun: agent-do auth ensure {site} --strategy interactive",
            f"Or import manually: agent-do auth import-browser {site}",
        ],
    }


def site_creds_login(site: str, profile: dict[str, Any], *, name: str = "default") -> tuple[bool, list[str]]:
    creds = ((profile.get("credentials") or {}).get("site") or {})
    totp_creds = ((profile.get("credentials") or {}).get("totp") or {})
    username_key = creds.get("username")
    password_key = creds.get("password")
    totp_key = totp_creds.get("secret")
    missing: list[str] = []
    username = resolve_secret(str(username_key) if username_key else None)
    password = resolve_secret(str(password_key) if password_key else None)
    totp_secret = resolve_secret(str(totp_key) if totp_key else None)
    if not username and username_key:
        missing.append(str(username_key))
    if not password and password_key:
        missing.append(str(password_key))
    if missing:
        return False, missing

    adapter_missing = run_site_login_adapter(profile, str(username), str(password), totp_secret)
    if adapter_missing:
        return False, adapter_missing
    raise_if_passkey_challenge_visible()
    validation = apply_validation(site, profile)
    if validation["ok"]:
        save_current_session(site, name=name, strategy="site-creds")
        return True, []
    write_session_meta(
        site,
        name,
        {
            "browse_session": browse_session_name(site, name),
            "last_strategy": "site-creds",
            "last_validation_ok": False,
            "state": "stale",
            "last_error": "validation_failed_after_site_creds",
        },
    )
    return False, []


def cmd_init(args: argparse.Namespace) -> int:
    site = site_slug(args.site)
    if not site or not SITE_RE.match(site):
        return fail("site id must be kebab/underscore-safe lowercase text", json_mode=args.json, code="invalid_site")

    profile = default_profile(site, domain=args.domain, login_url=args.login_url, provider_override=args.provider)
    if args.browser:
        profile.setdefault("browser_import", {})["browser"] = args.browser
    if args.no_browser_import:
        profile["strategies"] = [entry for entry in profile.get("strategies", []) if entry != "browser-import"]
        profile.pop("browser_import", None)
    if args.no_site_creds:
        profile["strategies"] = [entry for entry in profile.get("strategies", []) if entry != "site-creds"]
        profile.get("credentials", {}).pop("site", None)
    if args.email_code or args.magic_link:
        challenge_type = "link" if args.magic_link else "code"
        challenge: dict[str, Any] = {
            "type": challenge_type,
            "unread": True,
            "timeout_seconds": int(args.email_timeout),
            "poll_interval_seconds": int(args.email_interval),
        }
        if args.email_from:
            challenge["from_contains"] = args.email_from
        if args.email_subject:
            challenge["subject_contains"] = args.email_subject
        if args.email_contains:
            challenge["contains"] = args.email_contains
        if args.email_domain and challenge_type == "link":
            challenge["domain"] = args.email_domain
        if args.email_code_length and challenge_type == "code":
            challenge["code_length"] = int(args.email_code_length)
        if args.email_code_regex and challenge_type == "code":
            challenge["code_regex"] = args.email_code_regex
        profile["email_challenge"] = challenge
    if args.sms_code or args.sms_link:
        challenge_type = "link" if args.sms_link else "code"
        challenge = {
            "type": challenge_type,
            "unread": True,
            "timeout_seconds": int(args.sms_timeout),
            "poll_interval_seconds": int(args.sms_interval),
        }
        if args.sms_from:
            challenge["contact_contains"] = args.sms_from
        if args.sms_contains:
            challenge["contains"] = args.sms_contains
        if args.sms_domain and challenge_type == "link":
            challenge["domain"] = args.sms_domain
        if args.sms_code_length and challenge_type == "code":
            challenge["code_length"] = int(args.sms_code_length)
        if args.sms_code_regex and challenge_type == "code":
            challenge["code_regex"] = args.sms_code_regex
        profile["phone_challenge"] = challenge
    try:
        path = write_profile(profile, force=args.force)
    except FileExistsError as exc:
        return fail(str(exc), json_mode=args.json, code="profile_exists")

    payload = {
        "ok": True,
        "site": site,
        "path": str(path),
        "strategies": profile.get("strategies", []),
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"Initialized auth profile for {site}")
        print(path)
    return 0


