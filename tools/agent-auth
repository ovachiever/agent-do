def alternate_method_kind(selector: str) -> str:
    lowered = selector.lower()
    if "backup code" in lowered or "recovery code" in lowered:
        return "backup-code"
    if "verification code" in lowered or "authentication code" in lowered or "authenticator" in lowered:
        return "totp"
    if "password" in lowered:
        return "password"
    return "generic"


def alternate_password_available(profile: dict[str, Any]) -> bool:
    source_profile = provider_source_profile(profile)
    credentials_profile = source_profile or profile
    creds = ((credentials_profile.get("credentials") or {}).get("site") or {})
    username_key = creds.get("username")
    password_key = creds.get("password")
    username = resolve_secret(str(username_key) if username_key else None)
    password = resolve_secret(str(password_key) if password_key else None)
    return bool(username and password)


