def normalize_baseline_ids(values: Any) -> list[str]:
    if not isinstance(values, list):
        return []
    output: list[str] = []
    for item in values:
        value = str(item or "").strip()
        if value:
            output.append(value)
    return output


def capture_challenge_baselines(site: str, name: str, profile: dict[str, Any]) -> dict[str, Any]:
    email_ids = capture_email_baseline(profile)
    phone_ids = capture_phone_baseline(profile)
    return write_session_meta(
        site,
        name,
        {
            "email_baseline_ids": email_ids,
            "phone_baseline_ids": phone_ids,
            "challenge_baselines_captured_at": now_iso(),
        },
    )


def parse_backup_codes(raw_value: str) -> list[str]:
    text = (raw_value or "").strip()
    if not text:
        return []
    if text.startswith("["):
        try:
            parsed = json.loads(text)
        except Exception:
            parsed = None
        if isinstance(parsed, list):
            return [str(item).strip() for item in parsed if str(item).strip()]
    tokens = re.split(r"[\s,]+", text)
    return [token.strip() for token in tokens if token.strip()]


def backup_code_digest(secret_name: str, code: str) -> str:
    return hashlib.sha256(f"{secret_name}:{code}".encode("utf-8")).hexdigest()


def available_backup_codes(secret_name: str) -> tuple[str | None, list[str]]:
    raw_value = resolve_secret(secret_name)
    if not raw_value:
        return None, []
    candidates = parse_backup_codes(raw_value)
    if not candidates:
        return raw_value, []
    state = read_backup_code_state()
    used_hashes = set(((state.get(secret_name) or {}).get("used") or []))
    remaining = [code for code in candidates if backup_code_digest(secret_name, code) not in used_hashes]
    return raw_value, remaining


def mark_backup_code_used(secret_name: str, code: str) -> None:
    state = read_backup_code_state()
    secret_state = state.get(secret_name) or {}
    used = list(secret_state.get("used") or [])
    digest = backup_code_digest(secret_name, code)
    if digest not in used:
        used.append(digest)
    secret_state["used"] = used
    secret_state["updated_at"] = now_iso()
    state[secret_name] = secret_state
    write_backup_code_state(state)


def resolve_secret(key: str | None) -> str | None:
    if not key:
        return None
    env_value = os.environ.get(key)
    if env_value:
        return env_value
    proc = run_tool([*creds_cmd(), "get", key, "--reveal"])
    if proc.returncode != 0:
        return None
    return proc.stdout.strip() or None


def ensure_auth_master_key() -> str:
    existing = resolve_secret(AUTH_MASTER_KEY_NAME)
    if existing:
        return existing

    generated = secrets.token_hex(32)
    proc = run_tool([*creds_cmd(), "store", AUTH_MASTER_KEY_NAME, generated])
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or "failed to persist auth session master key")
    return generated


def encrypt_file(source: Path, destination: Path) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    key = ensure_auth_master_key()
    env = os.environ.copy()
    env["AGENT_DO_AUTH_MASTER_KEY"] = key
    proc = subprocess.run(
        [
            "openssl",
            "enc",
            "-aes-256-cbc",
            "-pbkdf2",
            "-salt",
            "-in",
            str(source),
            "-out",
            str(destination),
            "-pass",
            "env:AGENT_DO_AUTH_MASTER_KEY",
        ],
        text=True,
        capture_output=True,
        check=False,
        env=env,
    )
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or "openssl encryption failed")


def decrypt_file(source: Path, destination: Path) -> None:
    key = resolve_secret(AUTH_MASTER_KEY_NAME)
    if not key:
        raise RuntimeError("auth session master key is missing from secure storage")
    env = os.environ.copy()
    env["AGENT_DO_AUTH_MASTER_KEY"] = key
    proc = subprocess.run(
        [
            "openssl",
            "enc",
            "-d",
            "-aes-256-cbc",
            "-pbkdf2",
            "-in",
            str(source),
            "-out",
            str(destination),
            "-pass",
            "env:AGENT_DO_AUTH_MASTER_KEY",
        ],
        text=True,
        capture_output=True,
        check=False,
        env=env,
    )
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or "openssl decryption failed")


