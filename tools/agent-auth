def cmd_advance(args: argparse.Namespace) -> int:
    profile = load_profile(args.site)
    if profile is None:
        return fail(f"Unknown auth profile: {args.site}", json_mode=args.json, code="unknown_site")

    meta = get_session_meta(args.site, args.name) or {}
    live_mode = session_uses_live_browser(meta)
    initial = (
        live_probe_state(args.site, profile, name=args.name, browser_override=meta.get("live_browser"))
        if live_mode
        else probe_state(args.site, profile, name=args.name, load_saved=args.load)
    )
    validation = initial.get("validation") or {}
    if validation.get("ok"):
        payload = {
            "ok": True,
            "advanced": False,
            "validated": True,
            "site": args.site,
            "state": initial.get("state"),
            "message": "The current page is already authenticated.",
            "after": initial,
        }
        if args.json:
            print(json.dumps(payload, indent=2))
        else:
            print(f"{args.site}: already authenticated")
        return 0

    checkpoint = checkpoint_from_probe(initial, args.action)
    if checkpoint is None:
        return fail(
            "No actionable auth checkpoint detected on the current page",
            json_mode=args.json,
            code="no_checkpoint",
            extra={
                "site": args.site,
                "state": initial.get("state"),
                "probe": initial,
                "recommended": initial.get("recommended") or [f"agent-do auth ensure {args.site}"],
            },
        )

    meta = get_session_meta(args.site, args.name) or {}
    action_required = str(checkpoint.get("action_required") or "")
    action_taken: dict[str, Any] = {
        "action_required": action_required,
        "checkpoint_type": checkpoint.get("type"),
    }

    if live_mode:
        try:
            ensure_live_browser_approval(args.site, profile, browser_override=meta.get("live_browser"))
        except LiveApprovalRequiredError as exc:
            return fail(
                str(exc),
                json_mode=args.json,
                code="action_required",
                extra={
                    "site": args.site,
                    "state": "action-required",
                    "action_required": "LIVE_APPROVAL_REQUIRED",
                    "recommended": [exc.rerun],
                },
            )

    try:
        if live_mode:
            action_taken = live_advance_checkpoint(
                args.site,
                profile,
                name=args.name,
                action_required=action_required,
                browser_override=meta.get("live_browser"),
                timeout_seconds=args.timeout,
                interval_seconds=args.interval,
            )

        elif action_required == "ACCOUNT_CHOOSER_REQUIRED":
            identity = provider_identity_for_checkpoint(profile)
            selectors = account_chooser_selectors(profile)
            clicked = click_matching_identity(selectors, identity) if identity else None
            if not clicked:
                raise ActionRequiredError(
                    action_required,
                    "Account chooser is visible but no matching account selector was clickable",
                )
            wait_for_settle()
            action_taken.update({"selector": clicked, "identity": identity})

        elif action_required == "CONSENT_REQUIRED":
            selectors = consent_action_selectors(profile)
            clicked = click_first_selector(selectors)
            if not clicked:
                raise ActionRequiredError(
                    action_required,
                    "Consent screen is visible but no configured consent selector was clickable",
                )
            wait_for_settle()
            action_taken.update({"selector": clicked})

        elif action_required == "EMAIL_CHALLENGE_PENDING":
            baseline_ids = normalize_baseline_ids(meta.get("email_baseline_ids"))
            complete_email_challenge_with_baseline(profile, baseline_ids=baseline_ids)
            action_taken.update({"baseline_count": len(baseline_ids)})

        elif action_required == "PHONE_CHALLENGE_PENDING":
            baseline_ids = normalize_baseline_ids(meta.get("phone_baseline_ids"))
            complete_phone_challenge_with_baseline(profile, baseline_ids=baseline_ids)
            action_taken.update({"baseline_count": len(baseline_ids)})

        elif action_required == "TOTP_REQUIRED":
            totp_key = totp_config(profile).get("secret")
            totp_secret = resolve_secret(str(totp_key) if totp_key else None)
            missing = complete_totp_if_present(
                profile,
                totp_secret,
                selectors=totp_input_selectors(profile),
                submit_selectors=totp_submit_selectors(profile),
            )
            if missing:
                raise ActionRequiredError(
                    "MISSING_CREDENTIALS",
                    "TOTP checkpoint is visible but the configured secret is missing",
                    missing=missing,
                )
            action_taken.update({"totp_secret": str(totp_key or "")})

        elif action_required == "BACKUP_CODE_REQUIRED":
            missing, backup_code_used = complete_backup_code_if_present(profile)
            if missing:
                raise ActionRequiredError(
                    "MISSING_CREDENTIALS",
                    "Backup-code checkpoint is visible but no backup codes are configured",
                    missing=missing,
                )
            if backup_code_used:
                action_taken.update(
                    {
                        "backup_code_secret": backup_code_used[0],
                        "backup_code_used": True,
                    }
                )

        elif action_required == "PASSKEY_CHALLENGE_REQUIRED":
            alternate = click_alternate_method(profile)
            if alternate:
                action_taken.update({"alternate_selector": alternate["selector"], "alternate_kind": alternate["kind"]})
            else:
                dialog = safe_macos_dialog_probe()
                if not dialog or not dialog.get("type"):
                    raise ActionRequiredError(
                        action_required,
                        "Passkey checkpoint is active but no alternate method or actionable macOS dialog is available",
                    )
                run_macos_json("dialog", "click", "--default")
                wait_for_settle()
                action_taken.update({"dialog": dialog, "clicked": "--default"})

        elif action_required == "DEVICE_APPROVAL_REQUIRED":
            alternate = click_alternate_method(profile)
            if alternate:
                action_taken.update({"alternate_selector": alternate["selector"], "alternate_kind": alternate["kind"]})
            else:
                waited = wait_for_validation(
                    args.site,
                    profile,
                    timeout_seconds=args.timeout,
                    interval_seconds=args.interval,
                )
                action_taken.update(
                    {
                        "timeout_seconds": args.timeout,
                        "interval_seconds": args.interval,
                        "validation": waited,
                    }
                )
                if not waited.get("ok"):
                    updated = probe_state(args.site, profile, name=args.name, load_saved=False)
                    write_session_meta(
                        args.site,
                        args.name,
                        {
                            "last_strategy": "checkpoint-advance",
                            "last_validation_ok": False,
                            "state": "checkpoint",
                            "last_action_required": "DEVICE_APPROVAL_REQUIRED",
                            "last_error": f"Timed out waiting {args.timeout}s for device approval",
                        },
                    )
                    return fail(
                        f"Timed out waiting {args.timeout}s for device approval",
                        json_mode=args.json,
                        code="action_required",
                        extra={
                            "site": args.site,
                            "state": "action-required",
                            "action_required": "DEVICE_APPROVAL_REQUIRED",
                            "advanced": False,
                            "probe": updated,
                            "recommended": updated.get("recommended") or [f"agent-do auth probe {args.site}"],
                        },
                    )

        elif action_required == "CAPTCHA_REQUIRED":
            raise ActionRequiredError(action_required, "CAPTCHA is visible and cannot be advanced safely")

        else:
            raise ActionRequiredError(action_required or "UNSUPPORTED_CHECKPOINT", "No safe automation path exists for this checkpoint")

    except ActionRequiredError as exc:
        write_session_meta(
            args.site,
            args.name,
            {
                "last_strategy": "checkpoint-advance",
                "last_validation_ok": False,
                "state": "checkpoint",
                "last_action_required": exc.action_required,
                "last_error": str(exc),
            },
        )
        return fail(
            str(exc),
            json_mode=args.json,
            code="action_required",
            extra={
                "site": args.site,
                "state": "action-required",
                "action_required": exc.action_required,
                "missing": exc.missing,
                "advanced": False,
                "recommended": [f"agent-do auth probe {args.site}"],
            },
        )

    updated = (
        live_probe_state(args.site, profile, name=args.name, browser_override=meta.get("live_browser"))
        if live_mode
        else probe_state(args.site, profile, name=args.name, load_saved=False)
    )
    updated_validation = updated.get("validation") or {}
    if updated_validation.get("ok"):
        if live_mode:
            meta = persist_live_session_meta(
                args.site,
                profile,
                name=args.name,
                strategy="checkpoint-advance",
                browser_override=meta.get("live_browser"),
                state="authenticated",
                last_validation_ok=True,
            )
        else:
            meta = save_current_session(args.site, name=args.name, strategy="checkpoint-advance")
        payload = {
            "ok": True,
            "advanced": True,
            "validated": True,
            "site": args.site,
            "state": "authenticated",
            "action_taken": action_taken,
            "after": updated,
            "session": {"name": args.name, "browse_session": meta.get("browse_session"), "storage": meta.get("storage")},
        }
        if args.json:
            print(json.dumps(payload, indent=2))
        else:
            print(f"{args.site}: authenticated via checkpoint-advance")
        return 0

    next_checkpoint = checkpoint_from_probe(updated)
    write_session_meta(
        args.site,
        args.name,
        {
            "last_strategy": "checkpoint-advance",
            "last_validation_ok": False,
            "state": "checkpoint" if updated.get("checkpoints") else str(updated.get("state") or "stale"),
            "last_action_required": next_checkpoint.get("action_required") if next_checkpoint else None,
            "last_error": None,
        },
    )
    payload = {
        "ok": True,
        "advanced": True,
        "validated": False,
        "site": args.site,
        "state": updated.get("state"),
        "action_taken": action_taken,
        "after": updated,
        "recommended": updated.get("recommended") or [f"agent-do auth probe {args.site}"],
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"{args.site}: advanced checkpoint, current state is {updated.get('state')}")
    return 0


def cmd_instructions(args: argparse.Namespace) -> int:
    profile = load_profile(args.site)
    if profile is None:
        payload = {
            "site": args.site,
            "state": "unconfigured",
            "recommended": [f"agent-do auth init {args.site}"],
            "missing": ["profile"],
            "guidance": ["Create a site profile before attempting auth orchestration."],
        }
        if args.json:
            print(json.dumps(payload, indent=2))
        else:
            print(f"Create a profile first: agent-do auth init {args.site}")
        return 0

    meta = get_session_meta(args.site) or {}
    state = state_from_profile(args.site)
    recommended = [f"agent-do auth ensure {args.site}"]
    missing: list[str] = []
    guidance: list[str] = []

    strategies = profile.get("strategies", [])
    if state == "authenticated":
        recommended = [f"agent-do auth load {args.site}", f"agent-do auth validate {args.site}"]
        guidance.append("Saved authenticated state exists. Reuse it before trying a fresh login.")
    else:
        if state == "checkpoint" or meta.get("last_action_required"):
            recommended.insert(0, f"agent-do auth probe {args.site}")
            recommended.insert(1, f"agent-do auth advance {args.site}")
            guidance.append("A prior auth run stopped at a checkpoint. Probe the current branch before retrying.")
        if "browser-import" in strategies and profile.get("browser_import"):
            guidance.append("Browser import is configured and should be attempted before site credentials.")
        if "interactive" in strategies and profile.get("browser_import"):
            guidance.append(
                f"For anti-bot or human-visible login flows, use agent-do auth ensure {args.site} --strategy interactive --timeout 300."
            )
            guidance.append(
                f"For agent-controlled real-browser flows on this machine, use {live_command(args.site, profile, 'ensure', args.site, '--strategy', 'live-browser-control')}."
            )
        if "provider-refresh" in strategies and provider_type(profile) in {"github", "google"}:
            guidance.append(
                f"Provider refresh can reuse {provider_display_name(provider_type(profile))} auth to complete SSO into this site."
            )
        if email_challenge_config(profile):
            challenge = email_challenge_config(profile)
            challenge_type = str(challenge.get("type") or "code")
            guidance.append(
                f"Email challenge is configured ({challenge_type}). agent-do auth will use agent-do email to wait for the matching message."
            )
        if phone_challenge_config(profile):
            challenge = phone_challenge_config(profile)
            challenge_type = str(challenge.get("type") or "code")
            guidance.append(
                f"Phone challenge is configured ({challenge_type}). agent-do auth will use agent-do sms to wait for the matching message."
            )
        if "site-creds" in strategies:
            site_creds = ((profile.get("credentials") or {}).get("site") or {})
            username_key = site_creds.get("username")
            password_key = site_creds.get("password")
            if username_key and not resolve_secret(str(username_key)):
                missing.append(str(username_key))
            if password_key and not resolve_secret(str(password_key)):
                missing.append(str(password_key))
            totp_key = totp_config(profile).get("secret")
            if totp_key and not resolve_secret(str(totp_key)):
                guidance.append(
                    f"TOTP is configured for this provider. Store {totp_key} if the site prompts for one-time codes."
                )
            backup_key = backup_code_config(profile).get("secret")
            if backup_key and not resolve_secret(str(backup_key)):
                guidance.append(
                    f"Backup codes are configured for this provider. Store {backup_key} if the site offers recovery-code fallback."
                )
            if not missing:
                guidance.append("Site credentials are available for automated form login if session reuse fails.")

    recommended = dedupe_preserve_order(recommended)
    guidance = dedupe_preserve_order(guidance)

    payload = {
        "site": args.site,
        "state": state,
        "recommended": recommended,
        "missing": missing,
        "guidance": guidance or ["Run ensure to try saved-session, browser-import, then site credentials."],
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"State: {state}")
        for command in recommended:
            print(command)
    return 0


def cmd_clear(args: argparse.Namespace) -> int:
    profile = load_profile(args.site)
    if profile is None:
        return fail(f"Unknown auth profile: {args.site}", json_mode=args.json, code="unknown_site")
    sessions = list_session_meta(args.site)
    cleared: list[str] = []
    names = [args.name]
    if args.all:
        names = [session.get("name", "default") for session in sessions] or [args.name]

    for name in names:
        alias = browse_session_name(args.site, name)
        run_tool([*browse_cmd(), "session", "delete", alias])
        delete_session_meta(args.site, name)
        cleared.append(name)

    payload = {"ok": True, "site": args.site, "cleared": cleared}
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"Cleared auth state for {args.site}: {', '.join(cleared)}")
    return 0


def cmd_ensure(args: argparse.Namespace) -> int:
    profile = load_profile(args.site)
    if profile is None:
        return fail(f"Unknown auth profile: {args.site}", json_mode=args.json, code="unknown_site")

    name = args.name
    attempted: list[str] = []
    strategies = [args.strategy] if args.strategy else list(profile.get("strategies", []))

    for strategy in strategies:
        if strategy == "saved-session":
            attempted.append(strategy)
            if not get_session_meta(args.site, name):
                continue
            try:
                load_saved_session(args.site, name=name)
                validation = apply_validation(args.site, profile)
            except Exception as exc:
                write_session_meta(
                    args.site,
                    name,
                    {
                        "last_strategy": strategy,
                        "last_validation_ok": False,
                        "state": "stale",
                        "last_error": str(exc),
                    },
                )
                continue
            if validation["ok"]:
                meta = write_session_meta(
                    args.site,
                    name,
                    {
                        "last_strategy": strategy,
                        "validated_at": now_iso(),
                        "last_validation_ok": True,
                        "state": "authenticated",
                        "last_action_required": None,
                        "last_error": None,
                    },
                )
                payload = {
                    "site": args.site,
                    "ok": True,
                    "strategy_used": strategy,
                    "validated": True,
                    "session": {"name": name, "browse_session": meta.get("browse_session")},
                }
                print(json.dumps(payload, indent=2) if args.json else f"{args.site}: authenticated via {strategy}")
                return 0

        elif strategy == "browser-import":
            attempted.append(strategy)
            if not profile.get("browser_import"):
                continue
            try:
                imported = browser_import(args.site, profile, name=name)
                validation = apply_validation(args.site, profile)
            except Exception:
                continue
            if validation["ok"]:
                meta = persist_browse_alias(
                    args.site,
                    name=name,
                    alias=imported.get("browse_session"),
                    strategy=strategy,
                    extra={"source_browser": imported.get("source_browser")},
                )
                payload = {
                    "site": args.site,
                    "ok": True,
                    "strategy_used": strategy,
                    "validated": True,
                    "session": {"name": name, "browse_session": meta.get("browse_session")},
                }
                print(json.dumps(payload, indent=2) if args.json else f"{args.site}: authenticated via {strategy}")
                return 0
            run_tool([*browse_cmd(), "session", "delete", imported.get("browse_session", browse_session_name(args.site, name))])

        elif strategy == "site-creds":
            attempted.append(strategy)
            capture_challenge_baselines(args.site, name, profile)
            try:
                ok, missing = site_creds_login(args.site, profile, name=name)
            except ActionRequiredError as exc:
                write_session_meta(
                    args.site,
                    name,
                    {
                        "last_strategy": strategy,
                        "last_validation_ok": False,
                        "state": "checkpoint",
                        "last_error": str(exc),
                        "last_action_required": exc.action_required,
                    },
                )
                payload = {
                    "site": args.site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": attempted,
                    "action_required": exc.action_required,
                    "missing": exc.missing,
                    "message": str(exc),
                    "recommended": [f"agent-do auth probe {args.site}"],
                }
                print(json.dumps(payload, indent=2) if args.json else payload["message"])
                return 1
            if ok:
                meta = get_session_meta(args.site, name) or {}
                payload = {
                    "site": args.site,
                    "ok": True,
                    "strategy_used": strategy,
                    "validated": True,
                    "session": {"name": name, "browse_session": meta.get("browse_session")},
                }
                print(json.dumps(payload, indent=2) if args.json else f"{args.site}: authenticated via {strategy}")
                return 0
            if missing:
                payload = {
                    "site": args.site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": attempted,
                    "action_required": "MISSING_CREDENTIALS",
                    "missing": missing,
                    "message": "Required site credentials are missing from env or agent-do creds",
                }
                print(json.dumps(payload, indent=2) if args.json else f"Missing credentials: {', '.join(missing)}")
                return 1

        elif strategy == "provider-refresh":
            attempted.append(strategy)
            capture_challenge_baselines(args.site, name, profile)
            try:
                ok, missing, provider_strategy = provider_refresh_login(args.site, profile, name=name)
            except ActionRequiredError as exc:
                write_session_meta(
                    args.site,
                    name,
                    {
                        "last_strategy": strategy,
                        "last_validation_ok": False,
                        "state": "checkpoint",
                        "last_error": str(exc),
                        "last_action_required": exc.action_required,
                    },
                )
                payload = {
                    "site": args.site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": attempted,
                    "action_required": exc.action_required,
                    "missing": exc.missing,
                    "message": str(exc),
                    "recommended": [f"agent-do auth probe {args.site}"],
                }
                print(json.dumps(payload, indent=2) if args.json else payload["message"])
                return 1
            if ok:
                meta = get_session_meta(args.site, name) or {}
                payload = {
                    "site": args.site,
                    "ok": True,
                    "strategy_used": strategy,
                    "validated": True,
                    "provider_strategy_used": provider_strategy,
                    "session": {"name": name, "browse_session": meta.get("browse_session")},
                }
                print(json.dumps(payload, indent=2) if args.json else f"{args.site}: authenticated via {strategy}")
                return 0
            if missing:
                payload = {
                    "site": args.site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": attempted,
                    "action_required": "MISSING_CREDENTIALS",
                    "missing": missing,
                    "message": "Provider refresh requires additional secrets for the upstream identity provider",
                }
                print(json.dumps(payload, indent=2) if args.json else f"Missing credentials: {', '.join(missing)}")
                return 1
            continue

        elif strategy == "interactive":
            attempted.append(strategy)
            try:
                payload = interactive_browser_login(
                    args.site,
                    profile,
                    name=name,
                    timeout_seconds=int(args.timeout),
                    interval_seconds=int(args.interval),
                    browser_override=args.browser,
                    domain_override=args.domain,
                )
            except Exception as exc:
                write_session_meta(
                    args.site,
                    name,
                    {
                        "last_strategy": strategy,
                        "last_validation_ok": False,
                        "state": "checkpoint",
                        "last_error": str(exc),
                        "last_action_required": "INTERACTIVE_LOGIN",
                    },
                )
                payload = {
                    "site": args.site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": attempted,
                    "action_required": "INTERACTIVE_LOGIN",
                    "message": str(exc),
                }
                print(json.dumps(payload, indent=2) if args.json else payload["message"])
                return 1
            payload["attempted"] = attempted
            print(json.dumps(payload, indent=2) if args.json else (f"{args.site}: authenticated via interactive" if payload.get("ok") else payload["message"]))
            return 0 if payload.get("ok") else 1

        elif strategy == "live-browser-control":
            attempted.append(strategy)
            try:
                payload = live_browser_control_login(
                    args.site,
                    profile,
                    name=name,
                    timeout_seconds=int(args.timeout),
                    interval_seconds=int(args.interval),
                    browser_override=args.browser,
                )
            except LiveApprovalRequiredError as exc:
                payload = {
                    "site": args.site,
                    "ok": False,
                    "state": "action-required",
                    "attempted": attempted,
                    "action_required": "LIVE_APPROVAL_REQUIRED",
                    "message": str(exc),
                    "recommended": [exc.rerun],
                }
                print(json.dumps(payload, indent=2) if args.json else payload["message"])
                return 1
            payload["attempted"] = attempted
            print(json.dumps(payload, indent=2) if args.json else (f"{args.site}: authenticated via live-browser-control" if payload.get("ok") else payload["message"]))
            return 0 if payload.get("ok") else 1

    payload = {
        "site": args.site,
        "ok": False,
        "state": "action-required",
        "attempted": attempted,
        "action_required": "INTERACTIVE_LOGIN",
        "message": "No reusable authenticated state is available and configured strategies were exhausted",
    }
    print(json.dumps(payload, indent=2) if args.json else payload["message"])
    return 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Site-level authentication orchestration for agent-do")
    parser.add_argument("--json", action="store_true", help="Output JSON")
    sub = parser.add_subparsers(dest="command", required=True)

    init_parser = sub.add_parser("init", help="Initialize a site auth profile")
    init_parser.add_argument("site")
    init_parser.add_argument("--domain")
    init_parser.add_argument("--login-url")
    init_parser.add_argument("--browser")
    init_parser.add_argument("--provider", choices=["generic", "github", "google"])
    init_parser.add_argument("--email-code", action="store_true")
    init_parser.add_argument("--magic-link", action="store_true")
    init_parser.add_argument("--email-from")
    init_parser.add_argument("--email-subject")
    init_parser.add_argument("--email-contains")
    init_parser.add_argument("--email-domain")
    init_parser.add_argument("--email-timeout", type=int, default=120)
    init_parser.add_argument("--email-interval", type=int, default=5)
    init_parser.add_argument("--email-code-length", type=int)
    init_parser.add_argument("--email-code-regex")
    init_parser.add_argument("--sms-code", action="store_true")
    init_parser.add_argument("--sms-link", action="store_true")
    init_parser.add_argument("--sms-from")
    init_parser.add_argument("--sms-contains")
    init_parser.add_argument("--sms-domain")
    init_parser.add_argument("--sms-timeout", type=int, default=120)
    init_parser.add_argument("--sms-interval", type=int, default=5)
    init_parser.add_argument("--sms-code-length", type=int)
    init_parser.add_argument("--sms-code-regex")
    init_parser.add_argument("--force", action="store_true")
    init_parser.add_argument("--no-browser-import", action="store_true")
    init_parser.add_argument("--no-site-creds", action="store_true")

    sub.add_parser("list", help="List auth profiles")

    show_parser = sub.add_parser("show", help="Show one auth profile")
    show_parser.add_argument("site")

    status_parser = sub.add_parser("status", help="Show auth status for one site")
    status_parser.add_argument("site")
    status_parser.add_argument("--name", default="default")

    probe_parser = sub.add_parser("probe", help="Inspect the current auth checkpoint state")
    probe_parser.add_argument("site")
    probe_parser.add_argument("--name", default="default")
    probe_parser.add_argument("--load", action="store_true")

    advance_parser = sub.add_parser("advance", help="Advance one safe auth checkpoint step")
    advance_parser.add_argument("site")
    advance_parser.add_argument("--name", default="default")
    advance_parser.add_argument("--load", action="store_true")
    advance_parser.add_argument(
        "--action",
        choices=[
            "ACCOUNT_CHOOSER_REQUIRED",
            "CONSENT_REQUIRED",
            "EMAIL_CHALLENGE_PENDING",
            "PHONE_CHALLENGE_PENDING",
            "TOTP_REQUIRED",
            "BACKUP_CODE_REQUIRED",
            "PASSKEY_CHALLENGE_REQUIRED",
            "DEVICE_APPROVAL_REQUIRED",
            "CAPTCHA_REQUIRED",
        ],
    )
    advance_parser.add_argument("--timeout", type=int, default=60)
    advance_parser.add_argument("--interval", type=int, default=5)

    ensure_parser = sub.add_parser("ensure", help="Ensure authenticated state using the strategy ladder")
    ensure_parser.add_argument("site")
    ensure_parser.add_argument("--name", default="default")
    ensure_parser.add_argument("--strategy", choices=["saved-session", "browser-import", "site-creds", "provider-refresh", "interactive", "live-browser-control"])
    ensure_parser.add_argument("--timeout", type=int, default=180)
    ensure_parser.add_argument("--interval", type=int, default=5)
    ensure_parser.add_argument("--browser")
    ensure_parser.add_argument("--domain")

    save_parser = sub.add_parser("save", help="Save current authenticated browser state")
    save_parser.add_argument("site")
    save_parser.add_argument("--name", default="default")

    load_parser = sub.add_parser("load", help="Load saved authenticated browser state")
    load_parser.add_argument("site")
    load_parser.add_argument("--name", default="default")

    import_parser = sub.add_parser("import-browser", help="Import cookies/state from a real browser")
    import_parser.add_argument("site")
    import_parser.add_argument("--name", default="default")
    import_parser.add_argument("--browser")
    import_parser.add_argument("--domain")

    clear_parser = sub.add_parser("clear", help="Clear saved auth state")
    clear_parser.add_argument("site")
    clear_parser.add_argument("--name", default="default")
    clear_parser.add_argument("--all", action="store_true")

    validate_parser = sub.add_parser("validate", help="Validate authenticated state")
    validate_parser.add_argument("site")
    validate_parser.add_argument("--name", default="default")

    instructions_parser = sub.add_parser("instructions", help="Show next-step auth guidance")
    instructions_parser.add_argument("site")

    return parser


def main() -> int:
    parser = build_parser()
    argv = sys.argv[1:]
    json_mode = False
    filtered_argv: list[str] = []
    for item in argv:
        if item == "--json":
            json_mode = True
        else:
            filtered_argv.append(item)

    args = parser.parse_args(filtered_argv)
    args.json = json_mode or getattr(args, "json", False)
    if hasattr(args, "site") and getattr(args, "site", None):
        args.site = site_slug(str(args.site))

    try:
        if args.command == "init":
            return cmd_init(args)
        if args.command == "list":
            return cmd_list(args)
        if args.command == "show":
            return cmd_show(args)
        if args.command == "status":
            return cmd_status(args)
        if args.command == "probe":
            return cmd_probe(args)
        if args.command == "advance":
            return cmd_advance(args)
        if args.command == "ensure":
            return cmd_ensure(args)
        if args.command == "save":
            return cmd_save(args)
        if args.command == "load":
            return cmd_load(args)
        if args.command == "import-browser":
            return cmd_import_browser(args)
        if args.command == "clear":
            return cmd_clear(args)
        if args.command == "validate":
            return cmd_validate(args)
        if args.command == "instructions":
            return cmd_instructions(args)
        return fail("unknown command", json_mode=args.json)
    except RuntimeError as exc:
        return fail(str(exc), json_mode=args.json)


if __name__ == "__main__":
    raise SystemExit(main())
