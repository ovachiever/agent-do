def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def fail(message: str, *, json_mode: bool = False, code: str = "error", exit_code: int = 1, extra: dict[str, Any] | None = None) -> int:
    payload = {"ok": False, "error": code, "message": message}
    if extra:
        payload.update(extra)
    if json_mode:
        print(json.dumps(payload, indent=2))
    else:
        print(f"Error: {message}", file=sys.stderr)
    return exit_code


def _load_yaml_data(path: Path) -> dict[str, Any]:
    if yaml is not None:
        with open(path, encoding="utf-8") as handle:
            return yaml.safe_load(handle) or {}

    ruby = subprocess.run(
        [
            "ruby",
            "-e",
            'require "yaml"; require "json"; print JSON.generate(YAML.load_file(ARGV[0]) || {})',
            str(path),
        ],
        check=False,
        capture_output=True,
        text=True,
    )
    if ruby.returncode != 0:
        raise RuntimeError(
            f"Could not parse YAML without PyYAML. Ruby fallback failed: {ruby.stderr.strip()}"
        )
    return json.loads(ruby.stdout or "{}")


def _yaml_scalar(value: Any) -> str:
    if isinstance(value, bool):
        return "true" if value else "false"
    if value is None:
        return "null"
    if isinstance(value, (int, float)):
        return str(value)
    text = str(value)
    if text == "" or re.search(r"[:#\-\[\]\{\}\n]|^\s|\s$", text):
        return json.dumps(text)
    return text


def dump_yaml_lines(value: Any, indent: int = 0) -> list[str]:
    prefix = " " * indent
    if isinstance(value, dict):
        lines: list[str] = []
        for key, item in value.items():
            if isinstance(item, dict):
                if not item:
                    lines.append(f"{prefix}{key}: {{}}")
                else:
                    lines.append(f"{prefix}{key}:")
                    lines.extend(dump_yaml_lines(item, indent + 2))
            elif isinstance(item, list):
                if not item:
                    lines.append(f"{prefix}{key}: []")
                else:
                    lines.append(f"{prefix}{key}:")
                    for entry in item:
                        if isinstance(entry, (dict, list)):
                            lines.append(f"{prefix}  -")
                            lines.extend(dump_yaml_lines(entry, indent + 4))
                        else:
                            lines.append(f"{prefix}  - {_yaml_scalar(entry)}")
            else:
                lines.append(f"{prefix}{key}: {_yaml_scalar(item)}")
        return lines

    if isinstance(value, list):
        lines = []
        for entry in value:
            if isinstance(entry, (dict, list)):
                lines.append(f"{prefix}-")
                lines.extend(dump_yaml_lines(entry, indent + 2))
            else:
                lines.append(f"{prefix}- {_yaml_scalar(entry)}")
        return lines

    return [f"{prefix}{_yaml_scalar(value)}"]


def dump_yaml_data(data: dict[str, Any]) -> str:
    return "\n".join(dump_yaml_lines(data)) + "\n"


def ensure_root() -> None:
    PROFILES_DIR.mkdir(parents=True, exist_ok=True)
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        CONFIG_PATH.write_text("version: 1\n", encoding="utf-8")


def site_slug(site: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", site.strip().lower()).strip("-")


def env_prefix(source: str) -> str:
    value = source
    if "." in source:
        value = re.sub(r"^(www\.|app\.|accounts\.)", "", source)
        value = re.sub(r"\.[a-z0-9]+$", "", value)
    return re.sub(r"[^A-Za-z0-9]+", "_", value).upper().strip("_") or "SITE"


def auth_paths(site: str, name: str = "default") -> dict[str, Path]:
    slug = site_slug(site)
    return {
        "profile": PROFILES_DIR / f"{slug}.yaml",
        "session_dir": SESSIONS_DIR / slug / name,
        "meta": SESSIONS_DIR / slug / name / "meta.json",
        "state": SESSIONS_DIR / slug / name / "state.enc",
    }


def browse_session_name(site: str, name: str = "default") -> str:
    return f"auth-{site_slug(site)}-{site_slug(name)}"


def read_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    return json.loads(path.read_text(encoding="utf-8"))


def write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def load_profile(site: str) -> dict[str, Any] | None:
    path = auth_paths(site)["profile"]
    if not path.exists():
        return None
    data = _load_yaml_data(path)
    if not isinstance(data, dict):
        return None
    return data


def list_profiles() -> list[dict[str, Any]]:
    ensure_root()
    profiles = []
    for path in sorted(PROFILES_DIR.glob("*.yaml")):
        data = _load_yaml_data(path)
        if isinstance(data, dict):
            profiles.append(data)
    return profiles


def list_session_meta(site: str) -> list[dict[str, Any]]:
    site_dir = SESSIONS_DIR / site_slug(site)
    if not site_dir.exists():
        return []
    sessions = []
    for meta_path in sorted(site_dir.glob("*/meta.json")):
        data = read_json(meta_path)
        if data:
            sessions.append(data)
    sessions.sort(key=lambda item: item.get("updated_at", ""), reverse=True)
    return sessions


def get_session_meta(site: str, name: str = "default") -> dict[str, Any] | None:
    data = read_json(auth_paths(site, name)["meta"])
    return data or None


def write_session_meta(site: str, name: str, payload: dict[str, Any]) -> dict[str, Any]:
    path_info = auth_paths(site, name)
    session_dir = path_info["session_dir"]
    session_dir.mkdir(parents=True, exist_ok=True)
    base = get_session_meta(site, name) or {
        "site": site_slug(site),
        "name": name,
        "browse_session": browse_session_name(site, name),
        "created_at": now_iso(),
    }
    base.update(payload)
    base["updated_at"] = now_iso()
    write_json(path_info["meta"], base)
    return base


def delete_session_meta(site: str, name: str) -> None:
    path_info = auth_paths(site, name)
    if path_info["session_dir"].exists():
        shutil.rmtree(path_info["session_dir"], ignore_errors=True)


def session_bundle_exists(site: str, name: str = "default") -> bool:
    return auth_paths(site, name)["state"].exists()


def default_profile(site: str, *, domain: str | None = None, login_url: str | None = None) -> dict[str, Any]:
    slug = site_slug(site)
    if slug in KNOWN_PROFILES:
        profile = copy.deepcopy(KNOWN_PROFILES[slug])
        if domain:
            if domain not in profile["domains"]:
                profile["domains"] = [domain, *profile["domains"]]
            browser_domains = profile.get("browser_import", {}).get("domains", [])
            normalized = f".{domain.lstrip('.')}"
            if normalized not in browser_domains:
                browser_domains.insert(0, normalized)
                profile["browser_import"]["domains"] = browser_domains
        if login_url:
            profile["login_url"] = login_url
        return profile

    resolved_domain = (domain or site).strip()
    title = " ".join(part.capitalize() for part in slug.replace("_", "-").split("-"))
    prefix = env_prefix(resolved_domain)
    normalized_domain = resolved_domain.lstrip(".")
    return {
        "id": slug,
        "title": title or "Site",
        "domains": [normalized_domain],
        "login_url": login_url or f"https://{normalized_domain}/login",
        "validation": {
            "url_patterns": [f"https://{normalized_domain}/*"],
            "signed_in_markers": [],
            "signed_out_markers": ["Sign in", "Log in", "Login"],
        },
        "strategies": ["saved-session", "browser-import", "site-creds", "interactive"],
        "provider": {"type": "generic"},
        "credentials": {
            "site": {
                "username": f"{prefix}_EMAIL",
                "password": f"{prefix}_PASSWORD",
            }
        },
        "browser_import": {"browser": "arc", "domains": [f".{normalized_domain}"]},
        "notes": ["Tune validation markers for this site after the first successful authenticated run."],
    }


def state_from_profile(site: str) -> str:
    profile = load_profile(site)
    if profile is None:
        return "unconfigured"
    meta = get_session_meta(site)
    if not meta or (not session_bundle_exists(site) and not meta.get("browse_session")):
        return "configured"
    if meta.get("state") == "authenticated" and meta.get("last_validation_ok") is True:
        return "authenticated"
    if meta.get("state") == "stale" or meta.get("last_validation_ok") is False:
        return "stale"
    return "configured"


def tool_cmd_from_env(var_name: str, default: list[str]) -> list[str]:
    override = os.environ.get(var_name)
    return shlex.split(override) if override else default


def browse_cmd() -> list[str]:
    default = [str(ROOT / "tools" / "agent-browse" / "agent-browse")]
    return tool_cmd_from_env("AGENT_DO_AUTH_BROWSE_CMD", default)


def creds_cmd() -> list[str]:
    default = [str(ROOT / "tools" / "agent-creds")]
    return tool_cmd_from_env("AGENT_DO_AUTH_CREDS_CMD", default)


def run_tool(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True, check=False)


def run_browse(*args: str) -> dict[str, Any]:
    proc = run_tool([*browse_cmd(), "--json", *args])
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or f"browse failed: {' '.join(args)}")
    payload = json.loads(proc.stdout or "{}")
    if payload.get("success") is False:
        message = payload.get("error") or payload.get("message") or json.dumps(payload)
        raise RuntimeError(str(message))
    return payload.get("data") or payload.get("result") or payload


def resolve_secret(key: str | None) -> str | None:
    if not key:
        return None
    env_value = os.environ.get(key)
    if env_value:
        return env_value
    proc = run_tool([*creds_cmd(), "get", key, "--reveal"])
    if proc.returncode != 0:
        return None
    return proc.stdout.strip() or None


def ensure_auth_master_key() -> str:
    existing = resolve_secret(AUTH_MASTER_KEY_NAME)
    if existing:
        return existing

    generated = secrets.token_hex(32)
    proc = run_tool([*creds_cmd(), "store", AUTH_MASTER_KEY_NAME, generated])
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or "failed to persist auth session master key")
    return generated


def encrypt_file(source: Path, destination: Path) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    key = ensure_auth_master_key()
    env = os.environ.copy()
    env["AGENT_DO_AUTH_MASTER_KEY"] = key
    proc = subprocess.run(
        [
            "openssl",
            "enc",
            "-aes-256-cbc",
            "-pbkdf2",
            "-salt",
            "-in",
            str(source),
            "-out",
            str(destination),
            "-pass",
            "env:AGENT_DO_AUTH_MASTER_KEY",
        ],
        text=True,
        capture_output=True,
        check=False,
        env=env,
    )
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or "openssl encryption failed")


def decrypt_file(source: Path, destination: Path) -> None:
    key = resolve_secret(AUTH_MASTER_KEY_NAME)
    if not key:
        raise RuntimeError("auth session master key is missing from secure storage")
    env = os.environ.copy()
    env["AGENT_DO_AUTH_MASTER_KEY"] = key
    proc = subprocess.run(
        [
            "openssl",
            "enc",
            "-d",
            "-aes-256-cbc",
            "-pbkdf2",
            "-in",
            str(source),
            "-out",
            str(destination),
            "-pass",
            "env:AGENT_DO_AUTH_MASTER_KEY",
        ],
        text=True,
        capture_output=True,
        check=False,
        env=env,
    )
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or "openssl decryption failed")


def write_profile(profile: dict[str, Any], *, force: bool = False) -> Path:
    ensure_root()
    path = auth_paths(profile["id"])["profile"]
    if path.exists() and not force:
        raise FileExistsError(f"Profile already exists: {path}")
    path.write_text(dump_yaml_data(profile), encoding="utf-8")
    return path


def profile_summary(profile: dict[str, Any]) -> dict[str, Any]:
    site = str(profile.get("id", ""))
    sessions = list_session_meta(site)
    latest = sessions[0] if sessions else None
    return {
        "site": site,
        "title": profile.get("title", site),
        "domains": profile.get("domains") or [],
        "login_url": profile.get("login_url"),
        "state": state_from_profile(site),
        "last_strategy": (latest or {}).get("last_strategy"),
        "validated_at": (latest or {}).get("validated_at"),
        "session_count": len(sessions),
    }


def read_page_text() -> str:
    data = run_browse("eval", "document.body && document.body.innerText ? document.body.innerText : ''")
    return str(data.get("result", "") if isinstance(data, dict) else data)


def read_page_url() -> str:
    data = run_browse("get", "url")
    if isinstance(data, dict):
        return str(data.get("url", ""))
    return str(data or "")


def browse_count(selector: str) -> int:
    try:
        data = run_browse("get", "count", selector)
    except Exception:
        return 0
    if isinstance(data, dict):
        try:
            return int(data.get("count", 0))
        except (TypeError, ValueError):
            return 0
    return 0


def selector_exists(selector: str) -> bool:
    return browse_count(selector) > 0


def first_existing_selector(selectors: list[str]) -> str | None:
    for selector in selectors:
        if selector_exists(selector):
            return selector
    return None


def fill_first_selector(selectors: list[str], value: str) -> str | None:
    selector = first_existing_selector(selectors)
    if not selector:
        return None
    run_browse("fill", selector, value)
    return selector


def click_first_selector(selectors: list[str]) -> str | None:
    selector = first_existing_selector(selectors)
    if not selector:
        return None
    run_browse("click", selector)
    return selector


def wait_brief(milliseconds: int = 750) -> None:
    try:
        run_browse("wait", str(milliseconds))
    except Exception:
        pass


def generate_totp_code(secret: str) -> str:
    data = run_browse("auth", "totp", secret)
    if isinstance(data, dict) and data.get("code"):
        return str(data["code"])
    raise RuntimeError("Could not generate TOTP code")


def provider_type(profile: dict[str, Any]) -> str:
    provider = profile.get("provider") or {}
    return str(provider.get("type") or "generic").strip().lower()


def wait_for_settle() -> None:
    try:
        run_browse("wait", "--stable")
    except Exception:
        wait_brief(1000)


def missing_totp_keys(profile: dict[str, Any]) -> list[str]:
    totp_secret_key = (((profile.get("credentials") or {}).get("totp") or {}).get("secret"))
    if totp_secret_key:
        return [str(totp_secret_key)]
    return ["TOTP_SECRET"]


def complete_totp_if_present(
    profile: dict[str, Any],
    totp_secret: str | None,
    *,
    selectors: list[str],
    submit_selectors: list[str],
) -> list[str]:
    selector = first_existing_selector(selectors)
    if not selector:
        return []
    if not totp_secret:
        return missing_totp_keys(profile)
    code = generate_totp_code(totp_secret)
    run_browse("fill", selector, code)
    wait_brief()
    click_first_selector(submit_selectors)
    wait_for_settle()
    return []


def login_with_generic(profile: dict[str, Any], username: str, password: str, totp_secret: str | None) -> list[str]:
    login_url = profile.get("login_url")
    if login_url:
        run_browse("open", str(login_url))
    run_browse("auth", "autofill", str(username), str(password), "--submit")
    wait_for_settle()
    return complete_totp_if_present(
        profile,
        totp_secret,
        selectors=[
            'input[autocomplete="one-time-code"]',
            'input[name="otp"]',
            'input[name="totp"]',
            'input[name="code"]',
        ],
        submit_selectors=['button[type="submit"]', 'input[type="submit"]'],
    )


def login_with_github(profile: dict[str, Any], username: str, password: str, totp_secret: str | None) -> list[str]:
    login_url = profile.get("login_url")
    if login_url:
        run_browse("open", str(login_url))

    username_selector = fill_first_selector(
        [
            "#login_field",
            'input[name="login"]',
            'input[autocomplete="username"]',
            'input[type="email"]',
        ],
        username,
    )
    password_selector = fill_first_selector(
        [
            "#password",
            'input[name="password"]',
            'input[autocomplete="current-password"]',
            'input[type="password"]',
        ],
        password,
    )
    if not username_selector and not password_selector:
        return login_with_generic(profile, username, password, totp_secret)

    click_first_selector(['input[name="commit"]', 'input[type="submit"]', 'button[type="submit"]'])
    wait_for_settle()
    return complete_totp_if_present(
        profile,
        totp_secret,
        selectors=[
            'input[name="app_otp"]',
            'input[autocomplete="one-time-code"]',
            '#app_totp',
        ],
        submit_selectors=['button[type="submit"]', 'input[type="submit"]'],
    )


def login_with_google(profile: dict[str, Any], username: str, password: str, totp_secret: str | None) -> list[str]:
    login_url = profile.get("login_url")
    if login_url:
        run_browse("open", str(login_url))

    email_selector = fill_first_selector(
        [
            'input[type="email"]',
            'input[name="identifier"]',
            'input[autocomplete="username"]',
        ],
        username,
    )
    if not email_selector:
        return login_with_generic(profile, username, password, totp_secret)

    click_first_selector(["#identifierNext", "#identifierNext button", 'button[type="button"]'])
    wait_for_settle()

    password_selector = fill_first_selector(
        [
            'input[type="password"]',
            'input[name="Passwd"]',
            'input[autocomplete="current-password"]',
        ],
        password,
    )
    if not password_selector:
        return []

    click_first_selector(["#passwordNext", "#passwordNext button", 'button[type="button"]'])
    wait_for_settle()
    return complete_totp_if_present(
        profile,
        totp_secret,
        selectors=[
            'input[name="totpPin"]',
            'input[autocomplete="one-time-code"]',
        ],
        submit_selectors=["#totpNext", "#totpNext button", 'button[type="button"]'],
    )


def run_site_login_adapter(profile: dict[str, Any], username: str, password: str, totp_secret: str | None) -> list[str]:
    provider = provider_type(profile)
    if provider == "github":
        return login_with_github(profile, username, password, totp_secret)
    if provider == "google":
        return login_with_google(profile, username, password, totp_secret)
    return login_with_generic(profile, username, password, totp_secret)


def apply_validation(site: str, profile: dict[str, Any]) -> dict[str, Any]:
    validation = profile.get("validation") or {}
    current_url = read_page_url().strip()
    if (not current_url or current_url == "about:blank") and profile.get("login_url"):
        run_browse("open", str(profile["login_url"]))
        current_url = read_page_url().strip()

    body_text = read_page_text()
    body_lower = body_text.lower()
    signed_out_markers = [marker for marker in validation.get("signed_out_markers", []) if marker]
    signed_in_markers = [marker for marker in validation.get("signed_in_markers", []) if marker]
    url_patterns = [pattern for pattern in validation.get("url_patterns", []) if pattern]

    matched_out = [marker for marker in signed_out_markers if marker.lower() in body_lower]
    matched_in = [marker for marker in signed_in_markers if marker.lower() in body_lower]
    matched_urls = [pattern for pattern in url_patterns if fnmatch.fnmatch(current_url, pattern)]

    ok = not matched_out and bool(matched_in or matched_urls or (not signed_in_markers and not signed_out_markers))
    state = "authenticated" if ok else "stale"

    details = {
        "ok": ok,
        "site": site,
        "state": state,
        "url": current_url,
        "matched": {
            "signed_in_markers": matched_in,
            "signed_out_markers": matched_out,
            "url_patterns": matched_urls,
        },
    }
    return details


def save_current_session(site: str, *, name: str = "default", strategy: str) -> dict[str, Any]:
    alias = browse_session_name(site, name)
    run_browse("session", "save", alias, f"agent-do auth session for {site}")
    return persist_browse_alias(site, name=name, alias=alias, strategy=strategy)


def persist_browse_alias(site: str, *, name: str = "default", alias: str | None = None, strategy: str, extra: dict[str, Any] | None = None) -> dict[str, Any]:
    alias = alias or browse_session_name(site, name)
    path_info = auth_paths(site, name)
    with tempfile.TemporaryDirectory() as tmpdir:
        export_path = Path(tmpdir) / "session.json"
        run_browse("session", "export", alias, str(export_path))
        encrypt_file(export_path, path_info["state"])

    run_tool([*browse_cmd(), "session", "delete", alias])

    payload = {
        "browse_session": alias,
        "storage": "encrypted-bundle",
        "bundle_path": str(path_info["state"]),
        "last_strategy": strategy,
        "validated_at": now_iso(),
        "last_validation_ok": True,
        "state": "authenticated",
    }
    if extra:
        payload.update(extra)
    return write_session_meta(site, name, payload)


def load_saved_session(site: str, *, name: str = "default") -> dict[str, Any]:
    meta = get_session_meta(site, name)
    if not meta:
        raise FileNotFoundError(f"No saved auth session for {site}")
    alias = meta.get("browse_session") or browse_session_name(site, name)
    state_path = auth_paths(site, name)["state"]
    if state_path.exists():
        with tempfile.TemporaryDirectory() as tmpdir:
            import_path = Path(tmpdir) / "session.json"
            decrypt_file(state_path, import_path)
            run_browse("session", "import", str(import_path), str(alias))
            run_browse("session", "load", str(alias))
        run_tool([*browse_cmd(), "session", "delete", str(alias)])
    else:
        run_browse("session", "load", str(alias))
    return meta


def browser_import(site: str, profile: dict[str, Any], *, name: str = "default") -> dict[str, Any]:
    config = profile.get("browser_import") or {}
    browser = str(config.get("browser") or "arc")
    domains = config.get("domains") or []
    alias = browse_session_name(site, name)
    args = ["session", "import-browser", alias, "--browser", browser]
    if domains:
        args.extend(["--domain", str(domains[0])])
    run_browse(*args)
    run_browse("session", "load", alias)
    return {"browse_session": alias, "last_strategy": "browser-import", "source_browser": browser}


def site_creds_login(site: str, profile: dict[str, Any], *, name: str = "default") -> tuple[bool, list[str]]:
    creds = ((profile.get("credentials") or {}).get("site") or {})
    totp_creds = ((profile.get("credentials") or {}).get("totp") or {})
    username_key = creds.get("username")
    password_key = creds.get("password")
    totp_key = totp_creds.get("secret")
    missing: list[str] = []
    username = resolve_secret(str(username_key) if username_key else None)
    password = resolve_secret(str(password_key) if password_key else None)
    totp_secret = resolve_secret(str(totp_key) if totp_key else None)
    if not username and username_key:
        missing.append(str(username_key))
    if not password and password_key:
        missing.append(str(password_key))
    if missing:
        return False, missing

    adapter_missing = run_site_login_adapter(profile, str(username), str(password), totp_secret)
    if adapter_missing:
        return False, adapter_missing
    validation = apply_validation(site, profile)
    if validation["ok"]:
        save_current_session(site, name=name, strategy="site-creds")
        return True, []
    write_session_meta(
        site,
        name,
        {
            "browse_session": browse_session_name(site, name),
            "last_strategy": "site-creds",
            "last_validation_ok": False,
            "state": "stale",
            "last_error": "validation_failed_after_site_creds",
        },
    )
    return False, []


def cmd_init(args: argparse.Namespace) -> int:
    site = site_slug(args.site)
    if not site or not SITE_RE.match(site):
        return fail("site id must be kebab/underscore-safe lowercase text", json_mode=args.json, code="invalid_site")

    profile = default_profile(site, domain=args.domain, login_url=args.login_url)
    if args.browser:
        profile.setdefault("browser_import", {})["browser"] = args.browser
    if args.no_browser_import:
        profile["strategies"] = [entry for entry in profile.get("strategies", []) if entry != "browser-import"]
        profile.pop("browser_import", None)
    if args.no_site_creds:
        profile["strategies"] = [entry for entry in profile.get("strategies", []) if entry != "site-creds"]
        profile.get("credentials", {}).pop("site", None)
    try:
        path = write_profile(profile, force=args.force)
    except FileExistsError as exc:
        return fail(str(exc), json_mode=args.json, code="profile_exists")

    payload = {
        "ok": True,
        "site": site,
        "path": str(path),
        "strategies": profile.get("strategies", []),
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"Initialized auth profile for {site}")
        print(path)
    return 0


def cmd_list(args: argparse.Namespace) -> int:
