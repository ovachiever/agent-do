def alternate_backup_available(profile: dict[str, Any]) -> bool:
    secret_name = backup_code_secret_name(profile)
    if not secret_name:
        return False
    raw_value, codes = available_backup_codes(secret_name)
    return raw_value is not None and bool(codes)


def preferred_alternate_method_order(profile: dict[str, Any]) -> list[str]:
    order: list[str] = []
    if alternate_totp_available(profile):
        order.append("totp")
    if alternate_password_available(profile):
        order.append("password")
    if alternate_backup_available(profile):
        order.append("backup-code")
    order.append("generic")
    return dedupe_preserve_order(order)


def visible_alternate_methods(profile: dict[str, Any]) -> list[dict[str, str]]:
    visible: list[dict[str, str]] = []
    for selector in alternate_method_selectors(profile):
        if selector_exists(selector):
            visible.append({"selector": selector, "kind": alternate_method_kind(selector)})
    return visible


def preferred_alternate_method(profile: dict[str, Any]) -> dict[str, str] | None:
    visible = visible_alternate_methods(profile)
    if not visible:
        return None
    order = preferred_alternate_method_order(profile)
    for kind in order:
        for candidate in visible:
            if candidate["kind"] == kind:
                return candidate
    return visible[0]


def first_alternate_method_selector(profile: dict[str, Any]) -> str | None:
    candidate = preferred_alternate_method(profile)
