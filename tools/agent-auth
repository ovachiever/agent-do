def open_cmd() -> list[str]:
    override = os.environ.get("AGENT_DO_AUTH_OPEN_CMD")
    if override:
        return shlex.split(override)
    if sys.platform == "darwin":
        return ["open"]
    if shutil.which("xdg-open"):
        return ["xdg-open"]
    if os.name == "nt":
        return ["cmd", "/c", "start", ""]
    return ["open"]


def run_tool(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True, check=False)


def browser_app_name(browser: str | None) -> str | None:
    value = (browser or "").strip().lower()
    if value == "comet":
        return "Comet"
    if value == "atlas":
        return "ChatGPT Atlas"
    if value == "arc":
        return "Arc"
    if value == "chrome":
        return "Google Chrome"
    if value == "brave":
        return "Brave Browser"
    if value == "edge":
        return "Microsoft Edge"
    if value == "safari":
        return "Safari"
    return None


def open_system_browser(url: str, *, browser: str | None = None) -> None:
    opener = open_cmd()
    override = os.environ.get("AGENT_DO_AUTH_OPEN_CMD")
    if override:
        cmd = [*opener, url]
        if browser:
            cmd.extend(["--browser", browser])
    else:
        app_name = browser_app_name(browser)
        if sys.platform == "darwin" and opener and Path(opener[0]).name == "open" and app_name:
            cmd = [*opener, "-a", app_name, url]
        else:
            cmd = [*opener, url]
    proc = run_tool(cmd)
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"failed to open {url}"
        raise RuntimeError(detail)


def run_browse(*args: str) -> dict[str, Any]:
    proc = run_tool([*browse_cmd(), "--json", *args])
    if proc.returncode != 0:
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or f"browse failed: {' '.join(args)}")
    payload = json.loads(proc.stdout or "{}")
    if payload.get("success") is False:
        message = payload.get("error") or payload.get("message") or json.dumps(payload)
        raise RuntimeError(str(message))
    return payload.get("data") or payload.get("result") or payload


