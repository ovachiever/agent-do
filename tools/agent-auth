def live_detect_checkpoints(profile: dict[str, Any], text: str) -> list[dict[str, Any]]:
    lowered = text.lower()
    checkpoints: list[dict[str, Any]] = []

    captcha = live_captcha_result(text)
    if captcha.get("hasCaptcha"):
        checkpoints.append(
            {
                "type": "captcha",
                "action_required": "CAPTCHA_REQUIRED",
                "source": "live-browser",
                "details": {"types": captcha.get("types", [])},
            }
        )

    email_challenge = email_challenge_config(profile)
    if email_challenge and any(marker in lowered for marker in ["check your email", "we emailed you", "verification code", "magic link"]):
        checkpoints.append(
            {
                "type": "email-challenge",
                "action_required": "EMAIL_CHALLENGE_PENDING",
                "source": "email",
                "details": {"command": build_email_probe_command(email_challenge)},
            }
        )

    phone_challenge = phone_challenge_config(profile)
    if phone_challenge and any(marker in lowered for marker in ["check your phone", "we texted you", "texted you a code", "sms"]):
        checkpoints.append(
            {
                "type": "sms-challenge",
                "action_required": "PHONE_CHALLENGE_PENDING",
                "source": "sms",
                "details": {"command": build_phone_probe_command(phone_challenge)},
            }
        )

    device_markers = match_text_markers(
        text,
        [
            "check your phone",
            "approve sign in",
            "approve the sign in",
            "approve this sign-in",
            "tap yes on your phone",
            "notification sent to your phone",
            "check your device",
        ],
    )
    if device_markers:
        details = {"markers": device_markers}
        alternate = extract_text_selectors(alternate_method_selectors(profile))
        if alternate:
            details["alternate_texts"] = alternate
        checkpoints.append(
            {
                "type": "device-approval",
                "action_required": "DEVICE_APPROVAL_REQUIRED",
                "source": "live-browser",
                "details": details,
            }
        )

    totp_markers = match_text_markers(
        text,
        [
            "two-factor",
            "two factor",
            "authenticator",
            "one-time code",
            "verification code",
            "enter the code from your app",
        ],
    )
    if totp_markers:
        checkpoints.append(
            {
                "type": "totp",
                "action_required": "TOTP_REQUIRED",
                "source": "live-browser",
                "details": {"markers": totp_markers},
            }
        )

    backup_markers = match_text_markers(text, backup_code_markers(profile))
    if backup_markers:
        checkpoints.append(
            {
                "type": "backup-code",
                "action_required": "BACKUP_CODE_REQUIRED",
                "source": "live-browser",
                "details": {"markers": backup_markers, "secret_name": backup_code_secret_name(profile)},
            }
        )

    passkey_markers = match_text_markers(
        text,
        ["use a passkey", "sign in with a passkey", "security key", "touch your security key", "passkey"],
    )
    if passkey_markers:
        details = {"markers": passkey_markers}
        alternate = extract_text_selectors(alternate_method_selectors(profile))
        if alternate:
            details["alternate_texts"] = alternate
        checkpoints.append(
            {
                "type": "passkey",
                "action_required": "PASSKEY_CHALLENGE_REQUIRED",
                "source": "live-browser",
                "details": details,
            }
        )

    account_markers = match_text_markers(text, ["choose an account", "select an account", "pick an account", "continue as"])
    if account_markers:
        checkpoints.append(
            {
                "type": "account-chooser",
                "action_required": "ACCOUNT_CHOOSER_REQUIRED",
                "source": "live-browser",
                "details": {"markers": account_markers},
            }
        )

    consent_markers = match_text_markers(text, ["authorize", "grant access", "allow access", "approve access", "continue"])
    if any(marker in lowered for marker in ["authorize", "grant access", "allow access", "approve access"]):
        checkpoints.append(
            {
                "type": "consent",
                "action_required": "CONSENT_REQUIRED",
                "source": "live-browser",
                "details": {"markers": consent_markers},
            }
        )

    seen: set[str] = set()
    output: list[dict[str, Any]] = []
    for checkpoint in sort_checkpoints(checkpoints):
        key = f"{checkpoint.get('action_required')}:{checkpoint.get('type')}"
        if key in seen:
            continue
        seen.add(key)
        output.append(checkpoint)
    return output


def live_apply_validation(site: str, profile: dict[str, Any], *, browser_override: str | None = None) -> dict[str, Any]:
    text = live_screen_text()
    lowered = text.lower()
    validation = profile.get("validation") or {}
    signed_out_markers = [marker for marker in validation.get("signed_out_markers", []) if marker]
    signed_in_markers = [marker for marker in validation.get("signed_in_markers", []) if marker]
    matched_out = [marker for marker in signed_out_markers if marker.lower() in lowered]
    matched_in = [marker for marker in signed_in_markers if marker.lower() in lowered]
    login_form = live_login_form_result(text)
    checkpoints = live_detect_checkpoints(profile, text)
    browser_details = live_browser_details(profile, browser_override=browser_override)
    ok = not matched_out and not login_form.get("found") and not checkpoints and (
        bool(matched_in) or not signed_in_markers
    )
    return {
        "ok": ok,
        "site": site,
        "state": "authenticated" if ok else "stale",
        "url": None,
        "window": browser_details.get("app"),
        "login_form": login_form,
        "checkpoints": checkpoints,
        "matched": {
            "signed_in_markers": matched_in,
            "signed_out_markers": matched_out,
            "url_patterns": [],
        },
        "text_excerpt": text[:2000],
    }


