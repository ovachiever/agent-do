def complete_phone_challenge_with_baseline(profile: dict[str, Any], baseline_ids: list[str] | None = None) -> list[str]:
    challenge = phone_challenge_config(profile)
    if not challenge:
        return []

    challenge_type = str(challenge.get("type") or "code").strip().lower()
    timeout_seconds = int(challenge.get("timeout_seconds") or 120)
    poll_seconds = int(challenge.get("poll_interval_seconds") or 5)
    contact_filter = str(challenge.get("contact_contains") or challenge.get("from_contains") or "").strip()
    contains_filter = str(challenge.get("contains") or "").strip()
    unread_only = bool(challenge.get("unread", True))

    common_args: list[str] = []
    if contact_filter:
        common_args.extend(["--contact", contact_filter])
    if contains_filter:
        common_args.extend(["--contains", contains_filter])
    if unread_only:
        common_args.append("--unread")
    for message_id in baseline_ids or []:
        common_args.extend(["--exclude-id", message_id])
    common_args.extend(["--timeout", str(timeout_seconds), "--interval", str(poll_seconds)])

    try:
        if challenge_type == "link":
            link_args = ["link", *common_args]
            domain = str(challenge.get("domain") or "").strip()
            if domain:
                link_args.extend(["--domain", domain])
            payload = run_sms_json(*link_args)
            link = str(payload.get("link") or "")
            if not link:
                raise RuntimeError("No SMS link returned from message lookup")
            run_browse("open", link)
            wait_for_settle()
            raise_if_passkey_challenge_visible()
            return []

        input_selectors = list(
            challenge.get("input_selectors")
            or [
                'input[autocomplete="one-time-code"]',
                'input[name="code"]',
                'input[id*="code"]',
                'input[name*="code"]',
            ]
        )
        submit_selectors = list(
            challenge.get("submit_selectors")
            or ['button[type="submit"]', 'input[type="submit"]', 'button[type="button"]']
        )
        selector = first_existing_selector(input_selectors)
        if not selector:
            raise ActionRequiredError(
                "PHONE_CHALLENGE_FIELD_MISSING",
                "Phone challenge is configured but no verification code field is visible on the page",
            )
        code_args = ["code", *common_args]
        code_regex = str(challenge.get("code_regex") or "").strip()
        code_length = challenge.get("code_length")
        if code_regex:
            code_args.extend(["--regex", code_regex])
        elif code_length:
            code_args.extend(["--length", str(code_length)])
        payload = run_sms_json(*code_args)
        code = str(payload.get("code") or "")
        if not code:
            raise RuntimeError("No verification code returned from SMS lookup")
        run_browse("fill", selector, code)
        wait_brief()
        click_first_selector(submit_selectors)
        wait_for_settle()
        raise_if_passkey_challenge_visible()
        return []
    except ActionRequiredError:
        raise
    except RuntimeError as exc:
        raise ActionRequiredError("PHONE_CHALLENGE_TIMEOUT", str(exc))


