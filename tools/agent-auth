        return login_with_github(profile, username, password, totp_secret)
    if provider == "google":
        return login_with_google(profile, username, password, totp_secret)
    return login_with_generic(profile, username, password, totp_secret)


def ensure_provider_state(provider_site: str, profile: dict[str, Any], *, name: str = "default") -> tuple[bool, list[str], str | None]:
    if get_session_meta(provider_site, name):
        try:
            load_saved_session(provider_site, name=name)
            validation = apply_validation(provider_site, profile)
        except Exception:
            validation = {"ok": False}
        if validation.get("ok"):
            write_session_meta(
                provider_site,
                name,
                {
                    "last_strategy": "saved-session",
                    "validated_at": now_iso(),
                    "last_validation_ok": True,
                    "state": "authenticated",
                    "last_action_required": None,
                    "last_error": None,
                },
            )
            return True, [], "saved-session"

    if profile.get("browser_import"):
        try:
            imported = browser_import(provider_site, profile, name=name)
            validation = apply_validation(provider_site, profile)
        except Exception:
            validation = {"ok": False}
        if validation.get("ok"):
            persist_browse_alias(
                provider_site,
                name=name,
                alias=imported.get("browse_session"),
                strategy="browser-import",
                extra={"source_browser": imported.get("source_browser")},
            )
            return True, [], "browser-import"
        run_tool([*browse_cmd(), "session", "delete", browse_session_name(provider_site, name)])

    if "site-creds" in list(profile.get("strategies", [])):
        ok, missing = site_creds_login(provider_site, profile, name=name)
        if ok:
            return True, [], "site-creds"
        if missing:
            return False, missing, "site-creds"

    return False, [], None


def provider_refresh_login(site: str, profile: dict[str, Any], *, name: str = "default") -> tuple[bool, list[str], str | None]:
    provider_name = provider_type(profile)
    if provider_name not in {"github", "google"}:
        return False, [], None

    provider_profile = load_profile(provider_name) or default_profile(provider_name)
    provider_ok, missing, provider_strategy = ensure_provider_state(provider_name, provider_profile, name="default")
    if not provider_ok:
        return False, missing, provider_strategy
    provider_username = resolve_profile_username(provider_profile)

    if site_slug(site) == provider_name:
        return True, [], provider_strategy

    login_url = profile.get("login_url")
    if login_url:
        run_browse("open", str(login_url))
    phone_baseline = capture_phone_baseline(profile)
    email_baseline = capture_email_baseline(profile)

    refresh_cfg = provider_refresh_config(profile)
    defaults = provider_default_refresh(provider_name)
    sso_selectors = list(refresh_cfg.get("sso_selectors") or defaults.get("sso_selectors", []))

    if sso_selectors:
        clicked = click_first_selector(sso_selectors)
        if not clicked:
            return False, [], provider_strategy
        wait_for_settle()

    checkpoint_state = provider_checkpoint_state(profile, provider_name, provider_username)

    complete_phone_challenge_with_baseline(profile, baseline_ids=phone_baseline)
    complete_email_challenge_with_baseline(profile, baseline_ids=email_baseline)
    raise_if_passkey_challenge_visible()
    raise_if_manual_checkpoint_visible(profile)

    validation = apply_validation(site, profile)
    if validation["ok"]:
        save_current_session(site, name=name, strategy="provider-refresh")
        write_session_meta(
            site,
            name,
            {
                "provider_strategy": provider_strategy,
                "provider_checkpoint": checkpoint_state,
            },
        )
        return True, [], provider_strategy

    write_session_meta(
        site,
        name,
        {
            "browse_session": browse_session_name(site, name),
            "last_strategy": "provider-refresh",
            "last_validation_ok": False,
            "state": "stale",
            "last_error": f"validation_failed_after_{provider_name}_provider_refresh",
            "provider_strategy": provider_strategy,
            "provider_checkpoint": checkpoint_state,
        },
    )
    return False, [], provider_strategy


def apply_validation(site: str, profile: dict[str, Any]) -> dict[str, Any]:
    validation = profile.get("validation") or {}
    current_url = read_page_url().strip()
    if (not current_url or current_url == "about:blank") and profile.get("login_url"):
        run_browse("open", str(profile["login_url"]))
        current_url = read_page_url().strip()

    body_text = read_page_text()
    body_lower = body_text.lower()
    signed_out_markers = [marker for marker in validation.get("signed_out_markers", []) if marker]
    signed_in_markers = [marker for marker in validation.get("signed_in_markers", []) if marker]
    url_patterns = [pattern for pattern in validation.get("url_patterns", []) if pattern]

    matched_out = [marker for marker in signed_out_markers if marker.lower() in body_lower]
    matched_in = [marker for marker in signed_in_markers if marker.lower() in body_lower]
    matched_urls = [pattern for pattern in url_patterns if fnmatch.fnmatch(current_url, pattern)]

    ok = not matched_out and bool(matched_in or matched_urls or (not signed_in_markers and not signed_out_markers))
    state = "authenticated" if ok else "stale"

    details = {
        "ok": ok,
        "site": site,
        "state": state,
        "url": current_url,
        "matched": {
            "signed_in_markers": matched_in,
            "signed_out_markers": matched_out,
            "url_patterns": matched_urls,
        },
    }
    return details


def save_current_session(site: str, *, name: str = "default", strategy: str) -> dict[str, Any]:
    alias = browse_session_name(site, name)
    run_browse("session", "save", alias, f"agent-do auth session for {site}")
    return persist_browse_alias(site, name=name, alias=alias, strategy=strategy)


def persist_browse_alias(site: str, *, name: str = "default", alias: str | None = None, strategy: str, extra: dict[str, Any] | None = None) -> dict[str, Any]:
    alias = alias or browse_session_name(site, name)
    path_info = auth_paths(site, name)
    with tempfile.TemporaryDirectory() as tmpdir:
        export_path = Path(tmpdir) / "session.json"
        run_browse("session", "export", alias, str(export_path))
        encrypt_file(export_path, path_info["state"])

    run_tool([*browse_cmd(), "session", "delete", alias])

    payload = {
        "browse_session": alias,
        "storage": "encrypted-bundle",
        "bundle_path": str(path_info["state"]),
        "last_strategy": strategy,
        "validated_at": now_iso(),
        "last_validation_ok": True,
        "state": "authenticated",
        "last_action_required": None,
        "last_error": None,
    }
    if extra:
        payload.update(extra)
    return write_session_meta(site, name, payload)


def load_saved_session(site: str, *, name: str = "default") -> dict[str, Any]:
    meta = get_session_meta(site, name)
    if not meta:
        raise FileNotFoundError(f"No saved auth session for {site}")
    alias = meta.get("browse_session") or browse_session_name(site, name)
    state_path = auth_paths(site, name)["state"]
    if state_path.exists():
        with tempfile.TemporaryDirectory() as tmpdir:
            import_path = Path(tmpdir) / "session.json"
            decrypt_file(state_path, import_path)
            run_browse("session", "import", str(import_path), str(alias))
            run_browse("session", "load", str(alias))
        run_tool([*browse_cmd(), "session", "delete", str(alias)])
    else:
        run_browse("session", "load", str(alias))
    return meta


def browser_import(site: str, profile: dict[str, Any], *, name: str = "default") -> dict[str, Any]:
    config = profile.get("browser_import") or {}
    browser = str(config.get("browser") or "arc")
    domains = config.get("domains") or []
    alias = browse_session_name(site, name)
    args = ["session", "import-browser", alias, "--browser", browser]
    if domains:
        args.extend(["--domain", str(domains[0])])
    run_browse(*args)
    run_browse("session", "load", alias)
    return {"browse_session": alias, "last_strategy": "browser-import", "source_browser": browser}


def site_creds_login(site: str, profile: dict[str, Any], *, name: str = "default") -> tuple[bool, list[str]]:
    creds = ((profile.get("credentials") or {}).get("site") or {})
    totp_creds = ((profile.get("credentials") or {}).get("totp") or {})
    username_key = creds.get("username")
    password_key = creds.get("password")
    totp_key = totp_creds.get("secret")
    missing: list[str] = []
    username = resolve_secret(str(username_key) if username_key else None)
    password = resolve_secret(str(password_key) if password_key else None)
    totp_secret = resolve_secret(str(totp_key) if totp_key else None)
    if not username and username_key:
        missing.append(str(username_key))
    if not password and password_key:
        missing.append(str(password_key))
    if missing:
        return False, missing

    adapter_missing = run_site_login_adapter(profile, str(username), str(password), totp_secret)
    if adapter_missing:
        return False, adapter_missing
    raise_if_passkey_challenge_visible()
    validation = apply_validation(site, profile)
    if validation["ok"]:
        save_current_session(site, name=name, strategy="site-creds")
        return True, []
    write_session_meta(
        site,
        name,
        {
            "browse_session": browse_session_name(site, name),
            "last_strategy": "site-creds",
            "last_validation_ok": False,
            "state": "stale",
            "last_error": "validation_failed_after_site_creds",
        },
    )
    return False, []


def cmd_init(args: argparse.Namespace) -> int:
    site = site_slug(args.site)
    if not site or not SITE_RE.match(site):
        return fail("site id must be kebab/underscore-safe lowercase text", json_mode=args.json, code="invalid_site")

    profile = default_profile(site, domain=args.domain, login_url=args.login_url, provider_override=args.provider)
    if args.browser:
        profile.setdefault("browser_import", {})["browser"] = args.browser
    if args.no_browser_import:
        profile["strategies"] = [entry for entry in profile.get("strategies", []) if entry != "browser-import"]
        profile.pop("browser_import", None)
    if args.no_site_creds:
        profile["strategies"] = [entry for entry in profile.get("strategies", []) if entry != "site-creds"]
        profile.get("credentials", {}).pop("site", None)
    if args.email_code or args.magic_link:
        challenge_type = "link" if args.magic_link else "code"
        challenge: dict[str, Any] = {
            "type": challenge_type,
            "unread": True,
            "timeout_seconds": int(args.email_timeout),
            "poll_interval_seconds": int(args.email_interval),
        }
        if args.email_from:
            challenge["from_contains"] = args.email_from
        if args.email_subject:
            challenge["subject_contains"] = args.email_subject
        if args.email_contains:
            challenge["contains"] = args.email_contains
        if args.email_domain and challenge_type == "link":
            challenge["domain"] = args.email_domain
        if args.email_code_length and challenge_type == "code":
            challenge["code_length"] = int(args.email_code_length)
        if args.email_code_regex and challenge_type == "code":
            challenge["code_regex"] = args.email_code_regex
        profile["email_challenge"] = challenge
    if args.sms_code or args.sms_link:
        challenge_type = "link" if args.sms_link else "code"
        challenge = {
            "type": challenge_type,
            "unread": True,
            "timeout_seconds": int(args.sms_timeout),
            "poll_interval_seconds": int(args.sms_interval),
        }
        if args.sms_from:
            challenge["contact_contains"] = args.sms_from
        if args.sms_contains:
            challenge["contains"] = args.sms_contains
        if args.sms_domain and challenge_type == "link":
            challenge["domain"] = args.sms_domain
        if args.sms_code_length and challenge_type == "code":
            challenge["code_length"] = int(args.sms_code_length)
        if args.sms_code_regex and challenge_type == "code":
            challenge["code_regex"] = args.sms_code_regex
        profile["phone_challenge"] = challenge
    try:
        path = write_profile(profile, force=args.force)
    except FileExistsError as exc:
        return fail(str(exc), json_mode=args.json, code="profile_exists")

    payload = {
        "ok": True,
        "site": site,
        "path": str(path),
        "strategies": profile.get("strategies", []),
    }
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"Initialized auth profile for {site}")
        print(path)
    return 0


