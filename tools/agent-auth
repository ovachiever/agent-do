    return payload


def run_macos_json(*args: str) -> dict[str, Any]:
    proc = run_tool([*macos_cmd(), *args])
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"macos failed: {' '.join(args)}"
        raise RuntimeError(detail)
    payload = json.loads(proc.stdout or "{}")
    if payload.get("error"):
        raise RuntimeError(str(payload.get("error")))
    return payload


def capture_email_baseline(profile: dict[str, Any], *, limit: int = 25) -> list[str]:
    if not email_challenge_config(profile):
        return []
    try:
        payload = run_email_json("snapshot", "--limit", str(limit))
    except Exception:
        return []
    recent = ((payload.get("recent_messages") or {}).get("items") or [])
    baseline_ids: list[str] = []
    for item in recent:
        if isinstance(item, dict):
            message_id = str(item.get("id") or "").strip()
            if message_id:
                baseline_ids.append(message_id)
    return baseline_ids


def capture_phone_baseline(profile: dict[str, Any], *, limit: int = 25) -> list[str]:
    if not phone_challenge_config(profile):
        return []
    try:
        payload = run_sms_json("snapshot", "--limit", str(limit))
    except Exception:
        return []
    recent = ((payload.get("recent_messages") or {}).get("items") or [])
    baseline_ids: list[str] = []
