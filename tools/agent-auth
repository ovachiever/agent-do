def build_email_probe_command(challenge: dict[str, Any]) -> str:
    challenge_type = str(challenge.get("type") or "code").strip().lower()
    command = ["agent-do", "email", "link" if challenge_type == "link" else "code"]
    from_filter = str(challenge.get("from_contains") or "").strip()
    subject_filter = str(challenge.get("subject_contains") or "").strip()
    contains = str(challenge.get("contains") or "").strip()
    domain = str(challenge.get("domain") or "").strip()
    code_length = challenge.get("code_length")
    code_regex = str(challenge.get("code_regex") or "").strip()
    if from_filter:
        command.extend(["--from", from_filter])
    if subject_filter:
        command.extend(["--subject", subject_filter])
    if contains:
        command.extend(["--contains", contains])
    if domain and challenge_type == "link":
        command.extend(["--domain", domain])
    if code_regex and challenge_type == "code":
        command.extend(["--regex", code_regex])
    elif code_length and challenge_type == "code":
        command.extend(["--length", str(code_length)])
    return " ".join(shlex.quote(part) for part in command)


