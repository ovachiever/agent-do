#!/usr/bin/env bash
# agent-manna - Manna CLI wrapper
# Part of the agent-do ecosystem

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY_NAME="manna-core"

find_binary() {
    local candidates=(
        "$SCRIPT_DIR/target/release/$BINARY_NAME"
        "$SCRIPT_DIR/target/debug/$BINARY_NAME"
    )

    for candidate in "${candidates[@]}"; do
        if [[ -x "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    if command -v "$BINARY_NAME" &>/dev/null; then
        command -v "$BINARY_NAME"
        return 0
    fi

    return 1
}

BINARY="$(find_binary)" || {
    cat >&2 << EOF
Error: $BINARY_NAME binary not found

Expected one of:
  $SCRIPT_DIR/target/release/$BINARY_NAME
  $SCRIPT_DIR/target/debug/$BINARY_NAME
  \$PATH entry named $BINARY_NAME

To build the binary, run:
  cd "$SCRIPT_DIR"
  cargo build --release
EOF
    exit 1
}

# Exec binary with all arguments
exec "$BINARY" "$@"
