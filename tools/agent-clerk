    echo "$enterprise" | python3 -c "
import sys, json
conns = json.load(sys.stdin)
out = [{'id': c['id'], 'name': c.get('name',''), 'protocol': c.get('protocol',''), 'domain': c.get('domain','')} for c in conns]
print(json.dumps(out, indent=4))
"
    echo ","

    # JWT templates
    local jwt
    jwt=$(clerk_request GET "/jwt_templates" 2>/dev/null || echo "[]")
    echo '  "jwt_templates": '
    echo "$jwt" | python3 -c "
import sys, json
templates = json.load(sys.stdin)
out = [{'id': t['id'], 'name': t.get('name','')} for t in (templates if isinstance(templates, list) else [])]
print(json.dumps(out, indent=4))
"

    echo "}"
}

# --- Dispatch ---

main() {
    if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_help
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        # Users
        users|ls)                    cmd_users "$@" ;;
        user)                        cmd_user "$@" ;;
        user-create)                 cmd_user_create "$@" ;;
        user-update)                 cmd_user_update "$@" ;;
        user-delete)                 cmd_user_delete "$@" ;;
        user-ban)                    cmd_user_ban "$@" ;;
        user-unban)                  cmd_user_unban "$@" ;;
        user-lock)                   cmd_user_lock "$@" ;;
        user-unlock)                 cmd_user_unlock "$@" ;;
        user-count)                  cmd_user_count "$@" ;;
        user-orgs)                   cmd_user_orgs "$@" ;;
        user-metadata)               cmd_user_metadata "$@" ;;
        # Organizations
        orgs)                        cmd_orgs "$@" ;;
        org)                         cmd_org "$@" ;;
        org-create)                  cmd_org_create "$@" ;;
        org-update)                  cmd_org_update "$@" ;;
        org-delete)                  cmd_org_delete "$@" ;;
        org-members)                 cmd_org_members "$@" ;;
        org-add-member)              cmd_org_add_member "$@" ;;
        org-remove-member)           cmd_org_remove_member "$@" ;;
        org-update-member)           cmd_org_update_member "$@" ;;
        org-invitations)             cmd_org_invitations "$@" ;;
        org-invite)                  cmd_org_invite "$@" ;;
        org-revoke-invite)           cmd_org_revoke_invite "$@" ;;
        # Roles & Permissions
        roles)                       cmd_roles "$@" ;;
        role)                        cmd_role "$@" ;;
        role-create)                 cmd_role_create "$@" ;;
        permissions)                 cmd_permissions "$@" ;;
        permission-create)           cmd_permission_create "$@" ;;
        # Sessions
        sessions)                    cmd_sessions "$@" ;;
        session)                     cmd_session "$@" ;;
        session-revoke)              cmd_session_revoke "$@" ;;
        # OAuth
        oauth-apps)                  cmd_oauth_apps "$@" ;;
        oauth-app)                   cmd_oauth_app "$@" ;;
        oauth-app-create)            cmd_oauth_app_create "$@" ;;
        oauth-app-update)            cmd_oauth_app_update "$@" ;;
        oauth-app-delete)            cmd_oauth_app_delete "$@" ;;
        oauth-app-rotate-secret)     cmd_oauth_app_rotate_secret "$@" ;;
        # Enterprise SSO
        enterprise-connections)      cmd_enterprise_connections "$@" ;;
        enterprise-connection)       cmd_enterprise_connection "$@" ;;
        enterprise-connection-create) cmd_enterprise_connection_create "$@" ;;
        enterprise-connection-update) cmd_enterprise_connection_update "$@" ;;
        enterprise-connection-delete) cmd_enterprise_connection_delete "$@" ;;
        # JWT Templates
        jwt-templates)               cmd_jwt_templates "$@" ;;
        jwt-template)                cmd_jwt_template "$@" ;;
        jwt-template-create)         cmd_jwt_template_create "$@" ;;
        jwt-template-delete)         cmd_jwt_template_delete "$@" ;;
        # Invitations
        invitations)                 cmd_invitations "$@" ;;
        invite)                      cmd_invite "$@" ;;
        invite-revoke)               cmd_invite_revoke "$@" ;;
        # Allowlist / Blocklist
        allowlist)                   cmd_allowlist "$@" ;;
        allowlist-add)               cmd_allowlist_add "$@" ;;
        allowlist-remove)            cmd_allowlist_remove "$@" ;;
        blocklist)                   cmd_blocklist "$@" ;;
        blocklist-add)               cmd_blocklist_add "$@" ;;
        blocklist-remove)            cmd_blocklist_remove "$@" ;;
        # Admin
        whoami)                      cmd_whoami "$@" ;;
        jwks)                        cmd_jwks "$@" ;;
        snapshot)                    cmd_snapshot "$@" ;;
        *)
            echo "Unknown command: $cmd" >&2
            echo "Run 'agent-clerk --help' for usage" >&2
            exit 1
            ;;
    esac
}

main "$@"
