# --- Helpers ---

clerk_request() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"

    if [[ -z "${CLERK_SECRET_KEY:-}" ]]; then
        echo '{"error":"CLERK_SECRET_KEY not set"}' >&2
        return 1
    fi

    local url="${CLERK_API}${endpoint}"

    local args=(-s -X "$method" "$url" \
        -H "Authorization: Bearer $CLERK_SECRET_KEY" \
        -H "Accept: application/json" \
        -H "Content-Type: application/json")

    if [[ -n "$data" ]]; then
        args+=(-d "$data")
    fi

    local http_code body
    body=$(curl -w '\n%{http_code}' "${args[@]}")
    http_code=$(echo "$body" | tail -1)
    body=$(echo "$body" | sed '$d')

    # Handle rate limiting (429)
    if [[ "$http_code" == "429" ]]; then
        local retry_after
        retry_after=$(curl -s -o /dev/null -D- -X "$method" "$url" \
            -H "Authorization: Bearer $CLERK_SECRET_KEY" 2>/dev/null | grep -i 'retry-after' | tr -d '\r' | awk '{print $2}')
        if [[ -n "$retry_after" && "$retry_after" =~ ^[0-9]+$ ]]; then
            sleep "$retry_after"
        else
            sleep 2
        fi
        body=$(curl -w '\n%{http_code}' "${args[@]}")
        http_code=$(echo "$body" | tail -1)
        body=$(echo "$body" | sed '$d')
    fi

    # Check for API errors
    if [[ "$http_code" -ge 400 ]]; then
        echo "$body" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    errors = data.get('errors', [])
    if errors:
        for e in errors:
            msg = e.get('long_message', e.get('message', e.get('code', 'Unknown error')))
            print(f'Error: {msg}', file=sys.stderr)
    else:
        print(f'Error: HTTP {$http_code}', file=sys.stderr)
except:
    print(f'Error: HTTP {$http_code}', file=sys.stderr)
" 2>&1 >&2
        return 1
    fi

    echo "$body"
}

# Paginated list — handles both bare arrays and wrapped {data, total_count} responses
clerk_list() {
    local endpoint="$1"
    local limit="${2:-200}"

    if [[ -z "${CLERK_SECRET_KEY:-}" ]]; then
        echo '[]'
        return 1
    fi

    python3 -c "
import urllib.request, json, ssl, os

key = os.environ.get('CLERK_SECRET_KEY', '')
base = '$CLERK_API'
endpoint = '$endpoint'
limit = int('$limit')
ctx = ssl.create_default_context()

sep = '&' if '?' in endpoint else '?'
all_items = []
offset = 0

while True:
    url = f'{base}{endpoint}{sep}limit={limit}&offset={offset}'
    req = urllib.request.Request(url, headers={
        'Authorization': f'Bearer {key}',
        'Accept': 'application/json',
    })
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        body = json.loads(resp.read().decode())
    except Exception as e:
        break

    # Handle wrapped response {data: [...], total_count: N}
    if isinstance(body, dict) and 'data' in body:
        items = body['data']
        all_items.extend(items)
        total = body.get('total_count', len(all_items))
        if len(all_items) >= total or not items:
            break
    # Handle bare array response
    elif isinstance(body, list):
        all_items.extend(body)
        if len(body) < limit:
            break
    else:
        break

    offset += limit

print(json.dumps(all_items))
"
}

resolve_org() {
    local name_or_id="$1"

    if [[ "$name_or_id" == org_* ]]; then
        echo "$name_or_id"
        return 0
    fi

    # Try by slug directly (Clerk accepts slug in the path)
    local result
    result=$(clerk_request GET "/organizations/$name_or_id" 2>/dev/null)
    local org_id
    org_id=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('id',''))" 2>/dev/null)

    if [[ -n "$org_id" ]]; then
        echo "$org_id"
        return 0
    fi

    echo "Error: Organization '$name_or_id' not found" >&2
    return 1
}

resolve_user() {
    local name_or_id="$1"

    if [[ "$name_or_id" == user_* ]]; then
        echo "$name_or_id"
        return 0
    fi

    # Search by email
    local encoded
    encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name_or_id'))")
    local result
    result=$(clerk_request GET "/users?email_address[]=$encoded&limit=1" 2>/dev/null)

    local user_id
    user_id=$(echo "$result" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if isinstance(data, list) and data:
    print(data[0].get('id', ''))
" 2>/dev/null)

    if [[ -n "$user_id" ]]; then
        echo "$user_id"
        return 0
    fi

    echo "Error: User '$name_or_id' not found" >&2
    return 1
}

json_escape() {
    python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$1"
}

# --- User Commands ---

cmd_users() {
    local query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --query) query="$2"; shift 2 ;;
            *) query="$1"; shift ;;
        esac
    done

    local endpoint="/users"
    if [[ -n "$query" ]]; then
        local encoded
        encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$query'))")
        endpoint="/users?query=$encoded"
    fi

    local result
    result=$(clerk_list "$endpoint")

    echo "$result" | python3 -c "
import sys, json
users = json.load(sys.stdin)
if not users:
    print('No users found')
    sys.exit(0)
for u in users:
    uid = u.get('id', '')
    emails = u.get('email_addresses', [])
    email = emails[0].get('email_address', '') if emails else ''
    first = u.get('first_name', '') or ''
    last = u.get('last_name', '') or ''
    name = f'{first} {last}'.strip()
    banned = ' [BANNED]' if u.get('banned') else ''
    locked = ' [LOCKED]' if u.get('locked') else ''
    print(f'{uid}  {email:<40}  {name}{banned}{locked}')
"
}

cmd_user() {
    local name_or_id="${1:-}"
    [[ -z "$name_or_id" ]] && { echo "Usage: agent-clerk user <id-or-email>" >&2; return 1; }

    local user_id
    user_id=$(resolve_user "$name_or_id") || return 1

    local result
    result=$(clerk_request GET "/users/$user_id") || return 1

    echo "$result" | python3 -c "
import sys, json
u = json.load(sys.stdin)
emails = u.get('email_addresses', [])
email = emails[0].get('email_address', '') if emails else ''
print(f\"ID:          {u.get('id', '')}\")
print(f\"Email:       {email}\")
print(f\"First:       {u.get('first_name', '')}\")
print(f\"Last:        {u.get('last_name', '')}\")
print(f\"Username:    {u.get('username', '') or ''}\")
print(f\"Banned:      {u.get('banned', False)}\")
print(f\"Locked:      {u.get('locked', False)}\")
print(f\"Created:     {u.get('created_at', '')}\")
print(f\"Last Sign-in: {u.get('last_sign_in_at', 'never')}\")
pub = u.get('public_metadata', {})
priv = u.get('private_metadata', {})
if pub: print(f'Public Meta: {json.dumps(pub)}')
if priv: print(f'Private Meta: {json.dumps(priv)}')
"
}

cmd_user_create() {
    local email="" first="" last="" password=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --email) email="$2"; shift 2 ;;
            --first) first="$2"; shift 2 ;;
            --last) last="$2"; shift 2 ;;
            --password) password="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    [[ -z "$email" ]] && { echo "Usage: agent-clerk user-create --email <e> --first <f> --last <l>" >&2; return 1; }

    local body
    body=$(python3 -c "
import json
data = {'email_address': ['$email']}
if '$first': data['first_name'] = '$first'
if '$last': data['last_name'] = '$last'
if '$password': data['password'] = '$password'
print(json.dumps(data))
")

    local result
    result=$(clerk_request POST "/users" "$body") || return 1

    echo "$result" | python3 -c "
import sys, json
u = json.load(sys.stdin)
print(f\"Created: {u.get('id', '')}  {u.get('first_name', '')} {u.get('last_name', '')}\")
emails = u.get('email_addresses', [])
if emails: print(f'Email:   {emails[0].get(\"email_address\", \"\")}')
"
}

