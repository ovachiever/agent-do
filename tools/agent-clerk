    sys.exit(0)
for m in members:
    uid = m.get('public_user_data', {}).get('user_id', m.get('user_id', ''))
    email = m.get('public_user_data', {}).get('identifier', '')
    first = m.get('public_user_data', {}).get('first_name', '') or ''
    last = m.get('public_user_data', {}).get('last_name', '') or ''
