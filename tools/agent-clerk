cmd_org_add_member() {
    local org_name="${1:-}" user_name="${2:-}" role="member"
    [[ -z "$org_name" || -z "$user_name" ]] && { echo "Usage: agent-clerk org-add-member <org> <user> [--role admin|member]" >&2; return 1; }
    shift 2
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local org_id user_id
    org_id=$(resolve_org "$org_name") || return 1
    user_id=$(resolve_user "$user_name") || return 1

    clerk_request POST "/organizations/$org_id/memberships" "{\"user_id\":\"$user_id\",\"role\":\"org:$role\"}" > /dev/null || return 1
    echo "Added $user_id to $org_id as $role"
}

cmd_org_remove_member() {
    local org_name="${1:-}" user_name="${2:-}"
    [[ -z "$org_name" || -z "$user_name" ]] && { echo "Usage: agent-clerk org-remove-member <org> <user>" >&2; return 1; }
    local org_id user_id
    org_id=$(resolve_org "$org_name") || return 1
    user_id=$(resolve_user "$user_name") || return 1
