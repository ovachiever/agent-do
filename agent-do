#!/usr/bin/env bash
# agent-do - Automation CLI with structured API (AI) and natural language (human)

set -euo pipefail

AGENT_DO_HOME="${AGENT_DO_HOME:-$HOME/.agent-do}"
# Resolve through symlinks (macOS readlink, single-level)
_source="${BASH_SOURCE[0]}"
if [ -L "$_source" ]; then
    _target="$(readlink "$_source")"
    # Handle relative symlink targets
    case "$_target" in
        /*) _source="$_target" ;;
        *)  _source="$(dirname "$_source")/$_target" ;;
    esac
fi
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"

# Ensure home directory exists
mkdir -p "$AGENT_DO_HOME"

# Ensure tools directory is in PATH for this script
export PATH="$SCRIPT_DIR/tools:$PATH"

if [[ -f "$SCRIPT_DIR/lib/creds-helper.sh" ]]; then
    # shellcheck source=lib/creds-helper.sh
    source "$SCRIPT_DIR/lib/creds-helper.sh"
fi

show_help() {
    cat << 'EOF'
agent-do - Automation CLI

STRUCTURED API (for AI/scripts - no LLM, instant execution):
  agent-do <tool> <command> [args...]
  agent-do --raw <tool> <command> [args...]

  Examples:
    agent-do ios screenshot ~/Downloads/screen.png
    agent-do tui spawn htop --session my-htop
    agent-do browse open https://example.com
    agent-do network scan --port 3000
    agent-do slack send '#engineering' 'deploy complete'

NATURAL LANGUAGE (for humans - uses LLM routing):
  agent-do -n "what you want to do"
  agent-do --natural "description of intent"

  Examples:
    agent-do -n "take a screenshot of the iOS simulator"
    agent-do -n "what's using port 3000"
    agent-do -n "post deploy complete to engineering slack"

OPTIONS:
  --help, -h     Show this help
  --list, -l     List available tools
  suggest        Recommend likely tools/commands for a task
  find           Search tools by keyword
  nudges         Inspect local nudge telemetry
  bootstrap      Initialize stateful tools for the current project
  creds          Store and resolve tool credentials securely
  --status       Show active sessions and state
  --health       Check tool dependencies and readiness
  --how          Explain how to do something (uses LLM)
  --dry-run      Show what would be executed (uses LLM)
  --offline      Natural language with offline pattern matching only
  -n, --natural  Enable natural language mode (uses LLM)
  --raw          Explicit direct tool execution (bypasses NL routing)
  --json         Output structured JSON (for orchestrator integration)
  --context      Provide additional context for natural language

EXIT CODES:
  0 = success
  1 = error
  2 = needs clarification (natural or offline routing)

ENVIRONMENT:
  AGENT_DO_HOME      Config/state directory (default: ~/.agent-do)
    ANTHROPIC_API_KEY  Required for natural language mode
EOF
}

get_tool_secret_envs() {
    local tool="$1"
    python3 - "$tool" "$SCRIPT_DIR" <<'PY' 2>/dev/null || true
import sys
from pathlib import Path

tool = sys.argv[1]
script_dir = Path(sys.argv[2])
sys.path.insert(0, str(script_dir / "lib"))

from registry import load_registry, get_tool_info, get_tool_secret_envs  # noqa: E402

registry = load_registry()
info = get_tool_info(registry, tool) or {}
for key in get_tool_secret_envs(info):
    print(key)
PY
}

load_tool_credentials() {
    local tool="$1"
    [[ "$tool" == "creds" ]] && return 0
    declare -F creds_get_from_store >/dev/null 2>&1 || return 0

    local key value
    while IFS= read -r key; do
        [[ -n "$key" ]] || continue
        [[ -n "${!key:-}" ]] && continue
        value="$(creds_get_from_store "$key" 2>/dev/null || true)"
        if [[ -n "$value" ]]; then
            printf -v "$key" '%s' "$value"
            export "$key"
        fi
    done < <(get_tool_secret_envs "$tool")
}

resolve_tool_exec() {
    local tool="$1"
    local tool_path="$SCRIPT_DIR/tools/agent-$tool"

    if [[ -d "$tool_path" && -x "$tool_path/agent-$tool" ]]; then
        echo "$tool_path/agent-$tool"
        return 0
    fi

    if [[ -x "$tool_path" && ! -d "$tool_path" ]]; then
        echo "$tool_path"
        return 0
    fi

    if command -v "agent-$tool" &>/dev/null; then
        command -v "agent-$tool"
        return 0
    fi

    return 1
}

# List available tools
list_tools() {
    echo "Available tools:"
    echo ""
    for tool_path in "$SCRIPT_DIR/tools"/agent-*; do
        tool_name=$(basename "$tool_path" | sed 's/^agent-//')
        tool_exec="$(resolve_tool_exec "$tool_name" 2>/dev/null || true)"
        if [[ -n "$tool_exec" ]]; then
            # Get first line of help if available
            desc=$("$tool_exec" --help 2>/dev/null | head -1 || echo "")
            printf "  %-12s %s\n" "$tool_name" "$desc"
        fi
    done
    echo ""
    echo "Use: agent-do <tool> --help  for tool-specific help"
}

# Check if first arg is a known tool (structured API mode)
is_tool() {
    local tool="$1"
    resolve_tool_exec "$tool" &>/dev/null
}

# Execute tool directly (no LLM)
exec_tool() {
    local tool="$1"
    shift
    local tool_exec

    if ! tool_exec="$(resolve_tool_exec "$tool")"; then
        echo "Unknown tool: $tool" >&2
        exit 1
    fi

    load_tool_credentials "$tool"
    exec "$tool_exec" "$@"
}

# Natural language routing (uses LLM)
natural_route() {
    local json_mode="$1"
    local context="$2"
    shift 2
    local intent="$*"
    
    local args=()
    [[ "$json_mode" == "true" ]] && args+=(--json)
    [[ -n "$context" ]] && args+=(--context "$context")
    
    "$SCRIPT_DIR/bin/intent-router" "${args[@]}" "$intent"
    local exit_code=$?
    
    # Handle clarification needed (exit code 2)
    if [[ $exit_code -eq 2 && "$json_mode" != "true" ]]; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "ORCHESTRATOR: You must answer this question and retry."
        echo "Do not proceed with other tasks until resolved."
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi
    
    exit $exit_code
}

case "${1:-}" in
    --help|-h)
        show_help
        ;;
    --list|-l)
        list_tools
        ;;
    suggest)
        shift || true
        exec "$SCRIPT_DIR/bin/suggest" suggest "$@"
        ;;
    find)
        shift || true
        exec "$SCRIPT_DIR/bin/suggest" find "$@"
        ;;
    nudges)
        shift || true
        exec "$SCRIPT_DIR/bin/nudges" "$@"
        ;;
    bootstrap)
        shift || true
        exec "$SCRIPT_DIR/bin/bootstrap" "$@"
        ;;
    --status)
        exec "$SCRIPT_DIR/bin/status"
        ;;
    --health)
        shift || true
        exec "$SCRIPT_DIR/bin/health" "$@"
        ;;
    --how)
        shift
        if [[ -z "${1:-}" ]]; then
            echo "Usage: agent-do --how \"your question\""
            exit 1
        fi
        exec "$SCRIPT_DIR/bin/intent-router" --explain "$*"
        ;;
    --dry-run)
        shift
        if [[ -z "${1:-}" ]]; then
            echo "Usage: agent-do --dry-run \"what you want to do\""
            exit 1
        fi
        exec "$SCRIPT_DIR/bin/intent-router" --dry-run "$*"
        ;;
    --offline)
        shift
        if [[ -z "${1:-}" ]]; then
            echo "Usage: agent-do --offline \"what you want to do\""
            exit 1
        fi
        # Use pattern matcher instead of LLM router. Pattern matcher may exit 2
        # for clarification-needed results, so capture output before handling status.
        pattern_status=0
        if ! result=$("$SCRIPT_DIR/bin/pattern-matcher" --json "$*" 2>&1); then
            pattern_status=$?
        fi
        if ! echo "$result" | python3 -c "import sys,json; json.load(sys.stdin)" >/dev/null 2>&1; then
            echo "$result"
            exit "${pattern_status:-1}"
        fi
        tool=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r.get('tool') or '')")
        clarification=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r.get('clarification_needed') or '')")
        explanation=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r.get('explanation') or '')")

        if [[ -z "$tool" ]]; then
            echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r.get('clarification_needed', 'No match found'))"
            exit 1
        fi

        if [[ -n "$clarification" ]]; then
            echo "$clarification"
            [[ -n "$explanation" ]] && echo "  ($explanation)"
            exit 2
        fi

        cmd=$(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r.get('command', ''))")
        args_display=$(echo "$result" | python3 -c "import sys,json,shlex; r=json.load(sys.stdin); print(' '.join(shlex.quote(arg) for arg in r.get('args', [])))")
        mapfile -t args_array < <(echo "$result" | python3 -c "import sys,json; r=json.load(sys.stdin); [print(arg) for arg in r.get('args', [])]")

        echo "→ agent-$tool $cmd${args_display:+ $args_display} [offline match]"
        [[ -n "$explanation" ]] && echo "  ($explanation)"
        echo

        if [[ -n "$cmd" ]]; then
            exec_tool "$tool" "$cmd" "${args_array[@]}"
        fi

        exec_tool "$tool" "${args_array[@]}"
        ;;
    -n|--natural)
        # Natural language mode (human-friendly)
        shift
        if [[ -z "${1:-}" ]]; then
            echo "Usage: agent-do -n \"what you want to do\""
            exit 1
        fi
        # Check for --context
        context=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --context)
                    context="$2"
                    shift 2
                    ;;
                *)
                    break
                    ;;
            esac
        done
        natural_route "false" "$context" "$@"
        ;;
    --json)
        # JSON mode for orchestrators (uses LLM)
        shift
        if [[ -z "${1:-}" ]]; then
            echo '{"status":"error","error":"no_intent","message":"Usage: agent-do --json \"what you want\""}'
            exit 1
        fi
        # Check for --context flag
        intent=""
        context=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --context)
                    context="$2"
                    shift 2
                    ;;
                *)
                    intent="$intent $1"
                    shift
                    ;;
            esac
        done
        intent="${intent# }"  # Trim leading space
        natural_route "true" "$context" "$intent"
        ;;
    --raw)
        shift
        if [[ -z "${1:-}" ]]; then
            echo "Usage: agent-do --raw <tool> <command> [args...]"
            exit 1
        fi
        if is_tool "$1"; then
            exec_tool "$@"
        fi
        echo "Unknown tool: $1"
        exit 1
        ;;
    --context)
        # --context without -n implies natural language mode
        shift
        context="$1"
        shift
        if [[ -z "${1:-}" ]]; then
            echo "Usage: agent-do --context \"answer\" -n \"original intent\""
            exit 1
        fi
        # Skip -n if present
        [[ "${1:-}" == "-n" || "${1:-}" == "--natural" ]] && shift
        natural_route "false" "$context" "$@"
        ;;
    "")
        echo "Usage: agent-do <tool> <command> [args...]"
        echo "       agent-do -n \"natural language\""
        echo "Try: agent-do --help or agent-do --list"
        exit 1
        ;;
    -*)
        echo "Unknown option: $1"
        echo "Try: agent-do --help"
        exit 1
        ;;
    *)
        # Check if first arg is a tool name (structured API)
        if is_tool "$1"; then
            exec_tool "$@"
        else
            # Not a known tool - show helpful error
            echo "Unknown tool: $1"
            echo ""
            echo "Did you mean:"
            echo "  agent-do -n \"$*\"     (natural language mode)"
            echo "  agent-do --list       (see available tools)"
            exit 1
        fi
        ;;
esac
